#!/bin/bash
# usage-snapshot — one command → JSON of every paid AI surface's usage headroom + resets.
# ER-078 primitive. Zero-LLM at runtime (descent rung: full script). Confidence is
# honest per row: live | estimated | stale | unknown — percentages are never invented.
#
#   usage-snapshot                 # JSON to stdout
#   usage-snapshot --history       # also append ~/.usage-snapshot/history.jsonl + roll waste.tsv
#   usage-snapshot --html          # also render ~/.usage-snapshot/dashboard.html
#   usage-snapshot --no-ccusage    # skip the (slower) Claude ccusage source
#
# Env overrides (used by tests): USAGE_SNAPSHOT_DIR, CODEX_SESSIONS_DIR, CLAUDE_GLM_BIN,
# COPILOT_DB, HERMES_BIN, SKIP_CCUSAGE=1, CCUSAGE_BLOCKS_JSON/CCUSAGE_WEEKLY_JSON (fixture files).
set -u
umask 077

STATE_DIR="${USAGE_SNAPSHOT_DIR:-$HOME/.usage-snapshot}"
CODEX_SESSIONS="${CODEX_SESSIONS_DIR:-$HOME/.codex/sessions}"
GLM_BIN="${CLAUDE_GLM_BIN:-claude-glm}"
COPILOT_DB_PATH="${COPILOT_DB:-$HOME/.copilot/session-store.db}"
HERMES="${HERMES_BIN:-hermes}"
NOW_EPOCH=$(date +%s)
NOW_ISO=$(date -u +%Y-%m-%dT%H:%M:%SZ)
# Pinned after inspecting ccusage 20.0.17's npm metadata/tarball and exercising
# its native macOS CLI. Keep scheduled collection reproducible and price lookup
# offline; upgrade only as an explicit, verified repository change.
CCUSAGE_PACKAGE="ccusage@20.0.17"
CCUSAGE_TIMEOUT_SECONDS="${CCUSAGE_TIMEOUT_SECONDS:-120}"
GLM_TIMEOUT_SECONDS="${GLM_TIMEOUT_SECONDS:-15}"
NOTIFY_TIMEOUT_SECONDS="${NOTIFY_TIMEOUT_SECONDS:-15}"
NPX_BIN="${NPX_BIN:-npx}"
CCUSAGE_BIN="${CCUSAGE_BIN:-}"
SNAPSHOT_RC=0

DO_HISTORY=0; DO_HTML=0; NO_CCUSAGE="${SKIP_CCUSAGE:-0}"
for a in "$@"; do
  case "$a" in
    --history) DO_HISTORY=1 ;;
    --html) DO_HTML=1 ;;
    --no-ccusage) NO_CCUSAGE=1 ;;
    -h|--help) sed -n '2,14p' "$0"; exit 0 ;;
    *) echo "usage-snapshot: unknown arg: $a" >&2; exit 64 ;;
  esac
done

if ! mkdir -p "$STATE_DIR" 2>/dev/null; then
  echo "usage-snapshot: cannot create state directory" >&2
  exit 73
fi
ROWS_TMP=$(mktemp "${TMPDIR:-/tmp}/usage-snapshot.XXXXXX") || exit 1
HISTORY_LOCK=""
HISTORY_LOCK_HELD=0

process_start_identity() {
  ps -o lstart= -p "$1" 2>/dev/null | sed 's/^[[:space:]]*//;s/[[:space:]]*$//'
}

release_history_lock() {
  [ "$HISTORY_LOCK_HELD" -eq 1 ] || return 0
  [ -d "$HISTORY_LOCK" ] && [ ! -L "$HISTORY_LOCK" ] || return 0
  [ "$(cat "$HISTORY_LOCK/pid" 2>/dev/null)" = "$$" ] || return 0
  [ "$(cat "$HISTORY_LOCK/start" 2>/dev/null)" = "$(process_start_identity $$)" ] || return 0
  rm -f "$HISTORY_LOCK/pid" "$HISTORY_LOCK/start" 2>/dev/null || return 0
  rmdir "$HISTORY_LOCK" 2>/dev/null || return 0
  HISTORY_LOCK_HELD=0
}

cleanup() {
  rm -f "$ROWS_TMP"
  release_history_lock
}
trap cleanup EXIT

acquire_history_lock() {
  local lock="$1" owner_pid="" owner_start="" live_start="" unexpected=""
  if ! mkdir "$lock" 2>/dev/null; then
    [ -d "$lock" ] && [ ! -L "$lock" ] || return 73
    [ ! -L "$lock/pid" ] && [ ! -L "$lock/start" ] || return 73
    owner_pid=$(cat "$lock/pid" 2>/dev/null || true)
    owner_start=$(cat "$lock/start" 2>/dev/null || true)
    case "$owner_pid" in
      ''|*[!0-9]*) ;;
      *)
        live_start=$(process_start_identity "$owner_pid")
        if [ -n "$owner_start" ] && [ "$live_start" = "$owner_start" ] && kill -0 "$owner_pid" 2>/dev/null; then
          return 75
        fi
        ;;
    esac
    unexpected=$(find "$lock" -mindepth 1 -maxdepth 1 ! -name pid ! -name start -print -quit 2>/dev/null)
    [ -z "$unexpected" ] || return 73
    rm -f "$lock/pid" "$lock/start" 2>/dev/null || return 73
    rmdir "$lock" 2>/dev/null || return 73
    mkdir "$lock" 2>/dev/null || return 73
  fi
  owner_start=$(process_start_identity $$)
  [ -n "$owner_start" ] || { rmdir "$lock" 2>/dev/null; return 73; }
  printf '%s\n' "$$" > "$lock/pid" 2>/dev/null \
    && printf '%s\n' "$owner_start" > "$lock/start" 2>/dev/null \
    || { rm -f "$lock/pid" "$lock/start" 2>/dev/null; rmdir "$lock" 2>/dev/null; return 73; }
  HISTORY_LOCK="$lock"
  HISTORY_LOCK_HELD=1
  return 0
}

emit() { printf '%s\n' "$1" >> "$ROWS_TMP"; }

# row helper: all fields explicit, null allowed
row() { # provider window used_pct resets_at_epoch confidence health source notes extra_json
  local extra="${9:-}"
  [ -z "$extra" ] && extra='{}'
  jq -cn --arg p "$1" --arg w "$2" --argjson up "${3:-null}" --argjson ra "${4:-null}" \
        --arg c "$5" --arg h "$6" --arg s "$7" --arg n "$8" --argjson x "$extra" --argjson now "$NOW_EPOCH" '
    {provider:$p, window:$w, used_pct:$up,
     resets_at:(if $ra==null then null else ($ra|todate) end),
     resets_in_min:(if $ra==null then null else ((($ra-$now)/60)|floor) end),
     confidence:$c, health:$h, source:$s, notes:$n} + $x'
}

# Bound scheduled native/npm work without adding a third-party timeout utility.
# A new process session lets timeout cleanup reap npx and any descendants.
run_bounded() {
  local timeout_s="$1"
  shift
  python3 -c '
import os, signal, subprocess, sys
try:
    timeout_s = int(sys.argv[1])
    if timeout_s < 1 or timeout_s > 600:
        raise ValueError
except ValueError:
    sys.exit(64)
argv = sys.argv[2:]
try:
    proc = subprocess.Popen(argv, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL,
                            start_new_session=True)
except OSError:
    sys.exit(127)
try:
    out, _ = proc.communicate(timeout=timeout_s)
except subprocess.TimeoutExpired:
    try:
        os.killpg(proc.pid, signal.SIGTERM)
    except ProcessLookupError:
        pass
    try:
        proc.communicate(timeout=1)
    except subprocess.TimeoutExpired:
        try:
            os.killpg(proc.pid, signal.SIGKILL)
        except ProcessLookupError:
            pass
        proc.communicate()
    sys.exit(124)
sys.stdout.buffer.write(out)
sys.exit(proc.returncode if proc.returncode >= 0 else 128 - proc.returncode)
' "$timeout_s" "$@"
}

run_ccusage() {
  if [ -n "$CCUSAGE_BIN" ]; then
    run_bounded "$CCUSAGE_TIMEOUT_SECONDS" "$CCUSAGE_BIN" "$@"
  else
    run_bounded "$CCUSAGE_TIMEOUT_SECONDS" "$NPX_BIN" -y "$CCUSAGE_PACKAGE" "$@"
  fi
}

# ---------- codex: newest rollout carries real rate_limits (both windows) ----------
codex_rows() {
  local newest="" mtime=0 age_h line
  newest=$(find "$CODEX_SESSIONS" -type f -name 'rollout-*.jsonl' 2>/dev/null -print0 \
    | xargs -0 stat -f '%m %N' 2>/dev/null | sort -rn | head -1 | cut -d' ' -f2-)
  if [ -z "$newest" ]; then
    emit "$(row codex 5h null null unknown unknown none 'no rollout files found')"
    emit "$(row codex weekly null null unknown unknown none 'no rollout files found')"
    return
  fi
  mtime=$(stat -f %m "$newest" 2>/dev/null || echo 0)
  age_h=$(( (NOW_EPOCH - mtime) / 3600 ))
  line=$(tail -n 400 "$newest" | jq -c '.. | objects
          | select(has("primary") and has("secondary"))' \
          2>/dev/null | tail -1)
  if [ -z "$line" ]; then
    emit "$(row codex 5h null null unknown unknown "$newest" 'rollout has no valid rate_limits window')"
    emit "$(row codex weekly null null unknown unknown "$newest" 'rollout has no valid rate_limits window')"
    return
  fi
  local slots_valid
  slots_valid=$(printf '%s' "$line" | jq -r '
    [.primary, .secondary]
    | all(. == null or (type=="object"
        and (.window_minutes|type)=="number"
        and (.window_minutes==300 or .window_minutes==10080)))')
  if [ "$slots_valid" != "true" ]; then
    SNAPSHOT_RC=1
    emit "$(row codex 5h null null unknown down rollout-rate_limits 'current event contains invalid rate window metadata')"
    emit "$(row codex weekly null null unknown down rollout-rate_limits 'current event contains invalid rate window metadata')"
    return
  fi
  local base_conf=live; [ "$age_h" -ge 6 ] && base_conf=stale
  local five weekly plan
  # `primary` and `secondary` are transport slots, not stable window names.
  # Map by duration; classify malformed supported windows separately from omission.
  five=$(printf '%s' "$line" | jq -c '
    [.primary, .secondary] | map(select(type=="object" and .window_minutes==300)) as $matches
    | if ($matches|length)==0 then {status:"missing"}
      elif ($matches|length)!=1 then {status:"invalid"}
      else $matches[0] as $v
      | if (($v.used_percent==null) or (($v.used_percent|type)=="number" and $v.used_percent>=0 and $v.used_percent<=100))
          and (($v.resets_at==null) or (($v.resets_at|type)=="number" and $v.resets_at>=0 and $v.resets_at<=4102444800 and ($v.resets_at|floor)==$v.resets_at))
        then {status:"valid",value:$v} else {status:"invalid"} end
      end')
  weekly=$(printf '%s' "$line" | jq -c '
    [.primary, .secondary] | map(select(type=="object" and .window_minutes==10080)) as $matches
    | if ($matches|length)==0 then {status:"missing"}
      elif ($matches|length)!=1 then {status:"invalid"}
      else $matches[0] as $v
      | if (($v.used_percent==null) or (($v.used_percent|type)=="number" and $v.used_percent>=0 and $v.used_percent<=100))
          and (($v.resets_at==null) or (($v.resets_at|type)=="number" and $v.resets_at>=0 and $v.resets_at<=4102444800 and ($v.resets_at|floor)==$v.resets_at))
        then {status:"valid",value:$v} else {status:"invalid"} end
      end')
  plan=$(printf '%s' "$line" | jq -r '.plan_type // "?"')

  local used reset conf status
  status=$(printf '%s' "$five" | jq -r '.status')
  if [ "$status" = "missing" ]; then
    emit "$(row codex 5h null null unknown ok rollout-rate_limits "plan=$plan; current event omitted a valid 5h window")"
  elif [ "$status" = "invalid" ]; then
    SNAPSHOT_RC=1
    emit "$(row codex 5h null null unknown down rollout-rate_limits "plan=$plan; current event contains an invalid 5h window")"
  else
    used=$(printf '%s' "$five" | jq -r 'if .value.used_percent==null then "null" else (.value.used_percent|tostring) end')
    reset=$(printf '%s' "$five" | jq -r 'if .value.resets_at==null then "null" else (.value.resets_at|tostring) end')
    conf="$base_conf"
    # A reset that already passed means the number is from a closed window.
    [ "$reset" != "null" ] && [ "$reset" -le "$NOW_EPOCH" ] 2>/dev/null && conf=stale
    emit "$(row codex 5h "$used" "$reset" "$conf" ok rollout-rate_limits "plan=$plan; rollout age ${age_h}h; mapped by window_minutes=300; refresh: run any tiny codex exec")"
  fi

  status=$(printf '%s' "$weekly" | jq -r '.status')
  if [ "$status" = "missing" ]; then
    emit "$(row codex weekly null null unknown ok rollout-rate_limits "plan=$plan; current event omitted a valid weekly window")"
  elif [ "$status" = "invalid" ]; then
    SNAPSHOT_RC=1
    emit "$(row codex weekly null null unknown down rollout-rate_limits "plan=$plan; current event contains an invalid weekly window")"
  else
    used=$(printf '%s' "$weekly" | jq -r 'if .value.used_percent==null then "null" else (.value.used_percent|tostring) end')
    reset=$(printf '%s' "$weekly" | jq -r 'if .value.resets_at==null then "null" else (.value.resets_at|tostring) end')
    conf="$base_conf"
    [ "$reset" != "null" ] && [ "$reset" -le "$NOW_EPOCH" ] 2>/dev/null && conf=stale
    emit "$(row codex weekly "$used" "$reset" "$conf" ok rollout-rate_limits "plan=$plan; mapped by window_minutes=10080")"
  fi
}

# ---------- claude: ccusage local-JSONL estimates (limits undisclosed → never a %) ----------
claude_rows() {
  if [ "$NO_CCUSAGE" = "1" ]; then
    emit "$(row claude session-5h null null unknown ok skipped 'ccusage skipped (--no-ccusage)')"
    return
  fi
  local bj="" wj="" blocks_ok=1 weekly_ok=1
  if [ -n "${CCUSAGE_BLOCKS_JSON:-}" ]; then
    bj=$(cat "$CCUSAGE_BLOCKS_JSON" 2>/dev/null) || blocks_ok=0
  else
    bj=$(run_ccusage blocks --json --active --offline) || blocks_ok=0
  fi
  if [ -n "${CCUSAGE_WEEKLY_JSON:-}" ]; then
    wj=$(cat "$CCUSAGE_WEEKLY_JSON" 2>/dev/null) || weekly_ok=0
  else
    wj=$(run_ccusage weekly --json --offline) || weekly_ok=0
  fi

  if [ "$blocks_ok" -ne 1 ] || ! printf '%s' "$bj" | jq -e '.blocks | type=="array"' >/dev/null 2>&1; then
    SNAPSHOT_RC=1
    emit "$(row claude session-5h null null unknown down ccusage-blocks 'ccusage blocks failed or returned invalid JSON')"
  elif printf '%s' "$bj" | jq -e '.blocks|length==0 or (.blocks[0].isActive==false)' >/dev/null 2>&1; then
    emit "$(row claude session-5h null null estimated ok ccusage-blocks 'no active block (idle)')"
  else
    local block_norm end_epoch extra_s
    block_norm=$(printf '%s' "$bj" | jq -ce '
      .blocks[0] as $b
      | select($b.isActive==true
          and ($b.totalTokens|type)=="number" and $b.totalTokens>=0 and $b.totalTokens<=1e18
          and ($b.endTime|type)=="string"
          and ($b.burnRate|type)=="object"
          and ($b.burnRate.tokensPerMinuteForIndicator|type)=="number"
          and $b.burnRate.tokensPerMinuteForIndicator>=0 and $b.burnRate.tokensPerMinuteForIndicator<=1e12
          and ($b.costUSD|type)=="number" and $b.costUSD>=0 and $b.costUSD<=1e12
          and ($b.models|type)=="array" and all($b.models[]; type=="string"))
      | {tokens:($b.totalTokens|floor),end:$b.endTime,burn:($b.burnRate.tokensPerMinuteForIndicator|floor),cost:($b.costUSD|floor),models:($b.models|join(","))}' \
      2>/dev/null) || block_norm=""
    end_epoch=null
    if [ -n "$block_norm" ]; then
      end_epoch=$(date -j -u -f '%Y-%m-%dT%H:%M:%S' "$(printf '%s' "$block_norm" | jq -r '.end' | cut -c1-19)" +%s 2>/dev/null || echo null)
    fi
    if [ -z "$block_norm" ] || [ "$end_epoch" = "null" ]; then
      SNAPSHOT_RC=1
      emit "$(row claude session-5h null null unknown down ccusage-blocks 'ccusage active block failed schema or timestamp validation')"
    else
      extra_s=$(printf '%s' "$block_norm" | jq -c '{tokens_used:.tokens,burn_tpm:.burn,est_cost_usd:.cost,models:.models}')
      emit "$(row claude session-5h null "$end_epoch" estimated ok ccusage-blocks \
        'limits undisclosed; burn+reset only' "$extra_s")"
    fi
  fi
  if [ "$weekly_ok" -ne 1 ] || ! printf '%s' "$wj" | jq -e '.weekly | type=="array"' >/dev/null 2>&1; then
    SNAPSHOT_RC=1
    emit "$(row claude weekly null null unknown down ccusage-weekly 'ccusage weekly failed or returned invalid JSON')"
  elif printf '%s' "$wj" | jq -e '.weekly | length==0' >/dev/null 2>&1; then
    emit "$(row claude weekly null null unknown ok ccusage-weekly 'no weekly data')"
  else
    local weekly_norm extra_w wd add now_hm wr
    weekly_norm=$(printf '%s' "$wj" | jq -ce '
      .weekly[-1] as $w
      | select(($w|type)=="object"
          and ($w.totalTokens|type)=="number" and $w.totalTokens>=0 and $w.totalTokens<=1e18
          and ($w.totalCost|type)=="number" and $w.totalCost>=0 and $w.totalCost<=1e12)
      | {tokens:($w.totalTokens|floor),cost:($w.totalCost|floor)}' 2>/dev/null) || weekly_norm=""
    if [ -z "$weekly_norm" ]; then
      SNAPSHOT_RC=1
      emit "$(row claude weekly null null unknown down ccusage-weekly 'ccusage weekly record failed schema validation')"
      return
    fi
    extra_w=$(printf '%s' "$weekly_norm" | jq -c '{tokens_used:.tokens,est_cost_usd:.cost}')
    # weekly window resets Wednesdays 5:00 PM local time (from Trevor's plan screen)
    wd=$(date +%u); add=$(( (3 - wd + 7) % 7 )); now_hm=$(date +%H%M)
    [ "$add" -eq 0 ] && [ "$now_hm" -ge 1700 ] && add=7
    wr=$(date -j -v+"${add}"d -v17H -v0M -v0S +%s 2>/dev/null || echo null)
    emit "$(row claude weekly null "$wr" estimated ok ccusage-weekly 'resets Wed 5:00 PM PT (known schedule); limits undisclosed' "$extra_w")"
  fi
}

# ---------- glm / copilot / hermes / cursor ----------
glm_row() {
  if command -v "$GLM_BIN" >/dev/null 2>&1; then
    if run_bounded "$GLM_TIMEOUT_SECONDS" "$GLM_BIN" --doctor >/dev/null 2>&1; then
      emit "$(row glm plan null null unknown ok claude-glm-doctor 'quota API not wired; treat abundant while healthy')"
    else
      SNAPSHOT_RC=1
      emit "$(row glm plan null null unknown down claude-glm-doctor 'doctor failed — do not route')"
    fi
  else
    emit "$(row glm plan null null unknown absent none 'claude-glm not installed')"
  fi
}
copilot_row() {
  if [ -f "$COPILOT_DB_PATH" ]; then
    local mr; mr=$(date -j -v+1m -v1d -v0H -v0M -v0S +%s 2>/dev/null || echo null)
    emit "$(row copilot monthly null "$mr" estimated present session-store 'premium quota resets 1st of month (schedule-derived); usage API not wired')"
  else
    emit "$(row copilot monthly null null unknown absent none 'no local copilot store')"
  fi
}
hermes_row() {
  if command -v "$HERMES" >/dev/null 2>&1; then
    emit "$(row hermes plan null null unknown present binary 'credits exhausted until news cycle — do not route by default')"
  else
    emit "$(row hermes plan null null unknown absent none 'hermes not installed')"
  fi
}
cursor_row() {
  emit "$(row cursor plan null null unknown skipped none 'no headless usage source; dashboard-only (documented gap, not silent)')"
}

# ---------- purchased credits (e.g. Codex weekly-reset packs, 30-day expiry) ----------
CREDITS_FILE="${USAGE_CREDITS_FILE:-$STATE_DIR/credits.json}"
notify_credit_advice() {
  local advice="$1"
  if [ -n "${USAGE_NOTIFY_BIN:-}" ]; then
    run_bounded "$NOTIFY_TIMEOUT_SECONDS" "$USAGE_NOTIFY_BIN" notify --session usage-snapshot --name usage-snapshot --text "AI credits: $advice"
    return $?
  fi
  local -a notify_argv
  case "$USAGE_NOTIFY_CMD" in
    *";"*|*"|"*|*"&"*|*'`'*|*'$'*|*"<"*|*">"*)
      echo "usage-snapshot: notify command contains forbidden shell characters" >&2
      return 1
      ;;
  esac
  IFS=' ' read -r -a notify_argv <<< "$USAGE_NOTIFY_CMD"
  [ "${#notify_argv[@]}" -gt 0 ] || return 1
  run_bounded "$NOTIFY_TIMEOUT_SECONDS" "${notify_argv[@]}" "AI credits: $advice"
}

credit_rows() {
  [ -f "$CREDITS_FILE" ] || return 0
  local wk credits_json
  credits_json=$(jq -ce '
    select(type=="object" and (.credits|type)=="array"
      and all(.credits[];
        type=="object"
        and ((has("provider")|not) or (.provider|type)=="string")
        and ((has("kind")|not) or (.kind|type)=="string")
        and ((has("count")|not) or ((.count|type)=="number" and .count>=0 and .count<=1000000 and (.count|floor)==.count))
        and ((has("expires")|not) or (.expires|type)=="string")))
    | .credits' "$CREDITS_FILE" 2>/dev/null) || credits_json=""
  if [ -z "$credits_json" ]; then
    SNAPSHOT_RC=1
    emit "$(row credits config null null unknown down credits.json 'credits file failed schema or JSON validation')"
    return
  fi
  # numbers only — a string used_pct from a corrupt rollout must never reach advice text.
  # `first` on empty → bare `null` (NOT the quoted string "null", which jq ranks > any number).
  wk=$(jq -s '[.[] | select(.provider=="codex" and .window=="weekly") | .used_pct] | map(select(type=="number")) | first' "$ROWS_TMP" 2>/dev/null)
  [ -z "$wk" ] && wk=null
  while IFS= read -r c; do
    local prov kind cnt exp exp_epoch days advice note stamp
    prov=$(printf '%s' "$c" | jq -r '.provider // "codex"')
    kind=$(printf '%s' "$c" | jq -r '.kind // "credit"')
    cnt=$(printf '%s' "$c" | jq -r '.count // 1')
    exp=$(printf '%s' "$c" | jq -r '.expires // empty')
    exp_epoch=null
    # local end-of-day: a credit is good through its stated day (UTC-midnight parse was a day early in PT)
    [ -n "$exp" ] && exp_epoch=$(date -j -f '%Y-%m-%d %H:%M' "$exp 23:59" +%s 2>/dev/null || echo null)
    if [ -n "$exp" ] && [ "$exp_epoch" = "null" ]; then
      SNAPSHOT_RC=1
      emit "$(row "$prov" "credit:$kind" null null unknown down credits.json 'credit expiry failed date validation')"
      continue
    fi
    advice=""
    if [ "$exp_epoch" != "null" ]; then
      days=$(( (exp_epoch - NOW_EPOCH) / 86400 ))
      if [ "$days" -lt 0 ]; then advice="EXPIRED $(( -days ))d ago — check if still redeemable"
      elif [ "$days" -le 7 ]; then advice="USE IT OR LOSE IT — expires in ${days}d, redeem now"; fi
    fi
    if [ -z "$advice" ] && [ "$wk" != "null" ] \
       && [ "$(printf '%s' "$wk" | jq 'type=="number" and . >= 85' 2>/dev/null)" = "true" ]; then
      advice="weekly at ${wk}% — good time to redeem one"
    fi
    note="count=$cnt; expires ${exp:-unknown}${advice:+; $advice}"
    emit "$(row "$prov" "credit:$kind" null "$exp_epoch" manual held credits.json "$note")"
    if [ -n "$advice" ] && { [ -n "${USAGE_NOTIFY_BIN:-}" ] || [ -n "${USAGE_NOTIFY_CMD:-}" ]; }; then
      stamp="$STATE_DIR/.credit-alert-$(date +%Y%m%d)"
      # atomic claim (noclobber) so concurrent runs send at most one ping/day;
      # message passed as $1, never interpolated into the command string
      if ( set -C; : > "$stamp" ) 2>/dev/null; then
        # argv exec only — no sh -c; USAGE_NOTIFY_CMD = executable + fixed args
        notify_credit_advice "$advice" >/dev/null 2>&1 \
          || { SNAPSHOT_RC=1; rm -f "$stamp"; echo "usage-snapshot: notify failed — stamp released, retry next run" >&2; }
      fi
    fi
  done < <(printf '%s' "$credits_json" | jq -c '.[]')
  return 0
}

codex_rows; claude_rows; glm_row; copilot_row; hermes_row; cursor_row; credit_rows

SNAPSHOT=$(jq -s --arg ts "$NOW_ISO" '{fetched_at:$ts, providers:.}' "$ROWS_TMP")

# ---------- history + wasted-at-reset ----------
if [ "$DO_HISTORY" = "1" ]; then
  # Owner-fenced mkdir lock: recover proven-dead residue, refuse live/unsafe locks.
  LOCK="$STATE_DIR/.history.lock"
  acquire_history_lock "$LOCK"
  LOCK_RC=$?
  if [ "$LOCK_RC" -eq 75 ]; then
    SNAPSHOT_RC=1; DO_HISTORY=0
    echo "usage-snapshot: live --history writer owns the lock — history not updated" >&2
  elif [ "$LOCK_RC" -ne 0 ]; then
    SNAPSHOT_RC=1; DO_HISTORY=0
    echo "usage-snapshot: cannot safely acquire the history lock" >&2
  fi
fi
if [ "$DO_HISTORY" = "1" ]; then
  HIST="$STATE_DIR/history.jsonl"; WASTE="$STATE_DIR/waste.tsv"
  if [ -s "$HIST" ]; then
    # window closed since last run → record final observed used_pct as the waste sample
    prev=$(tail -n 1 "$HIST")
    waste_rows=$(printf '%s' "$prev" | jq -c --argjson now "$NOW_EPOCH" '
        .providers[] | select(.used_pct != null and .resets_at != null)
        | select((.resets_at | fromdate) <= $now)
        | {provider, window, closed:.resets_at, final_used_pct:.used_pct, waste_pct:(100-.used_pct)}' 2>/dev/null)
    if [ $? -ne 0 ]; then
      SNAPSHOT_RC=1
      echo "usage-snapshot: prior history row is invalid" >&2
      waste_rows=""
    fi
    while IFS= read -r w; do
        [ -n "$w" ] || continue
        key=$(printf '%s' "$w" | jq -r '"\(.provider)\t\(.window)\t\(.closed)"')
        grep -qF "$key" "$WASTE" 2>/dev/null && continue
        if ! printf '%s\t%s\n' "$key" "$(printf '%s' "$w" | jq -r '"\(.final_used_pct)\t\(.waste_pct)"')" >> "$WASTE"; then
          SNAPSHOT_RC=1
          echo "usage-snapshot: cannot append waste history" >&2
          break
        fi
      done <<< "$waste_rows"
  fi
  compact_snapshot=$(printf '%s\n' "$SNAPSHOT" | jq -c . 2>/dev/null) || compact_snapshot=""
  if [ -z "$compact_snapshot" ] || ! printf '%s\n' "$compact_snapshot" >> "$HIST"; then
    SNAPSHOT_RC=1
    echo "usage-snapshot: cannot append snapshot history" >&2
  fi
fi

# ---------- dashboard ----------
if [ "$DO_HTML" = "1" ]; then
  OUT="$STATE_DIR/dashboard.html"
  OUT_TMP=$(mktemp "$STATE_DIR/.dashboard.XXXXXX" 2>/dev/null) || OUT_TMP=""
  if [ -z "$OUT_TMP" ]; then
    SNAPSHOT_RC=1
    echo "usage-snapshot: cannot create dashboard temporary file" >&2
  elif {
    printf '<!doctype html><meta charset="utf-8"><title>AI usage</title>\n'
    printf '<style>body{font:14px -apple-system,sans-serif;margin:2em;max-width:820px}h1{font-size:20px}.bar{background:#eee;border-radius:4px;height:18px;width:320px;display:inline-block;vertical-align:middle}.fill{background:#e8a33d;height:18px;border-radius:4px}.ok{color:#2a7}.bad{color:#c33}.dim{color:#888}td,th{padding:4px 10px;text-align:left;border-bottom:1px solid #eee}</style>\n'
    printf '<h1>AI usage — %s</h1><table><tr><th>provider</th><th>window</th><th>used</th><th>resets in</th><th>health</th><th>confidence</th><th>notes</th></tr>\n' "$NOW_ISO"
    # @html only on .notes (free text) — @html on the whole row escaped the bar <span>s into literal text
    printf '%s' "$SNAPSHOT" | jq -r '.providers[] | "<tr><td><b>\(.provider)</b></td><td>\(.window)</td><td>\(if .used_pct!=null then "<span class=bar><span class=fill style=width:\(.used_pct*3.2|floor)px></span></span> \(.used_pct)%" elif .tokens_used?!=null then "\(.tokens_used) tok" else "—" end)</td><td>\(if .resets_in_min!=null then "\(.resets_in_min) min" else "—" end)</td><td class=\(if .health=="ok" or .health=="present" then "ok" else "bad" end)>\(.health)</td><td class=dim>\(.confidence)</td><td class=dim>\(.notes|@html)</td></tr>"'
    printf '</table><h1>Wasted at reset (goal: near 0)</h1><table><tr><th>closed</th><th>provider</th><th>window</th><th>final used %%</th><th>wasted %%</th></tr>\n'
    if [ -s "$STATE_DIR/waste.tsv" ]; then
      awk -F'\t' '{printf "<tr><td>%s</td><td>%s</td><td>%s</td><td>%s</td><td><b>%s</b></td></tr>\n",$3,$1,$2,$4,$5}' "$STATE_DIR/waste.tsv" | tail -30
    else
      printf '<tr><td colspan=5 class=dim>no closed windows observed yet</td></tr>\n'
    fi
    printf '</table>\n'
  } > "$OUT_TMP" && mv -f "$OUT_TMP" "$OUT"; then
    :
  else
    SNAPSHOT_RC=1
    rm -f "$OUT_TMP" 2>/dev/null
    echo "usage-snapshot: cannot render dashboard" >&2
  fi
fi

printf '%s\n' "$SNAPSHOT"
exit "$SNAPSHOT_RC"
