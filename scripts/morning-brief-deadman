#!/usr/bin/env python3
"""Independent Morning Brief delivery deadman.

Reads only durable compose/delivery state and sends a category-only alert over
a minimal direct Telegram path. It never imports or invokes the composer or the
mobile-connect runtime.
"""

import hashlib
import http.client
import ipaddress
import json
import math
import os
import re
import signal
import stat
import subprocess
import sys
import threading
import time
import urllib.error
import urllib.parse
import urllib.request
from contextlib import contextmanager

from mission_control_common import (
    DESKTOP_GLANCE_CTA, NOTIFICATION, sanitize_text, same_local_day,
                                    verify_install_stamp)


def _now():
    raw = os.environ.get("MORNING_BRIEF_DEADMAN_NOW_EPOCH")
    try:
        return int(raw) if raw else int(time.time())
    except ValueError:
        return int(time.time())


def _home():
    state = os.path.expanduser(os.environ.get(
        "MISSION_CONTROL_HOME", "~/.mission-control"))
    return os.path.join(state, "morning-brief")


def _load(path):
    try:
        with open(path) as handle:
            value = json.load(handle)
        return value if isinstance(value, dict) else None
    except (OSError, ValueError):
        return None


def _atomic_json(path, value):
    parent = os.path.dirname(path)
    os.makedirs(parent, mode=0o700, exist_ok=True)
    os.chmod(parent, 0o700)
    tmp = "%s.tmp.%d" % (path, os.getpid())
    fd = os.open(tmp, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
    try:
        with os.fdopen(fd, "w") as handle:
            json.dump(value, handle, ensure_ascii=True, sort_keys=True)
            handle.write("\n"); handle.flush(); os.fsync(handle.fileno())
        os.replace(tmp, path); os.chmod(path, 0o600)
    finally:
        try:
            os.remove(tmp)
        except OSError:
            pass


_CONFIG_KEYS = frozenset((
    "ALLOWED_USER_ID",
    "TELEGRAM_BOT_TOKEN",
    "TELEGRAM_BOT_TOKEN_KEYCHAIN_SERVICE",
))
_TOKEN_RE = re.compile(r"^[0-9]{5,}:[A-Za-z0-9_-]{20,}$")
_SERVICE_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._:@/ -]{0,127}$")
_CATEGORIES = frozenset(("missing", "stale", "empty", "partial", "unsent"))
_TELEGRAM_ORIGIN = "https://api.telegram.org"
_MAX_CONFIG_BYTES = 65536
_MAX_RESPONSE_BYTES = 65536


def _valid_chat_id(value):
    if not isinstance(value, str) or not re.match(r"^-?\d+$", value):
        return None
    try:
        numeric = int(value)
    except ValueError:
        return None
    if numeric == 0 or numeric < -(2 ** 63) or numeric > (2 ** 63 - 1):
        return None
    return str(numeric)


def _valid_token(value):
    if not isinstance(value, str):
        return None
    value = value.strip()
    if len(value) > 256 or not _TOKEN_RE.match(value):
        return None
    return value


def _parse_config_value(raw):
    raw = raw.strip()
    if not raw:
        return ""
    if raw[0] in ("'", '"'):
        quote = raw[0]
        end = raw.find(quote, 1)
        if end < 0:
            return None
        value = raw[1:end]
        tail = raw[end + 1:].strip()
        if tail and not tail.startswith("#"):
            return None
    else:
        value = raw.split("#", 1)[0].strip()
    if len(value) > 512 or any(ord(char) < 32 or ord(char) == 127
                               for char in value):
        return None
    return value


def _config_values():
    """Read only whitelisted scalar keys from a private regular config file."""
    path = os.path.expanduser(os.environ.get(
        "MOBILE_CONNECT_CONFIG", "~/.mobile-connect/config"))
    flags = (os.O_RDONLY | getattr(os, "O_NOFOLLOW", 0) |
             getattr(os, "O_NONBLOCK", 0))
    try:
        fd = os.open(path, flags)
    except FileNotFoundError:
        return {}
    except OSError:
        return None
    try:
        info = os.fstat(fd)
        if (not stat.S_ISREG(info.st_mode) or info.st_uid != os.getuid() or
                stat.S_IMODE(info.st_mode) & 0o077 or
                info.st_size > _MAX_CONFIG_BYTES):
            return None
        values = {}
        total = 0
        with os.fdopen(fd, encoding="utf-8") as handle:
            fd = None
            for line in handle:
                total += len(line)
                if total > _MAX_CONFIG_BYTES or len(line) > 4096:
                    return None
                content = line.rstrip("\r\n")
                if any(ord(char) < 32 and char != "\t" for char in content):
                    return None
                match = re.match(r"^\s*([A-Z0-9_]+)\s*=\s*(.*?)\s*$", line)
                if not match or match.group(1) not in _CONFIG_KEYS:
                    continue
                key = match.group(1)
                if key in values:
                    return None
                value = _parse_config_value(match.group(2))
                if value is None:
                    return None
                values[key] = value
        return values
    except (OSError, UnicodeError):
        return None
    finally:
        if fd is not None:
            try:
                os.close(fd)
            except OSError:
                pass


def _chat_id(config=None):
    if "MORNING_BRIEF_CHAT_ID" in os.environ:
        return _valid_chat_id(os.environ.get("MORNING_BRIEF_CHAT_ID", "").strip())
    if config is None:
        config = _config_values()
    if config is None:
        return None
    return _valid_chat_id(config.get("ALLOWED_USER_ID", "").strip())


def _keychain_token(service):
    service = service.strip() if isinstance(service, str) else ""
    if not _SERVICE_RE.match(service):
        return None, True
    security_bin = os.path.expanduser(os.environ.get(
        "MORNING_BRIEF_SECURITY_BIN", "/usr/bin/security"))
    if (not os.path.isabs(security_bin) or not os.path.isfile(security_bin) or
            not os.access(security_bin, os.X_OK)):
        return None, False
    try:
        result = subprocess.run([
            security_bin, "find-generic-password", "-s", service, "-w"],
            stdout=subprocess.PIPE, stderr=subprocess.DEVNULL,
            timeout=5, check=False)
    except (OSError, UnicodeError, subprocess.TimeoutExpired):
        return None, False
    if result.returncode != 0 or not result.stdout:
        return None, False
    try:
        output = (result.stdout.decode("ascii") if isinstance(result.stdout, bytes)
                  else result.stdout)
    except UnicodeError:
        return None, True
    token = _valid_token(output)
    return token, token is None


def _bot_token(config):
    for name in ("MORNING_BRIEF_TELEGRAM_BOT_TOKEN", "TELEGRAM_BOT_TOKEN"):
        if name in os.environ:
            return _valid_token(os.environ.get(name, ""))
    service = config.get("TELEGRAM_BOT_TOKEN_KEYCHAIN_SERVICE", "")
    if service:
        token, malformed = _keychain_token(service)
        if token:
            return token
        if malformed:
            return None
    fallback = config.get("TELEGRAM_BOT_TOKEN", "")
    return _valid_token(fallback) if fallback else None


def _api_base():
    raw = os.environ.get("MORNING_BRIEF_TELEGRAM_API_BASE")
    if raw is None:
        return _TELEGRAM_ORIGIN
    if raw != raw.strip():
        return None
    try:
        parsed = urllib.parse.urlsplit(raw)
        port = parsed.port
    except ValueError:
        return None
    if (not parsed.hostname or parsed.username is not None or
            parsed.password is not None or parsed.query or parsed.fragment or
            parsed.path not in ("", "/")):
        return None
    if parsed.scheme == "https":
        if parsed.hostname != "api.telegram.org" or port is not None:
            return None
    elif parsed.scheme == "http":
        if (os.environ.get("MORNING_BRIEF_TELEGRAM_TEST_MODE") != "1" or
                "MORNING_BRIEF_TELEGRAM_BOT_TOKEN" not in os.environ):
            return None
        host = parsed.hostname.lower()
        try:
            loopback = host == "localhost" or ipaddress.ip_address(host).is_loopback
        except ValueError:
            loopback = False
        if not loopback:
            return None
    else:
        return None
    return raw.rstrip("/")


def _send_timeout():
    raw = os.environ.get("MORNING_BRIEF_SEND_TIMEOUT_S", "30")
    try:
        value = float(raw)
    except (TypeError, ValueError):
        return None
    return value if 0.05 <= value <= 30 else None


class _NoRedirect(urllib.request.HTTPRedirectHandler):
    def redirect_request(self, req, fp, code, msg, headers, newurl):
        return None


class _WallClockExpired(Exception):
    pass


@contextmanager
def _wall_clock_deadline(seconds):
    """Bound DNS, connect, response headers, and body by one elapsed deadline."""
    supported = (hasattr(signal, "setitimer") and
                 threading.current_thread() is threading.main_thread())
    if not supported:
        yield
        return
    previous_timer = signal.getitimer(signal.ITIMER_REAL)
    if previous_timer[0] > 0:
        # An importing caller already owns the process-wide alarm. Preserve its
        # deadline exactly; the socket timeout remains the nested fallback.
        yield
        return
    previous_handler = signal.getsignal(signal.SIGALRM)

    def expire(_signum, _frame):
        raise _WallClockExpired()

    signal.signal(signal.SIGALRM, expire)
    signal.setitimer(signal.ITIMER_REAL, seconds)
    try:
        yield
    finally:
        signal.setitimer(signal.ITIMER_REAL, 0)
        signal.signal(signal.SIGALRM, previous_handler)


def _direct_send(chat_id, token, message):
    base = _api_base()
    timeout = _send_timeout()
    if not base or timeout is None:
        return False
    body = json.dumps({
        "chat_id": int(chat_id),
        "text": message,
        "disable_web_page_preview": True,
    }, ensure_ascii=True, separators=(",", ":")).encode("utf-8")
    url = "%s/bot%s/sendMessage" % (base, token)
    request = urllib.request.Request(
        url, data=body, headers={"Content-Type": "application/json"},
        method="POST")
    opener = urllib.request.build_opener(
        urllib.request.ProxyHandler({}), _NoRedirect())
    try:
        with _wall_clock_deadline(timeout):
            with opener.open(request, timeout=timeout) as response:
                status_code = response.getcode()
                if not isinstance(status_code, int) or not 200 <= status_code < 300:
                    return False
                payload = response.read(_MAX_RESPONSE_BYTES + 1)
            if len(payload) > _MAX_RESPONSE_BYTES:
                return False
        decoded = json.loads(payload.decode("utf-8"))
        if not isinstance(decoded, dict):
            return False
        result = decoded.get("result")
        message_id = result.get("message_id") if isinstance(result, dict) else None
        return (decoded.get("ok") is True and isinstance(message_id, int) and
                not isinstance(message_id, bool) and message_id > 0)
    except (_WallClockExpired, OSError, ValueError, UnicodeError, urllib.error.URLError,
            http.client.HTTPException):
        return False


def _send(category):
    if category not in _CATEGORIES:
        return False
    raw = "Morning Brief deadman: %s. %s" % (category, DESKTOP_GLANCE_CTA)
    sanitized = sanitize_text(raw, NOTIFICATION)
    if sanitized.dropped:
        return False
    if "MORNING_BRIEF_SEND_BIN" in os.environ:
        sender = os.path.expanduser(os.environ.get("MORNING_BRIEF_SEND_BIN", ""))
        chat_id = _chat_id()
        if (not chat_id or not os.path.isabs(sender) or
                not os.path.isfile(sender) or not os.access(sender, os.X_OK)):
            return False
        child_env = os.environ.copy()
        child_env.pop("MORNING_BRIEF_TELEGRAM_BOT_TOKEN", None)
        child_env.pop("TELEGRAM_BOT_TOKEN", None)
        try:
            result = subprocess.run([sender, "send", chat_id, sanitized.value],
                                    stdout=subprocess.DEVNULL,
                                    stderr=subprocess.DEVNULL, timeout=30,
                                    env=child_env)
            return result.returncode == 0
        except (OSError, subprocess.TimeoutExpired):
            return False

    needs_config = ("MORNING_BRIEF_CHAT_ID" not in os.environ or
                    not any(name in os.environ for name in
                            ("MORNING_BRIEF_TELEGRAM_BOT_TOKEN",
                             "TELEGRAM_BOT_TOKEN")))
    config = _config_values() if needs_config else {}
    if config is None:
        return False
    chat_id = _chat_id(config)
    if not chat_id:
        return False
    token = _bot_token(config)
    if not token:
        return False
    return _direct_send(chat_id, token, sanitized.value)


# Shared with the composer via the common module so a brief cannot be "valid"
# to the dashboard but "stale" to the deadman.
_same_local_day = same_local_day


def _as_int(value, default=None, allow_text=False):
    """Parse persisted integers without bool/string/non-finite coercion."""
    if isinstance(value, bool):
        return default
    if isinstance(value, int):
        return value
    if isinstance(value, float):
        return int(value) if math.isfinite(value) and value.is_integer() else default
    if allow_text and isinstance(value, str):
        try:
            return int(value)
        except (TypeError, ValueError, OverflowError):
            return default
    return default


def _problem(now):
    home = _home()
    latest = _load(os.path.join(home, "latest.json"))
    if not latest:
        return "missing", "none"
    brief_id = str(latest.get("brief_id") or "unknown")
    max_age = _as_int(os.environ.get("MORNING_BRIEF_MAX_AGE_S", "93600"),
                      93600, allow_text=True)
    generated = _as_int(latest.get("generated_epoch"))
    age = now - generated if generated is not None else 10**12
    if age < 0 or age > max_age or not _same_local_day(generated, now):
        return "stale", brief_id
    markdown = os.path.join(home, "latest.md")
    try:
        if os.path.getsize(markdown) <= 0:
            return "empty", brief_id
    except OSError:
        return "empty", brief_id
    delivery = latest.get("delivery")
    if not isinstance(delivery, dict):
        delivery = {}
    state = delivery.get("state")
    confirmed = _as_int(delivery.get("confirmed_chunks"), 0)
    total = _as_int(delivery.get("total_chunks"), 0)
    receipt = _load(os.path.join(home, "delivery", re.sub(
        r"[^A-Za-z0-9_.-]", "_", brief_id) + ".json")) or {}
    if receipt:
        state = receipt.get("state", state)
        confirmed = _as_int(receipt.get("confirmed_chunks"), confirmed)
        total = _as_int(receipt.get("total_chunks"), total)
    delivered_at = _as_int(receipt.get("delivered_at")) if receipt else None
    if (receipt and receipt.get("brief_id") == brief_id and state == "delivered" and
            total > 0 and confirmed == total and
            generated is not None and delivered_at is not None and
            generated <= delivered_at <= now and
            _same_local_day(delivered_at, now)):
        return None, brief_id
    if confirmed > 0 and (total == 0 or confirmed < total):
        return "partial", brief_id
    if state in ("failed", "partial"):
        return "partial", brief_id
    return "unsent", brief_id


def _acquire_lock():
    home = _home(); os.makedirs(home, mode=0o700, exist_ok=True)
    lock = os.path.join(home, "deadman.lock")
    deadline = time.monotonic() + 30
    while True:
        try:
            os.mkdir(lock, 0o700)
            return lock
        except FileExistsError:
            try:
                if time.time() - os.path.getmtime(lock) > 600:
                    os.rmdir(lock); continue
            except OSError:
                pass
            if time.monotonic() >= deadline:
                return None
            time.sleep(0.05)


def main():
    lock = _acquire_lock()
    if not lock:
        sys.stderr.write("morning-brief-deadman: lock busy\n")
        return 75
    try:
        return _main_locked()
    finally:
        try:
            os.rmdir(lock)
        except OSError:
            pass


def _main_locked():
    now = _now(); home = _home()
    category, brief_id = _problem(now)
    # Install integrity is a separate local health gate. It never becomes a
    # Telegram alert category; dashboard/automation health surfaces the nonzero
    # result while delivery alerts remain category-only.
    bin_dir = os.path.join(os.path.dirname(home), "bin")
    stamp = verify_install_stamp(bin_dir)
    fingerprint = hashlib.sha256(("%s:%s" % (category or "healthy", brief_id)).encode(
        "utf-8")).hexdigest()
    alert_state_path = os.path.join(home, "deadman-alert-state.json")
    previous = _load(alert_state_path) or {}
    alerted = False
    throttled = False
    if category:
        throttle = _as_int(os.environ.get("MORNING_BRIEF_DEADMAN_THROTTLE_S", "21600"),
                           21600, allow_text=True)
        last = _as_int(previous.get("alerted_at"), 0)
        elapsed = now - last
        throttled = (previous.get("fingerprint") == fingerprint and throttle > 0 and
                     0 <= elapsed < throttle)
        if not throttled and _send(category):
            alerted = True
            _atomic_json(alert_state_path, {
                "schema": 1, "fingerprint": fingerprint, "alerted_at": now,
                "category": category,
            })
    result = category or ("healthy" if stamp["ok"] else "install-unverified")
    _atomic_json(os.path.join(home, "deadman-last-check.json"), {
        "schema": 1, "checked_at": now, "brief_id": brief_id,
        "result": result, "alerted": alerted,
        "throttled": throttled,
        "install_stamp": {"present": stamp["present"], "ok": stamp["ok"],
                          "head_sha": stamp["head_sha"],
                          "provenance": stamp["provenance"],
                          "reason": stamp.get("reason", "unknown")},
    })
    if category:
        sys.stderr.write("morning-brief-deadman: %s\n" % category)
        return 1
    if not stamp["ok"]:
        sys.stderr.write("morning-brief-deadman: install-unverified (%s)\n" %
                         stamp.get("reason", "unknown"))
        return 1
    print("morning-brief-deadman: healthy")
    return 0


if __name__ == "__main__":
    sys.exit(main())
