#!/usr/bin/env python3
# automation-status — background-job health collector for the mission-control
# dashboard (ER-087 Part B "Automation health"). python3 stdlib only.
#
# Reads a registry JSON of expected launchd jobs, compares against live truth
# (`launchctl list`, evidence file mtimes, err-log tails) and emits either a
# human table (default) or the standard feed envelope (--json).
#
# Truth sources are all overridable for hermetic tests:
#   AUTOMATION_STATUS_LAUNCHCTL   replaces the `launchctl` binary
#   AUTOMATION_STATUS_T7          top-level T7 mount path (default /Volumes/T7)
# Registry path: --registry PATH (default dashboard/jobs.json at repo root).
#
# Exit 0 whenever it could run at all — the states live in the data; the
# dashboard CLI decides exit codes. Registry missing/unreadable → ok:false
# envelope, still exit 0.

import argparse
import glob
import hashlib
import json
import os
import re
import subprocess
import sys
import time

from mission_control_common import ERROR, safe_text

CADENCE_S = 300
FEED = "automation"
SCHEMA = 1
HISTORY_SCHEMA = 1
HISTORY_LIMIT = 20
HISTORY_LOCK_WAIT_S = 5
HISTORY_LOCK_STALE_S = 30

def _redact(s):
    return safe_text(s, ERROR)


def _repo_root():
    return os.path.dirname(os.path.dirname(os.path.abspath(__file__)))


def _expand(path):
    return os.path.expanduser(path or "")


def _now():
    raw = os.environ.get("AUTOMATION_STATUS_NOW_EPOCH")
    if raw:
        try:
            return float(raw)
        except ValueError:
            pass
    return time.time()


def _is_offline_media(path):
    """A /Volumes/<name> path whose mount root is absent = media unplugged."""
    p = _expand(path)
    if not p.startswith("/Volumes/"):
        return False
    parts = p.split("/")  # ['', 'Volumes', '<name>', ...]
    if len(parts) < 3 or not parts[2]:
        return False
    mount_root = "/" + os.path.join(parts[1], parts[2])
    return not os.path.exists(mount_root)


def read_registry(path):
    """Return (entries, error). Missing/unreadable/bad → ([], 'message')."""
    try:
        with open(path, "r") as f:
            data = json.load(f)
    except FileNotFoundError:
        return [], "registry not found: %s" % path
    except (OSError, ValueError) as e:
        return [], "registry unreadable: %s" % e
    jobs = data.get("jobs") if isinstance(data, dict) else data
    if not isinstance(jobs, list):
        return [], "registry has no jobs[] list"
    return jobs, None


def parse_launchctl(text):
    """Parse the stable 3-column `PID\\tStatus\\tLabel` form.

    Returns (by_label, parse_ok). by_label[label] = {pid, status}.
    Garbage that lacks the header → ({}, False) so the caller marks every
    job 'degraded' rather than falsely all-red.
    """
    lines = [ln for ln in text.splitlines() if ln.strip()]
    if not lines:
        return {}, False
    header = lines[0].split("\t")
    if len(header) < 3 or header[0].strip() != "PID" or "Label" not in header[2]:
        return {}, False
    by_label = {}
    for ln in lines[1:]:
        cols = ln.split("\t")
        if len(cols) < 3:
            continue
        pid_s, status_s, label = cols[0].strip(), cols[1].strip(), cols[2].strip()
        pid = None if pid_s in ("-", "") else _to_int(pid_s)
        status = _to_int(status_s)
        if label:
            by_label[label] = {"pid": pid, "status": status}
    return by_label, True


def _to_int(s):
    try:
        return int(s)
    except (TypeError, ValueError):
        return None


def launchctl_list(binary):
    try:
        out = subprocess.run(
            [binary, "list"], capture_output=True, text=True, timeout=15
        )
        return out.stdout or ""
    except (OSError, subprocess.SubprocessError):
        return ""


def err_log_tail(path):
    p = _expand(path)
    if not p or not os.path.isfile(p):
        return None
    try:
        with open(p, "r", errors="replace") as f:
            last = ""
            for line in f:
                if line.strip():
                    last = line.rstrip("\n")
        if not last:
            return None
        return _redact(last[:200])
    except OSError:
        return None


def evidence_details(evidence, now=None):
    """Return freshness plus stable evidence identity for one job.

    freshest_age = seconds since the newest existing evidence file's mtime.
    None means no readable evidence. offline_media = evidence lives on
    unmounted removable media (and none of it is currently readable).

    Registry paths may be exact files or globs. Only evidence explicitly marked
    ``run_key: true`` may identify a distinct run; ordinary progress/display
    files still participate in freshness without inflating run history.
    """
    now = _now() if now is None else now
    newest_ns = None
    newest_run_ns = None
    semantic_status = None
    semantic_status_ns = None
    saw_media_offline = False
    saw_readable = False
    for ev in evidence or []:
        pattern = _expand(ev.get("path", ""))
        if not pattern:
            continue
        if _is_offline_media(pattern):
            saw_media_offline = True
            continue
        paths = glob.glob(pattern) if glob.has_magic(pattern) else [pattern]
        for path in paths:
            if not os.path.isfile(path):
                continue
            try:
                mt_ns = os.stat(path).st_mtime_ns
                saw_readable = True
                if newest_ns is None or mt_ns > newest_ns:
                    newest_ns = mt_ns
                if ev.get("run_key") is True and (newest_run_ns is None or mt_ns > newest_run_ns):
                    newest_run_ns = mt_ns
                if (ev.get("semantic_status") is True and
                        (semantic_status_ns is None or mt_ns > semantic_status_ns)):
                    try:
                        if os.stat(path).st_size > 65536:
                            raise ValueError("semantic marker too large")
                        with open(path) as handle:
                            marker = json.load(handle)
                        status = marker.get("status") if isinstance(marker, dict) else None
                        semantic_status = (status if isinstance(status, str) and
                                           re.match(r"^[a-z][a-z0-9_-]{0,63}$", status)
                                           else "invalid")
                    except (OSError, ValueError):
                        semantic_status = "invalid"
                    semantic_status_ns = mt_ns
            except OSError:
                continue
    newest_epoch = newest_ns / 1000000000.0 if newest_ns is not None else None
    age = (now - newest_epoch) if newest_epoch is not None else None
    offline = saw_media_offline and not saw_readable
    return {
        "age_s": age,
        "offline": offline,
        "newest_mtime_ns": newest_ns,
        "newest_epoch": newest_epoch,
        "run_mtime_ns": newest_run_ns,
        "semantic_status": semantic_status,
    }


def evidence_state(evidence):
    """Compatibility helper used by tests and small callers."""
    details = evidence_details(evidence)
    return details["age_s"], details["offline"]


_DAILY_RE = re.compile(r"^(\d{1,2}):(\d{2}) daily$")
_INTERVAL_RE = re.compile(r"^every\s+(\d+)([smh])$")


def next_run_epoch(schedule, evidence_epoch, now=None):
    """Estimate the next future run for the two supported registry forms."""
    now = _now() if now is None else float(now)
    value = (schedule or "").strip()
    daily = _DAILY_RE.match(value)
    if daily:
        hour, minute = int(daily.group(1)), int(daily.group(2))
        if hour > 23 or minute > 59:
            return None
        local = list(time.localtime(now))
        local[3], local[4], local[5] = hour, minute, 0
        local[8] = -1  # let libc determine DST for the candidate occurrence
        candidate = time.mktime(tuple(local))
        if candidate <= now:
            local[2] += 1  # mktime normalizes month/year rollover and DST.
            candidate = time.mktime(tuple(local))
        return int(candidate)
    interval = _INTERVAL_RE.match(value)
    if interval and evidence_epoch is not None:
        amount = int(interval.group(1))
        unit = {"s": 1, "m": 60, "h": 3600}[interval.group(2)]
        seconds = amount * unit
        if seconds <= 0:
            return None
        candidate = float(evidence_epoch) + seconds
        if candidate <= now:
            candidate += (int((now - candidate) // seconds) + 1) * seconds
        return int(candidate)
    return None


def _mtime_ns(path):
    path = _expand(path)
    if not path or not os.path.isfile(path):
        return None
    try:
        return os.stat(path).st_mtime_ns
    except OSError:
        return None


def _history_path():
    home = _expand(os.environ.get("MISSION_CONTROL_HOME", "~/.mission-control"))
    return os.path.join(home, "job-history.json")


def _empty_history():
    return {"schema": HISTORY_SCHEMA, "jobs": {}}


def _load_history(path):
    try:
        with open(path) as f:
            data = json.load(f)
        if data.get("schema") != HISTORY_SCHEMA or not isinstance(data.get("jobs"), dict):
            return _empty_history()
        return data
    except (OSError, ValueError, AttributeError):
        return _empty_history()


def _acquire_history_lock(path):
    lock = path + ".lock"
    deadline = time.monotonic() + HISTORY_LOCK_WAIT_S
    while True:
        try:
            os.mkdir(lock, 0o700)
            return lock
        except FileExistsError:
            try:
                if time.time() - os.path.getmtime(lock) > HISTORY_LOCK_STALE_S:
                    os.rmdir(lock)
                    continue
            except OSError:
                pass
            if time.monotonic() >= deadline:
                raise RuntimeError("job history lock busy")
            time.sleep(0.01)


def _atomic_history_write(path, data):
    parent = os.path.dirname(path)
    os.makedirs(parent, mode=0o700, exist_ok=True)
    os.chmod(parent, 0o700)
    tmp = "%s.tmp.%d" % (path, os.getpid())
    try:
        fd = os.open(tmp, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
        with os.fdopen(fd, "w") as f:
            json.dump(data, f, ensure_ascii=True, sort_keys=True)
            f.write("\n")
            f.flush()
            os.fsync(f.fileno())
        os.replace(tmp, path)
        os.chmod(path, 0o600)
    finally:
        try:
            os.remove(tmp)
        except OSError:
            pass


def _run_key(name, result, exit_state, marker_ns):
    raw = "%s|%s|%s|%s" % (name, result, exit_state, marker_ns)
    return hashlib.sha256(raw.encode("utf-8")).hexdigest()


def _failure_streak(events):
    streak = 0
    for event in reversed(events or []):
        if event.get("result") == "failure":
            streak += 1
        elif event.get("result") == "success":
            break
    return streak


def _history_projection(job, stored, confidence):
    events = list(stored.get("events") or [])[-HISTORY_LIMIT:]
    job["history_confidence"] = confidence
    job["history_unknown"] = confidence != "trusted"
    job["failure_streak"] = _failure_streak(events)
    job["recent_runs"] = events


def _update_one_history(entry, job, stored, now):
    """Update one job from a trustworthy distinct-run signal."""
    events = list(stored.get("events") or [])
    result = None
    marker_ns = None
    confidence = "unknown"

    if entry.get("kind") == "keepalive":
        terminal = "success" if job.get("state") == "green" else (
            "failure" if job.get("state") == "red" else None)
        if terminal is not None:
            confidence = "trusted"
            previous = stored.get("keepalive_terminal")
            if terminal != previous:
                sequence = int(stored.get("keepalive_episode", 0)) + 1
                stored["keepalive_episode"] = sequence
                stored["keepalive_terminal"] = terminal
                result = terminal
                marker_ns = "episode-%d" % sequence
    else:
        status = job.get("last_exit")
        run_ns = job.pop("_run_mtime_ns", None)
        err_ns = job.pop("_err_mtime_ns", None)
        if entry.get("pseudo") and job.get("state") == "green" and run_ns is not None:
            result, marker_ns, confidence = "success", run_ns, "trusted"
        elif job.get("semantic_status") is not None and run_ns is not None:
            result = ("success" if job.get("semantic_status") == "completed"
                      else "failure")
            marker_ns, confidence = run_ns, "trusted"
        elif status is not None and job.get("state") not in ("offline-media", "degraded", "retired"):
            result = "success" if status == 0 else "failure"
            if result == "failure" and job.get("state") != "red":
                result = None
            marker_ns = run_ns
            if result == "failure" and err_ns is not None:
                marker_ns = max(x for x in (run_ns, err_ns) if x is not None)
            confidence = "trusted" if result is not None and marker_ns is not None else "unknown"
            if marker_ns is None:
                result = None

    if result is not None:
        key = _run_key(entry.get("name", ""), result, job.get("last_exit"), marker_ns)
        if key not in {event.get("run_key") for event in events}:
            run_at = now if isinstance(marker_ns, str) else marker_ns / 1000000000.0
            events.append({
                "run_key": key,
                "result": result,
                "run_at": int(run_at),
                "observed_at": int(now),
                "last_exit": job.get("last_exit"),
            })
    stored["events"] = events[-HISTORY_LIMIT:]
    stored["last_observed_at"] = int(now)
    stored["last_observed_state"] = job.get("state")
    stored["observation_count"] = int(stored.get("observation_count", 0)) + 1
    _history_projection(job, stored, confidence)
    job.pop("_run_mtime_ns", None)
    job.pop("_err_mtime_ns", None)


def attach_history(entries, jobs, parse_ok, now):
    """Attach bounded run history; only a parseable poll may mutate it."""
    path = _history_path()
    if not parse_ok:
        data = _load_history(path)
        for entry, job in zip(entries, jobs):
            stored = data["jobs"].get(entry.get("name", ""), {})
            _history_projection(job, stored, "unknown")
            job.pop("_run_mtime_ns", None)
            job.pop("_err_mtime_ns", None)
        return

    try:
        os.makedirs(os.path.dirname(path), mode=0o700, exist_ok=True)
        lock = _acquire_history_lock(path)
    except (OSError, RuntimeError):
        data = _load_history(path)
        for entry, job in zip(entries, jobs):
            _history_projection(job, data["jobs"].get(entry.get("name", ""), {}), "unknown")
            job.pop("_run_mtime_ns", None)
            job.pop("_err_mtime_ns", None)
        return
    try:
        data = _load_history(path)
        for entry, job in zip(entries, jobs):
            name = entry.get("name", "")
            stored = data["jobs"].setdefault(name, {"events": []})
            _update_one_history(entry, job, stored, now)
        _atomic_history_write(path, data)
    finally:
        try:
            os.rmdir(lock)
        except OSError:
            pass


def classify(entry, by_label, parse_ok, now=None):
    """Compute one job's state + detail fields."""
    now = _now() if now is None else now
    name = entry.get("name", "")
    result = {
        "label": entry.get("label", name),
        "name": name,
        "kind": entry.get("kind", "interval"),
        "schedule": entry.get("schedule", ""),
        "retry_schedule": entry.get("retry_schedule", ""),
        "loaded": name in by_label,
        "pid": by_label.get(name, {}).get("pid"),
        "last_exit": by_label.get(name, {}).get("status"),
        "evidence_age_s": None,
        "err_log_tail": None,
        "next_run_epoch": None,
        "next_run_estimate": None,
        "run_cmd": None,
        "activation_required": bool(entry.get("activation_required")),
        "semantic_status": None,
        "_run_mtime_ns": None,
        "_err_mtime_ns": None,
    }

    if (not entry.get("pseudo") and not entry.get("retired")
            and re.match(r"^[A-Za-z0-9_.-]+$", name or "")):
        result["run_cmd"] = "launchctl kickstart -k gui/$UID/%s" % name

    if entry.get("retired"):
        result["state"] = "retired"
        return result

    # pseudo jobs are NOT launchd labels (e.g. the nightly chat-graph refresh):
    # skip every launchctl loaded/exit check and classify from evidence freshness
    # ONLY. green if evidence is within expected_freshness_s, else yellow. Never
    # red-for-unloaded — an unloaded launchctl label is meaningless for a pseudo job.
    if entry.get("pseudo"):
        details = evidence_details(entry.get("evidence"), now)
        age = details["age_s"]
        result["evidence_age_s"] = None if age is None else round(age, 1)
        result["_run_mtime_ns"] = details["run_mtime_ns"]
        next_epoch = next_run_epoch(entry.get("schedule"), details["newest_epoch"], now)
        result["next_run_epoch"] = next_epoch
        result["next_run_estimate"] = _iso(next_epoch) if next_epoch is not None else None
        exp = entry.get("expected_freshness_s")
        fresh = age is not None and isinstance(exp, (int, float)) and age <= exp
        result["state"] = "green" if fresh else "yellow"
        return result

    if not parse_ok:
        result["state"] = "degraded"
        return result

    if entry.get("activation_required") and not result["loaded"]:
        result["state"] = "awaiting-activation"
        result["run_cmd"] = None
        return result

    details = evidence_details(entry.get("evidence"), now)
    age, offline = details["age_s"], details["offline"]
    result["evidence_age_s"] = None if age is None else round(age, 1)
    result["_run_mtime_ns"] = details["run_mtime_ns"]
    result["semantic_status"] = details["semantic_status"]
    result["_err_mtime_ns"] = _mtime_ns(entry.get("err_log", ""))
    next_epoch = next_run_epoch(entry.get("schedule"), details["newest_epoch"], now)
    result["next_run_epoch"] = next_epoch
    result["next_run_estimate"] = _iso(next_epoch) if next_epoch is not None else None
    if offline:
        result["state"] = "offline-media"
        return result

    exp = entry.get("expected_freshness_s")
    stale = True
    if age is not None and isinstance(exp, (int, float)):
        stale = age > exp
    nonzero = result["last_exit"] not in (0, None)
    loaded = result["loaded"]

    # err-log tail always captured when something looks wrong
    if not loaded or stale or nonzero:
        result["err_log_tail"] = err_log_tail(entry.get("err_log", ""))

    if not loaded:
        # red = not loaded (also covers stale-and-nonzero, subsumed here)
        result["state"] = "red"
        return result

    if nonzero:
        result["state"] = "red"
        return result

    if result["semantic_status"] not in (None, "completed"):
        result["state"] = "yellow"
        return result

    needs_pid = result["kind"] == "keepalive"
    if not stale and not nonzero and (not needs_pid or result["pid"] is not None):
        result["state"] = "green"
    else:
        result["state"] = "yellow"
    return result


def collect(registry_path):
    launchctl_bin = os.environ.get("AUTOMATION_STATUS_LAUNCHCTL", "launchctl")
    t7_path = os.environ.get("AUTOMATION_STATUS_T7", "/Volumes/T7")

    entries, reg_err = read_registry(registry_path)
    raw = launchctl_list(launchctl_bin)
    by_label, parse_ok = parse_launchctl(raw)

    now = _now()
    jobs = [classify(e, by_label, parse_ok, now) for e in entries]
    if reg_err is None:
        attach_history(entries, jobs, parse_ok, now)

    # unregistered: live com.gillette* labels absent from the registry
    known = set(e.get("name", "") for e in entries)
    unregistered = sorted(
        lbl for lbl in by_label
        if lbl.startswith("com.gillette") and lbl not in known
    )

    exception_states = {"red", "yellow", "degraded"}
    exceptions = sum(1 for j in jobs if j["state"] in exception_states)
    counts = {}
    for j in jobs:
        counts[j["state"]] = counts.get(j["state"], 0) + 1

    data = {
        "checked_at": _iso(now),
        "t7_mounted": os.path.exists(t7_path),
        "jobs": jobs,
        "unregistered": unregistered,
        "exceptions": exceptions,
        "counts": counts,
    }
    if not parse_ok:
        data["launchctl_note"] = "launchctl output unparseable — all jobs degraded"

    envelope = {
        "schema": SCHEMA,
        "feed": FEED,
        "generated_at": _iso(now),
        "generated_epoch": int(now),
        "cadence_s": CADENCE_S,
        "ok": reg_err is None,
        "error": reg_err,
        "data": data,
    }
    return envelope


def _iso(epoch):
    return time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime(epoch))


_GLYPH = {
    "green": "✓", "yellow": "!", "red": "✕",
    "offline-media": "○", "retired": "·", "degraded": "?",
    "awaiting-activation": "○",
}


def render_table(env):
    out = []
    d = env["data"]
    if not env["ok"]:
        out.append("automation: NOT OK — %s" % env.get("error"))
    if d.get("launchctl_note"):
        out.append("note: %s" % d["launchctl_note"])
    out.append("t7_mounted=%s  checked=%s  exceptions=%d"
               % (d["t7_mounted"], d["checked_at"], d["exceptions"]))
    out.append("%-14s %-2s %-34s %s" % ("STATE", "", "LABEL", "SCHEDULE"))
    for j in d["jobs"]:
        out.append("%-14s %-2s %-34s %s" % (
            j["state"], _GLYPH.get(j["state"], "?"),
            j["label"][:34], j["schedule"]))
        if j.get("err_log_tail"):
            out.append("    err: %s" % j["err_log_tail"])
    if d["unregistered"]:
        out.append("unregistered: %s" % ", ".join(d["unregistered"]))
    return "\n".join(out)


def main(argv=None):
    ap = argparse.ArgumentParser(description="background-job health collector")
    ap.add_argument("--registry",
                    default=os.path.join(_repo_root(), "dashboard", "jobs.json"))
    ap.add_argument("--json", action="store_true", help="emit feed envelope")
    args = ap.parse_args(argv)

    env = collect(args.registry)
    if args.json:
        print(json.dumps(env, ensure_ascii=True, indent=2))
    else:
        print(render_table(env))
    return 0  # exit 0 whenever we could run


if __name__ == "__main__":
    sys.exit(main())
