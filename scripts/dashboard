#!/usr/bin/env bash
# scripts/dashboard — mission-control CLI (ER-087 packet p4a).
#
# Static shell + per-feed data files, no server. Each feed is collected from a
# feeder command and written twice atomically: data/<feed>.json (canonical
# contract) + data/<feed>.js (window.MC transport, file:// loadable). JSON is
# built only inside the embedded python3 engine below — NEVER string-concatenated.
#
# Subcommands: collect [--due|--force] [feed] · refresh [feed] · status ·
#              brief --print · open [--serve] · install · demo
#
# Env: MISSION_CONTROL_HOME (state dir, default ~/.mission-control)
#      DASHBOARD_CMD_{USAGE,GIT,CHATS,AUTOMATION} override feeder commands
#      DASHBOARD_NO_OPEN=1 suppresses `open` (tests/CI)
# bash-3.2 safe; python3 stdlib only.

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# install bakes the resolved repo root into the copied runtime (bin/dashboard),
# whose SCRIPT_DIR is ~/.mission-control/bin — dirname of that is NOT the repo.
# Empty in the committed source, so the repo copy falls back to dirname(SCRIPT_DIR).
REPO_ROOT_DEFAULT=""
REPO_ROOT="${REPO_ROOT:-${REPO_ROOT_DEFAULT:-$(dirname "$SCRIPT_DIR")}}"  # pre-set respected (tests point it at a fixture repo)
MISSION_CONTROL_HOME="${MISSION_CONTROL_HOME:-$HOME/.mission-control}"
MISSION_CONTROL_RUNTIME_DIR="$SCRIPT_DIR"
export MISSION_CONTROL_HOME REPO_ROOT MISSION_CONTROL_RUNTIME_DIR

# --- python3 engine (collect/status/demo/freshness) -------------------------
# Code read from stdin (`python3 -`) so the body may use any quoting freely and
# macOS system Bash 3.2 does not reopen an already-consumed /dev/stdin as EOF;
# subcommand + args arrive as argv.
engine() {
  python3 - "$@" <<'PYEOF'
import errno, fcntl, hashlib, json, math, os, re, shlex, shutil, signal, stat, subprocess, sys, time

HOME = os.environ["MISSION_CONTROL_HOME"]
REPO = os.environ.get("REPO_ROOT", ".")
RUNTIME_DIR = os.environ.get("MISSION_CONTROL_RUNTIME_DIR",
                             os.path.join(REPO, "scripts"))
sys.dont_write_bytecode = True
DATA = os.path.join(HOME, "data")
sys.path.insert(0, RUNTIME_DIR)
try:
    from mission_control_common import (ERROR, EgressCounters, feed_health,
                                        sanitize_text, verify_install_stamp)
except ImportError:
    ERROR = "error"
    EgressCounters = None
    sanitize_text = None
    feed_health = None
    verify_install_stamp = None

_SHELL_FORBIDDEN = re.compile(r'[;|&`$<>]')


def _repo_script(name):
    # Feeders are repo siblings, NOT on PATH (live-proof 2026-07-03: bare names
    # -> exit 127 on the real machine). Quote: repo path contains spaces.
    return shlex.quote(os.path.join(REPO, "scripts", name))


# scan-unfinished-work exits 1 BY DESIGN when findings exist (its normal state)
OK_EXITS = {"git": (0, 1)}

# name, cadence_s, default feeder cmd, env override var, feeder timeout_s.
# ORDER MATTERS: collect runs feeds sequentially, so the fast/cheap feeds go FIRST
# and the slow chats feed (up to 150s catch-up scan) runs only after independent
# feeds; its dependent decision and brief feeds then run last.
FEEDS = [
    ("automation",  300, _repo_script("automation-status") + " --json --registry " + shlex.quote(os.path.join(REPO, "dashboard", "jobs.json")), "DASHBOARD_CMD_AUTOMATION", 30),
    ("usage",      1800, _repo_script("usage-snapshot") + " --no-ccusage", "DASHBOARD_CMD_USAGE", 60),
    # Per-repo sub-timeouts live in scan-unfinished-work --with-timeouts; whole-feed
    # budget is 300s so a slow unit becomes a partial ok:true feed, not a blank tab.
    ("git",         900, _repo_script("scan-unfinished-work") + " --json --with-timeouts", "DASHBOARD_CMD_GIT", 300),
    # export prints a status line; the JSON lives in the snapshot file -> run, then cat.
    # --catchup-limit bounds the stale-cursor catch-up scan (default 1500 files) so
    # export ALWAYS reaches its atomic rename inside the 150s budget even on a cold
    # ~/.chat-graph; successive ticker fires extend coverage via file cursors.
    # On timeout the feed keeps last-good + a stale banner, so the tab never blanks.
    # Late by design so its slow scan never delays the independent tabs.
    ("chats",      1800, "", "DASHBOARD_CMD_CHATS", 150),
    # Decisions consume deterministic Tier-1 chat outcomes and must follow chats.
    ("decisions",   300, "", "DASHBOARD_CMD_DECISIONS", 30),
    # Attention merges manual queue + fresh decisions + red automation after those
    # sibling feeds have been refreshed in this cycle (or last-good on disk).
    ("attention",   300, "", "DASHBOARD_CMD_ATTENTION", 30),
    # Brief consumes the stable snapshots above and therefore MUST run last.
    ("brief",       300, "", "DASHBOARD_CMD_BRIEF", 30),
]
FEED_CADENCE = dict((n, c) for n, c, _, _, _ in FEEDS)


def _now():
    # Test seam only (mirrors morning-brief's MORNING_BRIEF_NOW_EPOCH): freshness
    # is clock-critical, so a deterministic suite pins now. Never set in prod.
    raw = os.environ.get("MISSION_CONTROL_NOW_EPOCH")
    try:
        return int(raw) if raw else int(time.time())
    except ValueError:
        return int(time.time())


def _wire_epoch(value):
    if isinstance(value, bool) or not isinstance(value, (int, float)):
        return None
    if isinstance(value, float) and (not math.isfinite(value) or not value.is_integer()):
        return None
    return int(value)


def _iso(epoch):
    return time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime(epoch))


def _dumps(obj):
    # canonical: ascii-escapes emoji + U+2028/9; sorted keys so .json == .js payload
    return json.dumps(obj, ensure_ascii=True, sort_keys=True)


def ensure_state():
    os.makedirs(DATA, exist_ok=True)
    os.chmod(HOME, 0o700)   # security invariant: state dir 700
    os.chmod(DATA, 0o700)   # ...and the data dir too (sweep FIX 6: was 0755, world-readable)


def _atomic_write(path, text):
    tmp = "%s.tmp.%d" % (path, os.getpid())
    with open(tmp, "w") as f:
        f.write(text)
        f.flush()
        os.fsync(f.fileno())
    os.rename(tmp, path)  # atomic: a mid-write reload always sees a complete file


def _wrap(name, cadence, obj):
    """Normalize feeder output into the schema-1 envelope.

    Feeders like automation-status/chat-graph already emit a full envelope ->
    pass it through (renderer + demo + fixtures stay one shape). Raw payloads ->
    nest under data. Either way generated_* is stamped at collection time.
    """
    now = _now()
    is_env = isinstance(obj, dict) and {"schema", "feed", "data"} <= set(obj)
    if is_env:
        env = dict(obj)
        env.setdefault("ok", True)
        env.setdefault("error", None)
    else:
        env = {"ok": True, "error": None, "data": obj}
    env["schema"] = 1
    env["feed"] = name
    env["cadence_s"] = cadence
    if name == "brief":
        # Reading an old sidecar now must not relabel it as a newly composed
        # brief. The compose timestamp is a trust field, so malformed, boolean,
        # missing, or non-positive values fail this feed closed.
        epoch = obj.get("generated_epoch") if isinstance(obj, dict) else None
        if type(epoch) is not int or epoch <= 0:
            raise ValueError("brief generated_epoch must be a positive integer")
        env["generated_epoch"] = epoch
        env["generated_at"] = obj.get("generated_at") or _iso(epoch)
        # A daily product carries its own validity horizon; status + index.html
        # honor it so the brief is not aged out on the 5-minute poll cadence.
        valid_until = obj.get("valid_until") if isinstance(obj, dict) else None
        if isinstance(valid_until, int) and valid_until > 0:
            env["valid_until"] = valid_until
    else:
        env["generated_at"] = _iso(now)
        env["generated_epoch"] = now
    return env


def _write_feed(name, env):
    canon = _dumps(env)
    _atomic_write(os.path.join(DATA, name + ".json"), canon)
    js = "window.MC = window.MC||{feeds:{}}; window.MC.feeds.%s = %s;" % (name, canon)
    _atomic_write(os.path.join(DATA, name + ".js"), js)
    err = os.path.join(DATA, name + ".error.json")
    if os.path.exists(err):
        os.remove(err)  # good collection clears a prior error note
    # index.html declares every error sidecar unconditionally. Keep a healthy
    # no-error script at that path so file:// loads stay console-clean while a
    # successful refresh also clears an error from an already-open page.
    err_js = ("window.MC=window.MC||{feeds:{}};window.MC.feedErrors="
              "window.MC.feedErrors||{};delete window.MC.feedErrors.%s;" % name)
    _atomic_write(os.path.join(DATA, name + ".error.js"), err_js)


def _write_error(name, cadence, msg):
    """Record a feeder failure WITHOUT clobbering the last-good .json/.js."""
    now = _now()
    counters = EgressCounters() if EgressCounters else None
    if sanitize_text:
        result = sanitize_text(msg, ERROR, counters=counters)
        safe_error = result.value
    else:
        # A missing shared policy must never turn into permission to persist raw
        # feeder stderr. Installed and repo runtimes normally import the module.
        safe_error = "feeder error detail unavailable"
    env = {"schema": 1, "feed": name, "generated_at": _iso(now),
           "generated_epoch": now, "cadence_s": cadence,
           "ok": False, "error": safe_error, "data": None,
           "egress_counters": counters.snapshot() if counters else {
               "dropped_fields": 1, "policy_unavailable": 1}}
    canon = _dumps(env)
    _atomic_write(os.path.join(DATA, name + ".error.json"), canon)
    js = ("window.MC=window.MC||{feeds:{}};window.MC.feedErrors="
          "window.MC.feedErrors||{};window.MC.feedErrors.%s=%s;" % (name, canon))
    _atomic_write(os.path.join(DATA, name + ".error.js"), js)


def _signal_owned_group(proc, signum):
    """Signal only the unreaped session leader created by this Popen."""
    if proc.returncode is not None:
        return False
    try:
        # start_new_session made pid the group id. We deliberately do not poll
        # or wait before the final group signal, so the pid cannot be reused.
        os.killpg(proc.pid, signum)
        return True
    except ProcessLookupError:
        return True  # the unreaped leader proves this group id was not reused
    except OSError:
        return False


def _close_feeder_pipes(proc):
    for pipe in (proc.stdout, proc.stderr):
        if pipe is not None:
            try:
                pipe.close()
            except OSError:
                pass


def _terminate_feeder(proc):
    """Bound lifecycle cleanup; return True only when group cleanup is proven."""
    owned_unreaped = proc.returncode is None
    _signal_owned_group(proc, signal.SIGTERM)
    try:
        # Keep the session leader unreaped during the grace period. Its PID and
        # process-group identity therefore cannot be reused before SIGKILL.
        time.sleep(2)
    except BaseException:
        pass
    group_stopped = _signal_owned_group(proc, signal.SIGKILL)
    _close_feeder_pipes(proc)
    try:
        proc.wait(timeout=1)
    except subprocess.TimeoutExpired:
        try:
            proc.kill()
        except OSError:
            pass
        try:
            proc.wait(timeout=1)
        except (subprocess.TimeoutExpired, OSError):
            pass
    except OSError:
        pass
    return owned_unreaped and group_stopped and proc.returncode is not None


def _chat_graph_timeout_cleanup(graph_home, token):
    def cleanup(proc):
        lock = os.path.join(graph_home, "ingest.lock")
        owner_path = os.path.join(lock, "owner.json")
        expected = {"pid": proc.pid, "token": token}
        try:
            with open(owner_path) as f:
                owner = json.load(f)
                if (not isinstance(owner, dict) or owner.get("pid") != expected["pid"] or
                        owner.get("token") != expected["token"] or
                        any(key not in ("pid", "token", "start") for key in owner)):
                    return
            if any(name != "owner.json" for name in os.listdir(lock)):
                return
            os.unlink(owner_path)
            os.rmdir(lock)
        except (OSError, ValueError, TypeError):
            pass
    return cleanup


def _run_argv(argv, timeout_s, env=None, timeout_cleanup=None):
    """Run one feeder in a private session with bounded lifecycle cleanup."""
    try:
        proc = subprocess.Popen(argv, stdout=subprocess.PIPE, stderr=subprocess.PIPE,
                                text=True, encoding="utf-8", errors="replace",
                                env=env, start_new_session=True)
    except OSError:
        return None, "cannot start feeder"
    try:
        stdout, stderr = proc.communicate(timeout=timeout_s)
        return subprocess.CompletedProcess(argv, proc.returncode, stdout, stderr), None
    except subprocess.TimeoutExpired:
        cleanup_proven = _terminate_feeder(proc)
        if cleanup_proven and timeout_cleanup is not None:
            timeout_cleanup(proc)
        return None, "feeder timed out after %ds" % timeout_s
    except BaseException:
        cleanup_proven = _terminate_feeder(proc)
        if cleanup_proven and timeout_cleanup is not None:
            timeout_cleanup(proc)
        raise


# --- attention queue + ranked feed -----------------------------------------
ATTENTION_FALLBACK_Q = "Decision needs your answer"
DECISION_ATTENTION_MAX_AGE_S = 7 * 86400
STALE_DECISION_ARCHIVE_S = 14 * 86400


def _attention_dir():
    path = os.path.join(HOME, "attention")
    os.makedirs(path, exist_ok=True)
    try:
        os.chmod(path, 0o700)
    except OSError:
        pass
    return path


def _attention_queue_path():
    return os.path.join(_attention_dir(), "queue.jsonl")


def _attention_id_for_title(title):
    norm = re.sub(r"\s+", " ", (title or "").strip().lower())
    return "att:" + hashlib.sha1(norm.encode("utf-8")).hexdigest()[:12]


def _attention_read_events():
    path = _attention_queue_path()
    if not os.path.isfile(path):
        return []
    events = []
    try:
        with open(path) as fh:
            for line in fh:
                line = line.strip()
                if not line:
                    continue
                try:
                    obj = json.loads(line)
                except Exception:
                    continue
                if isinstance(obj, dict):
                    events.append(obj)
    except OSError:
        return []
    return events


def _attention_append(event):
    path = _attention_queue_path()
    line = _dumps(event) + "\n"
    flags = os.O_CREAT | os.O_APPEND | os.O_WRONLY | getattr(os, "O_NOFOLLOW", 0)
    fd = os.open(path, flags, 0o600)
    try:
        os.fchmod(fd, 0o600)
        with os.fdopen(fd, "a") as fh:
            fh.write(line)
            fh.flush()
            os.fsync(fh.fileno())
    except Exception:
        try:
            os.close(fd)
        except OSError:
            pass
        raise


def _attention_open_items():
    open_items = {}
    for event in _attention_read_events():
        eid = event.get("id")
        if not isinstance(eid, str) or not eid.startswith("att:"):
            continue
        kind = event.get("event") or event.get("kind")
        if kind in ("resolve", "resolved"):
            open_items.pop(eid, None)
            continue
        # upsert / add / refresh
        title = str(event.get("title") or "").strip()
        if not title:
            continue
        why = str(event.get("why") or "").strip()
        try:
            severity = int(event.get("severity") or 2)
        except (TypeError, ValueError):
            severity = 2
        if severity not in (1, 2, 3):
            severity = 2
        source = str(event.get("source") or "manual").strip() or "manual"
        due = event.get("due")
        if due is not None:
            due = str(due).strip() or None
        created = event.get("created_at")
        if not isinstance(created, int) or created <= 0:
            created = _now()
        open_items[eid] = {
            "id": eid,
            "title": title[:90],
            "why": why[:200],
            "severity": severity,
            "source": source,
            "due": due,
            "created_at": created,
            "kind": "manual",
        }
    return list(open_items.values())


def _parse_attention_args(argv):
    out = {"title": None, "why": "", "severity": 2, "source": "manual", "due": None}
    i = 0
    while i < len(argv):
        a = argv[i]
        if a == "--title" and i + 1 < len(argv):
            out["title"] = argv[i + 1]; i += 2
        elif a == "--why" and i + 1 < len(argv):
            out["why"] = argv[i + 1]; i += 2
        elif a == "--severity" and i + 1 < len(argv):
            out["severity"] = argv[i + 1]; i += 2
        elif a == "--source" and i + 1 < len(argv):
            out["source"] = argv[i + 1]; i += 2
        elif a == "--due" and i + 1 < len(argv):
            out["due"] = argv[i + 1]; i += 2
        else:
            raise ValueError("unknown attention argument: %s" % a)
    return out


def cmd_attention(argv):
    ensure_state()
    if not argv:
        sys.stderr.write("attention: need add|resolve|list\n")
        return 2
    sub = argv[0]
    rest = argv[1:]
    if sub == "add":
        try:
            args = _parse_attention_args(rest)
        except ValueError as exc:
            sys.stderr.write("attention add: %s\n" % exc)
            return 2
        title = (args["title"] or "").strip()
        if not title:
            sys.stderr.write("attention add: --title is required\n")
            return 2
        if len(title) > 90:
            sys.stderr.write("attention add: title must be <=90 chars\n")
            return 2
        why = (args["why"] or "").strip()
        if len(why) > 200:
            sys.stderr.write("attention add: why must be <=200 chars\n")
            return 2
        try:
            severity = int(args["severity"])
        except (TypeError, ValueError):
            sys.stderr.write("attention add: --severity must be 1|2|3\n")
            return 2
        if severity not in (1, 2, 3):
            sys.stderr.write("attention add: --severity must be 1|2|3\n")
            return 2
        due = args["due"]
        if due is not None:
            due = str(due).strip()
            if due and not re.match(r"^\d{4}-\d{2}-\d{2}$", due):
                sys.stderr.write("attention add: --due must be YYYY-MM-DD\n")
                return 2
            if not due:
                due = None
        eid = _attention_id_for_title(title)
        now = _now()
        _attention_append({
            "event": "upsert",
            "id": eid,
            "title": title,
            "why": why,
            "severity": severity,
            "source": (args["source"] or "manual").strip() or "manual",
            "due": due,
            "created_at": now,
        })
        print(eid)
        return 0
    if sub == "resolve":
        if not rest:
            sys.stderr.write("attention resolve: need <id>\n")
            return 2
        eid = rest[0].strip()
        if not re.match(r"^att:[0-9a-f]{12}$", eid):
            sys.stderr.write("attention resolve: invalid id\n")
            return 2
        _attention_append({
            "event": "resolve",
            "id": eid,
            "resolved_at": _now(),
        })
        print(eid)
        return 0
    if sub == "list":
        as_json = "--json" in rest
        items = sorted(
            _attention_open_items(),
            key=lambda x: (x.get("severity", 2), x.get("due") or "9999-99-99",
                           -(x.get("created_at") or 0)))
        if as_json:
            print(_dumps({"ok": True, "items": items, "count": len(items)}))
        else:
            if not items:
                print("(no open attention items)")
            for item in items:
                print("%s  s%s  %s" % (item["id"], item["severity"], item["title"]))
        return 0
    sys.stderr.write("attention: unknown subcommand %r\n" % sub)
    return 2


def _demote_stale_decisions(obj):
    """Move pinned decisions unanswered >14d into data.archived (keep on disk)."""
    if not isinstance(obj, dict):
        return obj
    data = obj.get("data")
    if not isinstance(data, dict):
        return obj
    pinned = data.get("pinned")
    if not isinstance(pinned, list):
        return obj
    now = _now()
    cutoff = now - STALE_DECISION_ARCHIVE_S
    keep = []
    archived = list(data.get("archived") or []) if isinstance(data.get("archived"), list) else []
    seen_arch = set(d.get("id") for d in archived if isinstance(d, dict))
    for item in pinned:
        if not isinstance(item, dict):
            continue
        first_seen = item.get("first_seen")
        try:
            first_seen_i = int(first_seen) if first_seen is not None else None
        except (TypeError, ValueError):
            first_seen_i = None
        if first_seen_i is not None and first_seen_i > 0 and first_seen_i < cutoff:
            if item.get("id") not in seen_arch:
                archived.append(item)
                seen_arch.add(item.get("id"))
        else:
            keep.append(item)
    data = dict(data)
    data["pinned"] = keep
    data["archived"] = archived
    data["archived_count"] = len(archived)
    out = dict(obj)
    out["data"] = data
    return out


def _decision_quality_ok(item, now):
    if not isinstance(item, dict):
        return False
    question = str(item.get("question") or "").strip()
    if not question and item.get("text"):
        # Fixture/old cache may only have text; use a cheap strip of markdown noise.
        raw = str(item.get("text") or "")
        question = re.sub(r"\*\*|`", " ", raw)
        question = re.sub(r"\s+", " ", question).strip()
        if question.lower().startswith("decision needed:"):
            question = question[16:].strip()
    if len(question) < 15:
        return False
    if question == ATTENTION_FALLBACK_Q:
        return False
    first_seen = item.get("first_seen")
    try:
        first_seen_i = int(first_seen) if first_seen is not None else None
    except (TypeError, ValueError):
        first_seen_i = None
    if first_seen_i is None or first_seen_i <= 0:
        # No age → treat as fresh enough to surface (fixtures often omit first_seen).
        return True
    return (now - first_seen_i) <= DECISION_ATTENTION_MAX_AGE_S


def _rank_attention_entries(entries):
    def due_key(item):
        due = item.get("due")
        if isinstance(due, str) and re.match(r"^\d{4}-\d{2}-\d{2}$", due):
            return due
        return "9999-99-99"

    return sorted(
        entries,
        key=lambda x: (
            int(x.get("severity") or 2),
            due_key(x),
            -(int(x.get("created_at") or 0)),
        ),
    )


def _run_builtin_attention(_timeout_s):
    now = _now()
    entries = []
    counts = {"manual": 0, "decision": 0, "automation": 0, "decisions_filtered_out": 0}

    for item in _attention_open_items():
        entries.append(item)
        counts["manual"] += 1

    dec_env = _load("decisions")
    dec_data = (dec_env or {}).get("data") if isinstance(dec_env, dict) else None
    pinned = (dec_data or {}).get("pinned") if isinstance(dec_data, dict) else []
    if not isinstance(pinned, list):
        pinned = []
    for item in pinned:
        if not isinstance(item, dict):
            counts["decisions_filtered_out"] += 1
            continue
        if not _decision_quality_ok(item, now):
            counts["decisions_filtered_out"] += 1
            continue
        question = str(item.get("question") or "").strip()
        if not question:
            question = str(item.get("text") or "").strip()[:90]
        entry = {
            "id": item.get("id"),
            "title": question[:90] if question else "Decision",
            "why": (str(item.get("provenance") or item.get("source_kind") or "decision")
                    )[:200],
            "severity": 1,
            "source": "decisions",
            "due": None,
            "created_at": int(item.get("first_seen") or now),
            "kind": "decision",
            "options": item.get("options") if isinstance(item.get("options"), list) else None,
            "question": item.get("question"),
            "recommended": item.get("recommended"),
            "text": item.get("text"),
        }
        entries.append(entry)
        counts["decision"] += 1

    auto_env = _load("automation")
    auto_data = (auto_env or {}).get("data") if isinstance(auto_env, dict) else None
    jobs = (auto_data or {}).get("jobs") if isinstance(auto_data, dict) else []
    if not isinstance(jobs, list):
        jobs = []
    for job in jobs:
        if not isinstance(job, dict) or job.get("state") != "red":
            continue
        name = str(job.get("label") or job.get("name") or "automation job")
        why = str(job.get("err_log_tail") or job.get("schedule") or
                  job.get("state") or "red")
        jid = "auto:" + hashlib.sha1(name.encode("utf-8")).hexdigest()[:12]
        entries.append({
            "id": jid,
            "title": name[:90],
            "why": why[:200],
            "severity": 1,
            "source": "automation",
            "due": None,
            "created_at": now,
            "kind": "automation",
        })
        counts["automation"] += 1

    ranked = _rank_attention_entries(entries)
    return {
        "board": ranked[:25],
        "top5": ranked[:5],
        "counts": counts,
    }, None


def _run_builtin_chats(timeout_s):
    cg = os.path.join(REPO, "scripts", "chat-graph")
    child_env = dict(os.environ)
    token = os.urandom(16).hex()
    child_env["CHAT_GRAPH_LOCK_TOKEN"] = token
    if "CHAT_GRAPH_GIT_FEED" not in child_env and "CHAT_GRAPH_SCAN_CMD" not in child_env:
        child_env["CHAT_GRAPH_GIT_FEED"] = os.path.join(DATA, "git.json")
    graph_home = os.path.expanduser(child_env.get(
        "CHAT_GRAPH_HOME", os.path.join(child_env.get("HOME", ""), ".chat-graph")))
    p, run_error = _run_argv(
        [cg, "export", "--json", "--catchup-limit", "1500"], timeout_s,
        env=child_env, timeout_cleanup=_chat_graph_timeout_cleanup(graph_home, token))
    if run_error:
        return None, run_error
    if p.returncode != 0:
        return None, "chat-graph export exit %d: %s" % (p.returncode, (p.stderr or "").strip()[:200])
    graph_home = os.environ.get("CHAT_GRAPH_HOME",
                                os.path.join(os.environ.get("HOME", ""), ".chat-graph"))
    graph_path = os.path.join(graph_home, "export", "graph.json")
    try:
        with open(graph_path) as f:
            return json.load(f), None
    except Exception as e:
        return None, "cannot read graph export: %s" % e


def _run_builtin_brief(timeout_s):
    installed = os.path.join(HOME, "bin", "morning-brief")
    composer = installed if os.path.isfile(installed) and os.access(installed, os.X_OK) \
        else os.path.join(REPO, "scripts", "morning-brief")
    path = os.path.join(HOME, "morning-brief", "latest.json")
    # Collection is a reader after the first bootstrap. Re-composing on every
    # 5-minute dashboard poll would overwrite a delivered sidecar with not_sent
    # before the 05:20 deadman checks it.
    if not os.path.isfile(path):
        p, run_error = _run_argv([composer], timeout_s)
        if run_error:
            return None, ("morning-brief timed out after %ds" % timeout_s
                          if "timed out" in run_error else "cannot start morning-brief")
        if p.returncode != 0:
            return None, "morning-brief exit %d: %s" % (p.returncode, (p.stderr or "").strip()[:200])
    try:
        with open(path) as f:
            return json.load(f), None
    except Exception as e:
        return None, "cannot read Morning Brief sidecar: %s" % e


def _run_builtin_decisions(timeout_s):
    installed = os.path.join(HOME, "bin", "decision-alert")
    tool = installed if os.path.isfile(installed) and os.access(installed, os.X_OK) \
        else os.path.join(REPO, "scripts", "decision-alert")
    p, run_error = _run_argv([tool, "sync-snapshot", "--json"], timeout_s)
    if run_error:
        return None, ("decision queue timed out after %ds" % timeout_s
                      if "timed out" in run_error else "cannot start decision queue")
    if p.returncode != 0:
        return None, "decision queue exit %d" % p.returncode
    try:
        payload = json.loads(p.stdout)
    except Exception:
        return None, "decision queue output not JSON"
    # Best-effort loud channel: after sync, alert a small newest batch through
    # the existing mobile-connect sender. Failures never poison the decisions
    # feed; they surface under data.alert for glance trust.
    auto = os.environ.get("DECISION_ALERT_AUTO", "1").strip().lower()
    if auto not in ("0", "false", "no", "off") and isinstance(payload, dict):
        alert_timeout = min(30, max(5, int(timeout_s) // 2 or 5))
        try:
            max_send = int(os.environ.get("DECISION_ALERT_MAX", "3"))
        except ValueError:
            max_send = 3
        try:
            fresh_within = int(os.environ.get("DECISION_ALERT_FRESH_WITHIN_S",
                                              str(48 * 60 * 60)))
        except ValueError:
            fresh_within = 48 * 60 * 60
        argv = [tool, "alert", "--send", "--newest-first",
                "--max", str(max(0, max_send)),
                "--fresh-within", str(max(0, fresh_within)), "--json"]
        ap, aerr = _run_argv(argv, alert_timeout)
        alert_meta = {
            "ok": False,
            "error": aerr or "alert runner failed",
            "sent_count": 0,
            "failed_count": 0,
            "eligible_count": 0,
        }
        if not aerr and ap is not None:
            try:
                aobj = json.loads(ap.stdout or "{}")
                if isinstance(aobj, dict):
                    alert_meta = {
                        "ok": bool(aobj.get("ok")) and ap.returncode == 0,
                        "error": None if ap.returncode == 0 else (
                            (ap.stderr or "").strip()[:200] or "alert exit %d" % ap.returncode),
                        "sent_count": int(aobj.get("sent_count") or 0),
                        "failed_count": int(aobj.get("failed_count") or 0),
                        "eligible_count": int(aobj.get("eligible_count") or 0),
                        "sent": aobj.get("sent") or [],
                        "mode": aobj.get("mode"),
                    }
                    if ap.returncode != 0 and not alert_meta["error"]:
                        # Prefer structured stderr from decision-alert.
                        try:
                            err_obj = json.loads(ap.stderr or "")
                            if isinstance(err_obj, dict) and err_obj.get("error"):
                                alert_meta["error"] = str(err_obj["error"])[:200]
                        except Exception:
                            pass
                else:
                    alert_meta["error"] = "alert output not object"
            except Exception:
                # Non-zero send can still print JSON on stdout; try stderr too.
                try:
                    err_obj = json.loads((ap.stderr or ap.stdout or "").strip() or "{}")
                    if isinstance(err_obj, dict) and err_obj.get("error"):
                        alert_meta["error"] = str(err_obj["error"])[:200]
                except Exception:
                    alert_meta["error"] = "alert output not JSON"
        data = payload.get("data")
        if not isinstance(data, dict):
            data = {}
            payload["data"] = data
        data["alert"] = alert_meta
        # Refresh status so receipts stamped by this tick appear in the feed.
        if alert_meta.get("sent_count"):
            sp, serr = _run_argv([tool, "status", "--json"], min(15, alert_timeout))
            if not serr and sp is not None and sp.returncode == 0:
                try:
                    refreshed = json.loads(sp.stdout)
                    if isinstance(refreshed, dict) and isinstance(refreshed.get("data"), dict):
                        refreshed["data"]["alert"] = alert_meta
                        if isinstance(data.get("sync"), dict):
                            refreshed["data"]["sync"] = data["sync"]
                        payload = refreshed
                except Exception:
                    pass
    return payload, None


def _run_feeder(name, defcmd, envvar, timeout_s):
    override = os.environ.get(envvar)
    if override:
        if _SHELL_FORBIDDEN.search(override):
            return None, "feeder override contains forbidden shell characters"
        argv = shlex.split(override)
        p, run_error = _run_argv(argv, timeout_s)
        if run_error:
            return None, run_error
        if p.returncode not in OK_EXITS.get(name, (0,)):
            return None, "feeder exit %d: %s" % (p.returncode, (p.stderr or "").strip()[:200])
        try:
            obj = json.loads(p.stdout)
        except Exception as e:
            return None, "feeder output not JSON: %s" % e
        if name == "decisions":
            obj = _demote_stale_decisions(obj)
        return obj, None
    if name == "chats":
        return _run_builtin_chats(timeout_s)
    if name == "decisions":
        obj, err = _run_builtin_decisions(timeout_s)
        if err:
            return None, err
        return _demote_stale_decisions(obj), None
    if name == "attention":
        return _run_builtin_attention(timeout_s)
    if name == "brief":
        return _run_builtin_brief(timeout_s)
    argv = shlex.split(defcmd)
    p, run_error = _run_argv(argv, timeout_s)
    if run_error:
        return None, run_error
    if p.returncode not in OK_EXITS.get(name, (0,)):
        return None, "feeder exit %d: %s" % (p.returncode, (p.stderr or "").strip()[:200])
    try:
        obj = json.loads(p.stdout)
    except Exception as e:
        return None, "feeder output not JSON: %s" % e
    if name == "decisions":
        obj = _demote_stale_decisions(obj)
    return obj, None


def _collect_one(name, cadence, defcmd, envvar, timeout_s):
    # Advisory file locks are released by the kernel when this process exits,
    # including SIGKILL. The distinct suffix ignores crash-left mkdir locks from
    # older runtimes without stealing ownership from a still-running old process.
    lock = os.path.join(DATA, "." + name + ".lockfile")
    try:
        flags = os.O_CREAT | os.O_RDWR | getattr(os, "O_NOFOLLOW", 0)
        lock_fd = os.open(lock, flags, 0o600)
        os.fchmod(lock_fd, 0o600)
        if not stat.S_ISREG(os.fstat(lock_fd).st_mode):
            raise OSError(errno.EINVAL, "feed lock is not a regular file")
    except OSError as exc:
        # A missing/unwritable/unsafe lock is an operational error, not proof
        # that another healthy collector owns the lock.
        code = errno.errorcode.get(exc.errno, "OS_ERROR")
        try:
            _write_error(name, cadence, "feed lock setup failed (%s)" % code)
        except OSError:
            pass
        return "error"
    try:
        try:
            fcntl.flock(lock_fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError:
            return "locked"
        except OSError as exc:
            if exc.errno in (errno.EACCES, errno.EAGAIN):
                return "locked"
            code = errno.errorcode.get(exc.errno, "OS_ERROR")
            try:
                _write_error(name, cadence, "feed lock acquisition failed (%s)" % code)
            except OSError:
                pass
            return "error"
        obj, err = _run_feeder(name, defcmd, envvar, timeout_s)
        if err:
            _write_error(name, cadence, err)
            return "error"
        try:
            env = _wrap(name, cadence, obj)
        except (TypeError, ValueError) as exc:
            _write_error(name, cadence, "invalid feeder payload: %s" % exc)
            return "error"
        _write_feed(name, env)
        return "ok"
    finally:
        try:
            os.close(lock_fd)
        except OSError:
            pass


def _is_due(name, cadence):
    p = os.path.join(DATA, name + ".json")
    if not os.path.exists(p):
        return True
    try:
        with open(p) as f:
            env = json.load(f)
        age = _now() - int(env.get("generated_epoch", 0))
        return age < 0 or age >= cadence
    except Exception:
        return True


def cmd_collect(argv):
    ensure_state()
    force = "--force" in argv
    due = "--due" in argv
    strict = "--strict" in argv
    only = [a for a in argv if not a.startswith("--")]
    failed = False
    git_attempt_status = None
    for name, cadence, defcmd, envvar, tmo in FEEDS:
        if only and name not in only:
            continue
        if due and not force and not _is_due(name, cadence):
            continue
        prior_skip = os.environ.get("CHAT_GRAPH_SKIP_REPO_SCAN")
        if name == "chats" and git_attempt_status in ("error", "locked"):
            os.environ["CHAT_GRAPH_SKIP_REPO_SCAN"] = \
                "dashboard Git feed %s in this collection cycle" % git_attempt_status
        try:
            status = _collect_one(name, cadence, defcmd, envvar, tmo)
        finally:
            if name == "chats":
                if prior_skip is None:
                    os.environ.pop("CHAT_GRAPH_SKIP_REPO_SCAN", None)
                else:
                    os.environ["CHAT_GRAPH_SKIP_REPO_SCAN"] = prior_skip
        if name == "git":
            git_attempt_status = status
        failed = failed or status != "ok"
    # Normal collection preserves feed independence. Explicit operator
    # round-trips can request strict status so a lock/error is never reported
    # as a successful user-visible refresh.
    return 1 if strict and failed else 0


def _load(name):
    p = os.path.join(DATA, name + ".json")
    if not os.path.exists(p):
        return None
    try:
        with open(p) as f:
            return json.load(f)
    except Exception:
        return None


def _load_error(name):
    p = os.path.join(DATA, name + ".error.json")
    if not os.path.exists(p):
        return None
    try:
        with open(p) as f:
            value = json.load(f)
        return value if isinstance(value, dict) and value.get("ok") is False else None
    except Exception:
        return None


def _current_status_env(name):
    good = _load(name)
    if not isinstance(good, dict):
        good = None
    error = _load_error(name)
    error_epoch = _wire_epoch(error.get("generated_epoch")) if error else 0
    good_epoch = _wire_epoch(good.get("generated_epoch")) if good else 0
    error_epoch = error_epoch if error_epoch is not None else _now()
    good_epoch = good_epoch if good_epoch is not None else 0
    if error and (good is None or error_epoch >= good_epoch):
        return error
    return good


def _verdict(env, cadence):
    """(text, is_red). red = errored feed or stale beyond 6x cadence.

    Thin adapter over the shared feed_health so status, index.html and the brief
    agree on freshness (incl. a daily product's valid_until and nested ingest).
    """
    h = feed_health(env, cadence, _now())
    return h["state"], h["red"]


def _automation_red(env):
    # structured read: data.jobs[].state == "red". NOT a substring/recursive
    # scan -- data.counts has a "red" COUNT key that would false-match.
    if not env or not isinstance(env.get("data"), dict):
        return False
    jobs = env["data"].get("jobs")
    if not isinstance(jobs, list):
        return False
    return any(isinstance(j, dict) and j.get("state") == "red" for j in jobs)


def _chats_nested_ingest_state(env, cadence):
    # The feed can be freshly generated from a bounded catch-up while the last
    # completed transcript scan is stale. Shared detector, surfaced separately.
    return feed_health(env, cadence, _now()).get("nested_state", "fresh")


def cmd_status(argv):
    ensure_state()
    now = _now()
    red = False
    print("%-12s %-9s %-6s %s" % ("FEED", "AGE", "OK", "VERDICT"))
    for name, cadence, _, _, _ in FEEDS:
        env = _current_status_env(name)
        verdict, is_red = _verdict(env, cadence)
        if name == "automation" and _automation_red(env):
            is_red = True
            verdict += " (red job)"
        if name == "chats":
            nested = _chats_nested_ingest_state(env, cadence)
            if nested == "stale":
                is_red = True
                verdict += " (stale full ingest)"
            elif nested == "unknown":
                is_red = True
                verdict += " (unknown full ingest)"
        if env is None:
            age, oks = "-", "-"
        else:
            epoch = _wire_epoch(env.get("generated_epoch"))
            age = ("%ds" % (now - epoch)) if epoch is not None else "-"
            oks = "ok" if env.get("ok") is True else "error"
        red = red or is_red
        print("%-12s %-9s %-6s %s" % (name, age, oks, verdict))
    if verify_install_stamp is None:
        stamp = {"present": False, "ok": False, "head_sha": None,
                 "provenance": None, "reason": "verifier-unavailable",
                 "mismatches": [], "missing": [], "unexpected": []}
    else:
        stamp = verify_install_stamp(os.path.join(HOME, "bin"))
    sha_value = stamp.get("head_sha")
    sha = (sha_value[:12] if isinstance(sha_value, str) and sha_value
           else "unknown")
    prov = stamp.get("provenance") or "unknown"
    if stamp["ok"]:
        print("%-12s %-9s %-6s %s" % ("install", sha, "ok",
              "verified (%s)" % prov))
    else:
        red = True
        reason = stamp.get("reason") or "unverified"
        details = ",".join(stamp.get("mismatches", []) +
                           stamp.get("missing", []) +
                           stamp.get("unexpected", []))
        suffix = (" (%s)" % details) if details else ""
        print("%-12s %-9s %-6s %s" % ("install", sha, "error",
              "UNVERIFIED: %s%s" % (reason, suffix)))
    return 1 if red else 0


def cmd_freshness(argv):
    now = _now()
    for name, cadence, _, _, _ in FEEDS:
        env = _current_status_env(name)
        verdict, _ = _verdict(env, cadence)
        if env is None:
            print("%-12s no data" % name)
        else:
            epoch = _wire_epoch(env.get("generated_epoch"))
            age = ("%ds ago" % (now - epoch)) if epoch is not None else "unknown age"
            print("%-12s %s (%s)" % (name, verdict, age))
    return 0


def cmd_demo(argv):
    """Build feeds from committed fixtures into the given state dir (argv[0])."""
    dest = argv[0]
    data_dir = os.path.join(dest, "data")
    os.makedirs(data_dir, exist_ok=True)
    os.chmod(dest, 0o700)
    fixtures = os.path.join(REPO, "dashboard", "fixtures")
    built = []
    if os.path.isdir(fixtures):
        for fn in sorted(os.listdir(fixtures)):
            if not fn.endswith(".json"):
                continue
            name = fn[:-5]
            env = json.load(open(os.path.join(fixtures, fn)))
            now = _now()
            env["generated_at"] = _iso(now)      # fresh dots for design iteration
            env["generated_epoch"] = now
            canon = _dumps(env)
            _atomic_write(os.path.join(data_dir, name + ".json"), canon)
            js = ("window.MC = window.MC||{feeds:{}}; window.MC.feeds.%s = %s;"
                  % (name, canon))
            _atomic_write(os.path.join(data_dir, name + ".js"), js)
            no_error = ("window.MC=window.MC||{feeds:{}};window.MC.feedErrors="
                        "window.MC.feedErrors||{};delete window.MC.feedErrors.%s;" % name)
            _atomic_write(os.path.join(data_dir, name + ".error.js"), no_error)
            built.append(name)
    shell = os.path.join(REPO, "dashboard", "index.html")
    if os.path.isfile(shell):
        shutil.copy(shell, os.path.join(dest, "index.html"))
    vendor = os.path.join(REPO, "dashboard", "vendor", "cytoscape.min.js")
    if os.path.isfile(vendor):
        vendor_dir = os.path.join(dest, "vendor")
        os.makedirs(vendor_dir, exist_ok=True)
        shutil.copy(vendor, os.path.join(vendor_dir, "cytoscape.min.js"))
    print("demo state: %s" % dest)
    print("demo feeds: %s" % ",".join(built))
    return 0


def main():
    cmd = sys.argv[1] if len(sys.argv) > 1 else ""
    rest = sys.argv[2:]
    fn = {"collect": cmd_collect, "status": cmd_status,
          "demo": cmd_demo, "freshness": cmd_freshness,
          "attention": cmd_attention}.get(cmd)
    if not fn:
        sys.stderr.write("dashboard-engine: unknown command %r\n" % cmd)
        return 2
    return fn(rest)


sys.exit(main())
PYEOF
}

usage() {
  cat <<'EOF'
usage: dashboard <command>
  collect [--due|--force] [feed]   collect feeds (--due honors cadence)
  refresh [feed]                   = collect --force
  status                           text health table; nonzero if any feed red
  brief --print                    print a deterministic preview; change no cursor
  extract-outcomes [options]       run bounded Tier 2 outcome enrichment
  attention add --title <text> [--why <text>] [--severity 1|2|3] [--source <text>] [--due YYYY-MM-DD]
                                    publish/refresh a manual attention item; prints id
  attention resolve <id>           resolve one manual attention item
  attention list [--json]          list open manual attention items
  decide dismiss <decision-id> [--source <src>]
                                    dismiss one queued decision; execute no action
  decide answer <decision-id> <n> [--source <src>] [--resume-chat-id <id>] [--resume-provider <p>]
                                    record Trevor choice n, write Goal prompt, resolve decision
  decide alert-backfill [--max N]  send remaining eligible alerts (default 10, ceiling 25)
  panel [--install-only]           refresh feeds + open corner menu-bar panel; installs login KeepAlive (ER-134)
  open [--serve]                   collect --due, open the shell (--serve: local http)
  install                          install shell + launchd job (no flags; idempotent)
  demo                             build feeds from fixtures into a temp dir + open
EOF
}

do_serve() {
  mkdir -p "$MISSION_CONTROL_HOME/data"
  chmod 700 "$MISSION_CONTROL_HOME" 2>/dev/null || true
  python3 - "$MISSION_CONTROL_HOME" <<'PYEOF'
import http.server, os, socketserver, sys
root = sys.argv[1]
os.chdir(root)
with socketserver.TCPServer(("127.0.0.1", 0), http.server.SimpleHTTPRequestHandler) as h:
    print("serving %s at http://127.0.0.1:%d/" % (root, h.server_address[1]))
    sys.stdout.flush()
    h.serve_forever()
PYEOF
}



# Login KeepAlive for the menu-bar panel (ER-134). Not part of install selected_plists.
_mc_panel_autoload_allowed() {
  [ "${DASHBOARD_NO_OPEN:-}" = "1" ] && return 1
  [ "${DASHBOARD_INSTALL_NO_LAUNCHD:-0}" = "1" ] && return 1
  case "$MISSION_CONTROL_HOME" in
    /tmp/*|/private/tmp/*|/var/folders/*)
      return 1
      ;;
  esac
  if [ -n "${TMPDIR:-}" ]; then
    case "$MISSION_CONTROL_HOME" in
      "${TMPDIR%/}"/*) return 1 ;;
    esac
  fi
  return 0
}

# Render + bootstrap com.gillettes.mc-panel. Returns 0 when launchd owns the process.
_ensure_mc_panel_autoload() {
  local label="com.gillettes.mc-panel"
  local plist="${label}.plist"
  local tmpl="$MISSION_CONTROL_HOME/launchd/${plist}.template"
  local dest="$HOME/Library/LaunchAgents/$plist"
  local domain="gui/$(id -u)"
  local rendered changed loaded

  [ -f "$tmpl" ] || {
    echo "panel: missing autoload template: $tmpl" >&2
    return 1
  }
  command -v launchctl >/dev/null 2>&1 || return 1
  command -v plutil >/dev/null 2>&1 || return 1
  mkdir -p "$HOME/Library/LaunchAgents" "$MISSION_CONTROL_HOME/logs" || return 1
  if [ -L "$dest" ] || { [ -e "$dest" ] && [ ! -f "$dest" ]; }; then
    echo "panel: refusing unsafe LaunchAgent destination: $dest" >&2
    return 1
  fi
  rendered="$(mktemp "${TMPDIR:-/tmp}/mc-panel-plist.XXXXXX")" || return 1
  if ! python3 - "$tmpl" "$rendered" "$MISSION_CONTROL_HOME" "$HOME" "$REPO_ROOT" <<'PYEOF'
import sys
source, dest, mc_home, home, repo = sys.argv[1:]
text = open(source).read()
text = text.replace("__MCHOME__", mc_home).replace("__HOME__", home).replace("__REPO__", repo)
with open(dest, "w") as handle:
    handle.write(text)
PYEOF
  then
    rm -f "$rendered"
    return 1
  fi
  if ! plutil -lint "$rendered" >/dev/null 2>&1; then
    echo "panel: autoload plist failed validation" >&2
    rm -f "$rendered"
    return 1
  fi
  changed=1
  [ -f "$dest" ] && cmp -s "$rendered" "$dest" && changed=0
  loaded=0
  if launchctl print "$domain/$label" >/dev/null 2>&1; then
    loaded=1
  fi
  if [ "$changed" = 1 ] && [ "$loaded" = 1 ]; then
    launchctl bootout "$domain/$label" >/dev/null 2>&1 || true
    loaded=0
  fi
  if [ "$changed" = 1 ]; then
    if ! cp "$rendered" "$dest"; then
      rm -f "$rendered"
      return 1
    fi
    chmod 600 "$dest" || true
    echo "panel: installed login autoload -> $dest"
  else
    chmod 600 "$dest" 2>/dev/null || true
  fi
  rm -f "$rendered"
  if [ "$loaded" = 0 ]; then
    if ! launchctl bootstrap "$domain" "$dest" >/dev/null 2>&1; then
      echo "panel: bootstrap failed: $label" >&2
      return 1
    fi
    echo "panel: bootstrapped $label (KeepAlive + RunAtLoad)"
  else
    launchctl kickstart -k "$domain/$label" >/dev/null 2>&1 || true
    echo "panel: login autoload already loaded ($label)"
  fi
  return 0
}

_mc_panel_build_valid() {
  python3 - "$MISSION_CONTROL_HOME/bin/mc-panel.swift" \
    "$MISSION_CONTROL_HOME/bin/mc-panel" "$MISSION_CONTROL_HOME/bin/mc-panel-build.json" <<'PYEOF'
import hashlib,json,os,sys
source,binary,stamp=sys.argv[1:]
def digest(path):
    h=hashlib.sha256()
    with open(path,"rb") as handle:
        for chunk in iter(lambda:handle.read(131072),b""):h.update(chunk)
    return h.hexdigest()
try:
    data=json.load(open(stamp))
    ok=(not os.path.islink(source) and not os.path.islink(binary) and
        os.path.isfile(source) and os.path.isfile(binary) and
        data.get("schema")==1 and data.get("source_sha256")==digest(source) and
        data.get("binary_sha256")==digest(binary))
except (OSError,ValueError,TypeError):
    ok=False
raise SystemExit(0 if ok else 1)
PYEOF
}

_mc_stamp_panel_build() {
  python3 - "$MISSION_CONTROL_HOME/bin/mc-panel.swift" \
    "$MISSION_CONTROL_HOME/bin/mc-panel" "$MISSION_CONTROL_HOME/bin/mc-panel-build.json" <<'PYEOF'
import hashlib,json,os,sys,tempfile,time
source,binary,stamp=sys.argv[1:]
def digest(path):
    h=hashlib.sha256()
    with open(path,"rb") as handle:
        for chunk in iter(lambda:handle.read(131072),b""):h.update(chunk)
    return h.hexdigest()
payload={"schema":1,"source_sha256":digest(source),"binary_sha256":digest(binary),
         "built_at":int(time.time())}
fd,tmp=tempfile.mkstemp(prefix=".mc-panel-build.",dir=os.path.dirname(stamp))
try:
    os.fchmod(fd,0o600)
    with os.fdopen(fd,"w") as handle:
        json.dump(payload,handle,sort_keys=True);handle.write("\n")
        handle.flush();os.fsync(handle.fileno())
    os.replace(tmp,stamp)
except BaseException:
    try:os.unlink(tmp)
    except OSError:pass
    raise
PYEOF
}

do_panel() {
  # Create the panel state roots without following a pre-seeded directory link.
  # The collector and compiler both write below these paths.
  if ! python3 - "$MISSION_CONTROL_HOME" <<'PYEOF'
import os, stat, sys
home=sys.argv[1]
for path in (home, os.path.join(home,"data"), os.path.join(home,"bin")):
    if os.path.lexists(path):
        st=os.lstat(path)
        if stat.S_ISLNK(st.st_mode) or not stat.S_ISDIR(st.st_mode):
            raise SystemExit("panel: unsafe runtime directory: %s"%path)
    else:
        os.mkdir(path,0o700)
    os.chmod(path,0o700)
PYEOF
  then
    return 1
  fi
  engine collect --due decisions automation attention >/dev/null 2>&1 || engine collect --force decisions automation attention >/dev/null || true
  local src_panel="$MISSION_CONTROL_HOME/panel.html"
  if [ -L "$src_panel" ] || { [ -e "$src_panel" ] && [ ! -f "$src_panel" ]; }; then
    echo "panel: unsafe installed panel destination" >&2
    return 1
  fi
  if [ ! -f "$src_panel" ] && [ "${DASHBOARD_INSTALL_ALLOW_WORKTREE:-0}" = "1" ]; then
    if ! python3 - "$REPO_ROOT/dashboard/panel.html" "$src_panel" \
        "$REPO_ROOT/scripts/mc-panel.swift" "$MISSION_CONTROL_HOME/bin/mc-panel.swift" <<'PYEOF'
import os, stat, sys, tempfile
for source, dest in zip(sys.argv[1::2], sys.argv[2::2]):
    if not os.path.isfile(source) or os.path.islink(source):
        raise SystemExit("panel: unsafe worktree source")
    if os.path.lexists(dest):
        st=os.lstat(dest)
        if stat.S_ISLNK(st.st_mode) or not stat.S_ISREG(st.st_mode):
            raise SystemExit("panel: unsafe installed destination")
    fd,tmp=tempfile.mkstemp(prefix=".panel-install.",dir=os.path.dirname(dest))
    try:
        os.fchmod(fd,0o600)
        with open(source,"rb") as src, os.fdopen(fd,"wb") as out:
            out.write(src.read());out.flush();os.fsync(out.fileno())
        os.replace(tmp,dest)
    except BaseException:
        try:os.unlink(tmp)
        except OSError:pass
        raise
PYEOF
    then
      return 1
    fi
    chmod 600 "$src_panel" "$MISSION_CONTROL_HOME/bin/mc-panel.swift" || return 1
  fi
  if [ ! -f "$src_panel" ]; then
    echo "panel: installed panel missing; run dashboard install" >&2
    return 1
  fi
  if [ "${1:-}" = "--install-only" ]; then
    echo "installed panel -> $src_panel"
    return 0
  fi
  local bin=""
  if _mc_panel_build_valid; then
    bin="$MISSION_CONTROL_HOME/bin/mc-panel"
  elif [ -f "$MISSION_CONTROL_HOME/bin/mc-panel.swift" ] && command -v swiftc >/dev/null 2>&1; then
    if [ -L "$MISSION_CONTROL_HOME/bin/mc-panel" ] || \
       { [ -e "$MISSION_CONTROL_HOME/bin/mc-panel" ] && [ ! -f "$MISSION_CONTROL_HOME/bin/mc-panel" ]; }; then
      echo "panel: unsafe compiled binary destination" >&2
      return 1
    fi
    echo "panel: compiling mc-panel…"
    rm -f "$MISSION_CONTROL_HOME/bin/mc-panel-build.json"
    if swiftc -O -o "$MISSION_CONTROL_HOME/bin/mc-panel" "$MISSION_CONTROL_HOME/bin/mc-panel.swift" \
        -framework AppKit -framework WebKit 2>/dev/null; then
      if chmod 700 "$MISSION_CONTROL_HOME/bin/mc-panel" && _mc_stamp_panel_build; then
        bin="$MISSION_CONTROL_HOME/bin/mc-panel"
      fi
    fi
  fi
  if [ -z "$bin" ]; then
    echo "panel: mc-panel binary missing; open panel.html in browser instead" >&2
    if [ "${DASHBOARD_NO_OPEN:-}" != "1" ]; then
      open "$MISSION_CONTROL_HOME/panel.html" 2>/dev/null || true
    fi
    return 0
  fi
  # Stage a tiny LSUIElement .app so Control Center keeps the status item alive.
  # Anonymous raw binaries get "after-life.interrupted" and exit within ~20s on modern macOS.
  local app_dir="$MISSION_CONTROL_HOME/Mission Control Panel.app"
  local app_macos="$app_dir/Contents/MacOS"
  local app_bin="$app_macos/mc-panel"
  # Treat the entire app staging tree as a deployment boundary. Refuse links
  # and non-directories at every ancestor, then replace both files atomically.
  # This prevents a pre-seeded app bundle from redirecting writes elsewhere.
  if ! python3 - "$app_dir" "$bin" <<'PYEOF'
import hashlib, os, stat, sys, tempfile

app, source = sys.argv[1:]
contents = os.path.join(app, "Contents")
macos = os.path.join(contents, "MacOS")
binary = os.path.join(macos, "mc-panel")
plist = os.path.join(contents, "Info.plist")

def safe_dir(path, mode=0o700):
    if os.path.lexists(path):
        st = os.lstat(path)
        if stat.S_ISLNK(st.st_mode) or not stat.S_ISDIR(st.st_mode):
            raise SystemExit("panel: unsafe app directory: %s" % path)
    else:
        os.mkdir(path, mode)
    os.chmod(path, mode)

def atomic_bytes(dest, payload, mode):
    if os.path.lexists(dest):
        st = os.lstat(dest)
        if stat.S_ISLNK(st.st_mode) or not stat.S_ISREG(st.st_mode):
            raise SystemExit("panel: unsafe app file: %s" % dest)
    fd, tmp = tempfile.mkstemp(prefix=".mc-panel-stage.", dir=os.path.dirname(dest))
    try:
        os.fchmod(fd, mode)
        with os.fdopen(fd, "wb") as handle:
            handle.write(payload)
            handle.flush()
            os.fsync(handle.fileno())
        os.replace(tmp, dest)
    except BaseException:
        try: os.unlink(tmp)
        except OSError: pass
        raise

if os.path.islink(source) or not os.path.isfile(source):
    raise SystemExit("panel: compiled binary is not a regular file")
parent = os.path.dirname(app)
if not os.path.isdir(parent) or os.path.islink(parent):
    raise SystemExit("panel: unsafe runtime home")
for directory in (app, contents, macos):
    safe_dir(directory)
with open(source, "rb") as handle:
    source_bytes = handle.read()
plist_bytes = b'''<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
<key>CFBundleExecutable</key><string>mc-panel</string>
<key>CFBundleIdentifier</key><string>com.gillettes.mission-control.panel</string>
<key>CFBundleName</key><string>Mission Control Panel</string>
<key>CFBundlePackageType</key><string>APPL</string>
<key>CFBundleVersion</key><string>1</string>
<key>LSMinimumSystemVersion</key><string>13.0</string>
<key>LSUIElement</key><true/>
<key>NSHighResolutionCapable</key><true/>
<key>NSSupportsAutomaticTermination</key><false/>
<key>NSSupportsSuddenTermination</key><false/>
</dict></plist>
'''
atomic_bytes(binary, source_bytes, 0o700)
atomic_bytes(plist, plist_bytes, 0o600)
with open(binary, "rb") as handle:
    deployed = handle.read()
if hashlib.sha256(deployed).digest() != hashlib.sha256(source_bytes).digest():
    raise SystemExit("panel: deployed binary hash mismatch")
PYEOF
  then
    echo "panel: app staging failed closed" >&2
    return 1
  fi
  pkill -f '[m]c-panel' 2>/dev/null || true
  pkill -f 'Mission Control Panel' 2>/dev/null || true
  if [ "${DASHBOARD_NO_OPEN:-}" != "1" ]; then
    # Prefer KeepAlive LaunchAgent so login/reboot restores MC without a manual panel run.
    # Skipped under DASHBOARD_NO_OPEN / DASHBOARD_INSTALL_NO_LAUNCHD / tmp MISSION_CONTROL_HOME.
    if _mc_panel_autoload_allowed && _ensure_mc_panel_autoload; then
      echo "panel: menu-bar Mission Control started (login KeepAlive; look for MC)"
    else
      # open(1) registers a real app identity with Launch Services / Control Center.
      if ! open -n -a "$app_dir" --args "$MISSION_CONTROL_HOME/panel.html" >/dev/null 2>&1; then
        nohup "$app_bin" "$MISSION_CONTROL_HOME/panel.html" >/dev/null 2>&1 &
      fi
      echo "panel: menu-bar Mission Control started (look for MC)"
    fi
  else
    echo "panel: binary present; DASHBOARD_NO_OPEN=1 skipped launch"
  fi
}

do_open() {
  if [ "${1:-}" = "--serve" ]; then
    do_serve
    return $?
  fi
  engine collect --due
  if [ "${DASHBOARD_NO_OPEN:-}" != "1" ]; then
    open "$MISSION_CONTROL_HOME/index.html" 2>/dev/null || true
  fi
  engine freshness
}

do_install() {
  if [ "$#" -ne 0 ]; then
    echo "install: unexpected argument: $1 (install accepts no flags; use 'dashboard status' to verify)" >&2
    return 2
  fi
  if ! mkdir -p "$MISSION_CONTROL_HOME" || ! chmod 700 "$MISSION_CONTROL_HOME"; then
    echo "install: could not create or secure runtime home" >&2
    return 1
  fi
  local install_lock="$MISSION_CONTROL_HOME/.install.lock"
  if ! mkdir "$install_lock" 2>/dev/null; then
    echo "install: another install is active (or a prior crash left $install_lock); verify no installer is running before removing it" >&2
    return 75
  fi
  DASHBOARD_INSTALL_LOCK_HELD="$install_lock"
  _release_install_lock() {
    if [ -n "${DASHBOARD_INSTALL_LOCK_HELD:-}" ]; then
      rm -f "$DASHBOARD_INSTALL_LOCK_HELD/owner" 2>/dev/null || true
      rmdir "$DASHBOARD_INSTALL_LOCK_HELD" 2>/dev/null || true
      DASHBOARD_INSTALL_LOCK_HELD=""
    fi
  }
  if ! printf '%s\n' "$$" > "$install_lock/owner"; then
    _release_install_lock
    return 1
  fi
  trap '_release_install_lock' EXIT
  trap '_release_install_lock; exit 130' HUP INT TERM
  if ! mkdir -p "$MISSION_CONTROL_HOME/data" "$MISSION_CONTROL_HOME/bin" "$MISSION_CONTROL_HOME/logs"; then
    echo "install: could not create runtime directories" >&2
    return 1
  fi
  if ! chmod 700 "$MISSION_CONTROL_HOME" "$MISSION_CONTROL_HOME/data" \
      "$MISSION_CONTROL_HOME/bin" "$MISSION_CONTROL_HOME/logs"; then
    echo "install: could not secure runtime directories" >&2
    return 1
  fi
  local install_failed=0
  local stamp_path="$MISSION_CONTROL_HOME/bin/install-stamp.json"
  # Keep this Bash 3.2 install loop aligned with the canonical verifier manifest
  # in mission_control_common.py; dashboard.test.sh asserts the exact set.
  local required_runtimes="dashboard morning-brief morning-brief-deadman decision-alert mission_control_common.py queue_admission.py compose-decision-prompt.py mc-panel.swift"
  local required_assets="index.html vendor/cytoscape.min.js panel.html launchd/com.gillettes.mc-panel.plist.template"
  # Safe file install: refuse a symlink or non-regular-file destination (never
  # write THROUGH a link, which would escape the target dir), write via a temp
  # in the same dir then atomic mv (so a blocked/failed write cannot leave a
  # half-file or silently no-op), and return nonzero on any failure so the caller
  # can fail the whole install loudly instead of stamping a copy that never landed.
  _mc_write() { # $1=dest ; new content on stdin
    local d="$1" tmp
    if [ -L "$d" ]; then
      echo "install: refusing to write through symlink destination: $d" >&2
      cat >/dev/null; return 1
    fi
    if [ -e "$d" ] && [ ! -f "$d" ]; then
      echo "install: destination is not a regular file (dir/special): $d" >&2
      cat >/dev/null; return 1
    fi
    tmp="$(dirname "$d")/.mcw.$$.$(basename "$d")"
    if ! cat > "$tmp" 2>/dev/null; then
      echo "install: write failed (unwritable destination): $d" >&2; rm -f "$tmp"; return 1
    fi
    if ! mv -f "$tmp" "$d" 2>/dev/null; then
      echo "install: could not place file at destination: $d" >&2; rm -f "$tmp"; return 1
    fi
    return 0
  }
  # Production installs require a committed HEAD. A worktree source is available
  # only behind an explicit fixture/development opt-in and never verifies green.
  local head_sha="" provenance="head"
  if head_sha="$(git -C "$REPO_ROOT" rev-parse --verify 'HEAD^{commit}' 2>/dev/null)"; then
    provenance="head"
  elif [ "${DASHBOARD_INSTALL_ALLOW_WORKTREE:-0}" = "1" ]; then
    head_sha="worktree"
    provenance="worktree"
  else
    echo "install: committed git HEAD required (set DASHBOARD_INSTALL_ALLOW_WORKTREE=1 only for fixtures)" >&2
    return 1
  fi
  # Once the source is proven usable, the upgrade remains unverified until every
  # selected surface lands. Remove the prior regular stamp before the first write
  # so a partial code/plist failure cannot leave an old green attestation behind.
  if [ -L "$stamp_path" ] || { [ -e "$stamp_path" ] && [ ! -f "$stamp_path" ]; }; then
    echo "install: stamp destination is not a regular file: $stamp_path" >&2
    return 1
  fi
  if [ -f "$stamp_path" ] && ! rm -f "$stamp_path"; then
    echo "install: could not invalidate prior stamp: $stamp_path" >&2
    return 1
  fi
  # Copy the dashboard to a STABLE runtime path the plist execs, baking the
  # resolved REPO_ROOT into the copy so `collect --due` finds repo-sibling feeders
  # even though the copy's own SCRIPT_DIR is ~/.mission-control/bin (not the repo).
  if [ "$provenance" = "head" ] && ! git -C "$REPO_ROOT" cat-file -e "$head_sha:scripts/dashboard" 2>/dev/null; then
    # provenance=head promises every shipped file comes from the committed SHA;
    # a missing source must fail loud, never silently fall back to the worktree
    # and then get stamped "head" (that would be a provenance lie).
    echo "install: scripts/dashboard not committed at HEAD (provenance=head) — refusing worktree fallback" >&2
    install_failed=1
  else
    { if [ "$provenance" = "head" ]; then
        git -C "$REPO_ROOT" show "$head_sha:scripts/dashboard"
      else
        cat "$SCRIPT_DIR/dashboard"
      fi; } | sed -e "s|^REPO_ROOT_DEFAULT=.*|REPO_ROOT_DEFAULT=\"$REPO_ROOT\"|" \
      | _mc_write "$MISSION_CONTROL_HOME/bin/dashboard" || install_failed=1
    if [ "$install_failed" = 0 ]; then
      if chmod 700 "$MISSION_CONTROL_HOME/bin/dashboard"; then
        echo "installed runtime -> $MISSION_CONTROL_HOME/bin/dashboard (REPO_ROOT=$REPO_ROOT, $provenance $head_sha)"
      else
        echo "install: could not set executable mode: $MISSION_CONTROL_HOME/bin/dashboard" >&2
        install_failed=1
      fi
    fi
  fi
  local runtime dest
  for runtime in chat-graph morning-brief morning-brief-deadman decision-alert mission_control_common.py queue_admission.py compose-decision-prompt.py mc-panel.swift; do
    dest="$MISSION_CONTROL_HOME/bin/$runtime"
    if [ "$provenance" = "head" ]; then
      if git -C "$REPO_ROOT" cat-file -e "$head_sha:scripts/$runtime" 2>/dev/null; then
        git -C "$REPO_ROOT" show "$head_sha:scripts/$runtime" | _mc_write "$dest" || { install_failed=1; continue; }
      else
        echo "install: required runtime missing at HEAD: scripts/$runtime" >&2
        install_failed=1; continue
      fi
    elif [ -f "$REPO_ROOT/scripts/$runtime" ]; then
      _mc_write "$dest" < "$REPO_ROOT/scripts/$runtime" || { install_failed=1; continue; }
    else
      echo "install: required runtime missing from worktree: scripts/$runtime" >&2
      install_failed=1; continue
    fi
    case "$runtime" in
      mission_control_common.py|queue_admission.py|mc-panel.swift) chmod 600 "$dest" || { echo "install: could not secure runtime: $dest" >&2; install_failed=1; continue; } ;;
      *) chmod 700 "$dest" || { echo "install: could not set executable mode: $dest" >&2; install_failed=1; continue; } ;;
    esac
    echo "installed runtime -> $dest"
  done
  # Deployment assets (index.html render shell + vendored graph engine) install
  # from the SAME committed HEAD as the runtimes when provenance=head, so the
  # stamped head_sha is truthful for the exact code/render surface — never a dirty
  # working tree stamped "head". Worktree fallback mirrors the runtime path.
  if [ "$provenance" = "head" ]; then
    if git -C "$REPO_ROOT" cat-file -e "$head_sha:dashboard/index.html" 2>/dev/null; then
      git -C "$REPO_ROOT" show "$head_sha:dashboard/index.html" | _mc_write "$MISSION_CONTROL_HOME/index.html" || install_failed=1
      chmod 600 "$MISSION_CONTROL_HOME/index.html" || install_failed=1
      # Rebuild vendor from HEAD only: rm -rf drops any asset deleted upstream so a
      # stale vendor/index file can't linger and get stamped under the new HEAD.
      rm -rf "$MISSION_CONTROL_HOME/vendor" "$MISSION_CONTROL_HOME/launchd" || install_failed=1
      mkdir -p "$MISSION_CONTROL_HOME/vendor" "$MISSION_CONTROL_HOME/launchd" || install_failed=1
      chmod 700 "$MISSION_CONTROL_HOME/vendor" "$MISSION_CONTROL_HOME/launchd" || install_failed=1
      for asset in $required_assets; do
        local source_asset
        [ "$asset" = "index.html" ] && continue
        case "$asset" in launchd/*) source_asset="$asset" ;; *) source_asset="dashboard/$asset" ;; esac
        if git -C "$REPO_ROOT" cat-file -e "$head_sha:$source_asset" 2>/dev/null; then
          git -C "$REPO_ROOT" show "$head_sha:$source_asset" | _mc_write "$MISSION_CONTROL_HOME/$asset" || install_failed=1
          chmod 600 "$MISSION_CONTROL_HOME/$asset" || install_failed=1
        else
          echo "install: required asset missing at HEAD: $source_asset" >&2
          install_failed=1
        fi
      done
      echo "installed shell -> $MISSION_CONTROL_HOME/index.html (head $head_sha)"
    else
      # index.html is a shipped asset; missing at HEAD under provenance=head is a
      # broken install. Fail loud and DROP the stale installed shell + vendor so a
      # deleted-upstream asset can't remain installed and get stamped as "head".
      echo "install: dashboard/index.html not committed at HEAD (provenance=head) — refusing worktree fallback" >&2
      rm -f "$MISSION_CONTROL_HOME/index.html"
      rm -rf "$MISSION_CONTROL_HOME/vendor"
      install_failed=1
    fi
  elif [ -f "$REPO_ROOT/dashboard/index.html" ]; then
    _mc_write "$MISSION_CONTROL_HOME/index.html" < "$REPO_ROOT/dashboard/index.html" || install_failed=1
    chmod 600 "$MISSION_CONTROL_HOME/index.html" || install_failed=1
    rm -rf "$MISSION_CONTROL_HOME/vendor" "$MISSION_CONTROL_HOME/launchd" || install_failed=1
    mkdir -p "$MISSION_CONTROL_HOME/vendor" "$MISSION_CONTROL_HOME/launchd" || install_failed=1
    chmod 700 "$MISSION_CONTROL_HOME/vendor" "$MISSION_CONTROL_HOME/launchd" || install_failed=1
    for asset in $required_assets; do
      local source_asset
      [ "$asset" = "index.html" ] && continue
      case "$asset" in launchd/*) source_asset="$asset" ;; *) source_asset="dashboard/$asset" ;; esac
      if [ -f "$REPO_ROOT/$source_asset" ]; then
        _mc_write "$MISSION_CONTROL_HOME/$asset" < "$REPO_ROOT/$source_asset" || install_failed=1
        chmod 600 "$MISSION_CONTROL_HOME/$asset" || install_failed=1
      else
        echo "install: required asset missing from worktree: $source_asset" >&2
        install_failed=1
      fi
    done
    echo "installed shell -> $MISSION_CONTROL_HOME/index.html (worktree)"
  else
    echo "install: required asset missing from worktree: dashboard/index.html" >&2
    install_failed=1
  fi
  # A file that could not be installed safely must NOT be papered over by a stamp
  # that claims a clean committed surface. Fail loud with a nonzero rc and no new
  # stamp, so status/deadman keep flagging the surface as unverified.
  if [ "$install_failed" != 0 ]; then
    echo "install: one or more files could not be installed safely — refusing to stamp (rc=1)" >&2
    return 1
  fi
  _write_install_stamp() {
    # The stamp attests the canonical installed runtime and render/panel sets.
    # LaunchAgents have a separate checked deployment/reload gate below.
    MC_BIN="$MISSION_CONTROL_HOME/bin" MC_HOME="$MISSION_CONTROL_HOME" \
    MC_HEAD_SHA="$head_sha" MC_PROVENANCE="$provenance" \
      python3 - "$MISSION_CONTROL_HOME/bin" <<'PYEOF'
import os, sys, time
sys.path.insert(0, sys.argv[1])
from mission_control_common import (REQUIRED_INSTALL_ASSETS,
    REQUIRED_INSTALL_RUNTIMES, write_install_stamp)
names = list(REQUIRED_INSTALL_RUNTIMES)
home = os.environ["MC_HOME"]
assets = {name: os.path.join(home, name) for name in REQUIRED_INSTALL_ASSETS}
write_install_stamp(os.environ["MC_BIN"], os.environ.get("MC_HEAD_SHA") or None,
                    os.environ.get("MC_PROVENANCE") or "unknown", names,
                    int(time.time()), assets=assets)
print("stamped install -> %s/install-stamp.json (%s, %d assets)" % (
    os.environ["MC_BIN"], os.environ.get("MC_PROVENANCE"), len(assets)))
PYEOF
  }
  if [ "${DASHBOARD_INSTALL_NO_LAUNCHD:-0}" = "1" ]; then
    if ! _write_install_stamp; then
      echo "install: stamp write failed — refusing success (rc=1)" >&2
      return 1
    fi
    echo "skip: launchd installation disabled by DASHBOARD_INSTALL_NO_LAUNCHD"
    return 0
  fi
  command -v launchctl >/dev/null 2>&1 || {
    echo "install: launchctl is required unless DASHBOARD_INSTALL_NO_LAUNCHD=1" >&2
    return 1
  }
  command -v plutil >/dev/null 2>&1 || {
    echo "install: plutil is required for LaunchAgent validation" >&2
    return 1
  }
  mkdir -p "$HOME/Library/LaunchAgents" || return 1
  local selected_plists="com.gillettes.mission-control.plist"
  if [ "${DASHBOARD_INSTALL_ACTIVATE_GATED:-0}" = "1" ]; then
    selected_plists="$selected_plists com.gillettes.outcome-extractor.plist com.gillettes.morning-brief.plist com.gillettes.morning-brief-deadman.plist"
  else
    echo "skip: activation-gated job requires DASHBOARD_INSTALL_ACTIVATE_GATED=1: com.gillettes.outcome-extractor"
    echo "skip: activation-gated job requires DASHBOARD_INSTALL_ACTIVATE_GATED=1: com.gillettes.morning-brief"
    echo "skip: activation-gated job requires DASHBOARD_INSTALL_ACTIVATE_GATED=1: com.gillettes.morning-brief-deadman"
  fi
  local plist dest label source_tmp rendered changed loaded was_loaded domain
  domain="gui/$(id -u)"
  for plist in $selected_plists; do
    label="${plist%.plist}"
    dest="$HOME/Library/LaunchAgents/$plist"
    if [ -L "$dest" ] || { [ -e "$dest" ] && [ ! -f "$dest" ]; }; then
      echo "install: refusing unsafe LaunchAgent destination: $dest" >&2
      return 1
    fi
    source_tmp="$(mktemp "${TMPDIR:-/tmp}/mc-plist-source.XXXXXX")" || return 1
    rendered="$(mktemp "${TMPDIR:-/tmp}/mc-plist-rendered.XXXXXX")" || {
      rm -f "$source_tmp"; return 1;
    }
    if [ "$provenance" = "head" ]; then
      if ! git -C "$REPO_ROOT" show "$head_sha:launchd/$plist.template" > "$source_tmp"; then
        echo "install: required plist missing at HEAD: launchd/$plist.template" >&2
        rm -f "$source_tmp" "$rendered"; return 1
      fi
    elif [ -f "$REPO_ROOT/launchd/$plist.template" ]; then
      cp "$REPO_ROOT/launchd/$plist.template" "$source_tmp" || {
        rm -f "$source_tmp" "$rendered"; return 1;
      }
    else
      echo "install: required plist missing from worktree: launchd/$plist.template" >&2
      rm -f "$source_tmp" "$rendered"; return 1
    fi
    if ! python3 - "$source_tmp" "$rendered" "$MISSION_CONTROL_HOME" "$HOME" "$REPO_ROOT" <<'PYEOF'
import sys
source, dest, mc_home, home, repo = sys.argv[1:]
text = open(source).read()
text = text.replace("__MCHOME__", mc_home).replace("__HOME__", home).replace("__REPO__", repo)
with open(dest, "w") as handle:
    handle.write(text)
PYEOF
    then
      echo "install: plist render failed: $plist" >&2
      rm -f "$source_tmp" "$rendered"; return 1
    fi
    if ! plutil -lint "$rendered" >/dev/null 2>&1; then
      echo "install: rendered plist failed validation: $plist" >&2
      rm -f "$source_tmp" "$rendered"; return 1
    fi
    changed=1
    [ -f "$dest" ] && cmp -s "$rendered" "$dest" && changed=0
    loaded=0
    was_loaded=0
    if launchctl print "$domain/$label" >/dev/null 2>&1; then
      loaded=1; was_loaded=1
    fi
    if [ "$changed" = 1 ] && [ "$loaded" = 1 ]; then
      if ! launchctl bootout "$domain/$label" >/dev/null 2>&1; then
        echo "install: could not unload changed LaunchAgent: $label" >&2
        rm -f "$source_tmp" "$rendered"; return 1
      fi
      loaded=0
    fi
    if [ "$changed" = 1 ]; then
      if ! _mc_write "$dest" < "$rendered"; then
        [ "$was_loaded" = 1 ] && launchctl bootstrap "$domain" "$dest" >/dev/null 2>&1 || true
        rm -f "$source_tmp" "$rendered"; return 1
      fi
      echo "installed plist -> $dest"
    fi
    # Content equality does not prove deployment integrity: repair/reject mode
    # drift on every selected plist, including unchanged bytes and retries after
    # an earlier chmod failure.
    if ! chmod 600 "$dest"; then
      echo "install: could not secure LaunchAgent: $dest" >&2
      rm -f "$source_tmp" "$rendered"; return 1
    fi
    if [ "$loaded" = 0 ]; then
      if ! launchctl bootstrap "$domain" "$dest" >/dev/null 2>&1; then
        echo "install: bootstrap failed: $label" >&2
        rm -f "$source_tmp" "$rendered"; return 1
      fi
      echo "bootstrapped $label"
    else
      echo "already current and bootstrapped: $label"
    fi
    rm -f "$source_tmp" "$rendered"
  done
  if ! _write_install_stamp; then
    echo "install: stamp write failed — refusing success (rc=1)" >&2
    return 1
  fi
}

do_demo() {
  local dir
  dir="$(mktemp -d "${TMPDIR:-/tmp}/mc-demo.XXXXXX")"
  engine demo "$dir"
  if [ "${DASHBOARD_NO_OPEN:-}" != "1" ]; then
    open "$dir/index.html" 2>/dev/null || open "$dir" 2>/dev/null || true
  fi
}

cmd="${1:-}"
[ $# -gt 0 ] && shift
case "$cmd" in
  collect)  engine collect "$@" ;;
  refresh)  engine collect --force "$@" ;;
  status)   engine status "$@"; exit $? ;;
  brief)    exec "$SCRIPT_DIR/morning-brief" "$@" ;;
  extract-outcomes) exec "$REPO_ROOT/scripts/chat-graph" extract-outcomes "$@" ;;
  attention)
    engine attention "$@"
    ;;
  decide)
    case "${1:-}" in
      dismiss)
        [ $# -ge 2 ] || { usage; exit 2; }
        did="$2"; shift 2
        dismiss_source=""
        while [ $# -gt 0 ]; do
          case "$1" in
            --source)
              [ $# -ge 2 ] || { echo "decide dismiss: --source needs a value" >&2; exit 2; }
              dismiss_source="$2"; shift 2 ;;
            *) echo "decide dismiss: unknown argument: $1" >&2; usage; exit 2 ;;
          esac
        done
        dismiss_argv=(dismiss "$did" --json)
        [ -n "$dismiss_source" ] && dismiss_argv=(dismiss "$did" --source "$dismiss_source" --json)
        decision_result="$("$SCRIPT_DIR/decision-alert" "${dismiss_argv[@]}")" || exit $?
        engine collect --force --strict decisions >/dev/null || exit $?
        printf '%s\n' "$decision_result"
        ;;
      answer)
        [ $# -ge 3 ] || { usage; exit 2; }
        did="$2"; choice="$3"; shift 3
        answer_source=""; answer_resume_chat=""; answer_resume_provider=""
        while [ $# -gt 0 ]; do
          case "$1" in
            --source)
              [ $# -ge 2 ] || { echo "decide answer: --source needs a value" >&2; exit 2; }
              answer_source="$2"; shift 2 ;;
            --resume-chat-id)
              [ $# -ge 2 ] || { echo "decide answer: --resume-chat-id needs a value" >&2; exit 2; }
              answer_resume_chat="$2"; shift 2 ;;
            --resume-provider)
              [ $# -ge 2 ] || { echo "decide answer: --resume-provider needs a value" >&2; exit 2; }
              answer_resume_provider="$2"; shift 2 ;;
            *) echo "decide answer: unknown argument: $1" >&2; usage; exit 2 ;;
          esac
        done
        case "$choice" in *[!0-9]*|"") echo "decide answer: choice must be a positive integer" >&2; exit 2 ;; esac
        [ "$choice" -ge 1 ] || { echo "decide answer: choice must be >= 1" >&2; exit 2; }
        printf '%s\n' "$did" | grep -Eq '^decision:[0-9a-f]{24}$' || {
          echo "decide answer: invalid decision id" >&2; exit 2;
        }
        compose_bin="$REPO_ROOT/scripts/compose-decision-prompt.py"
        [ -f "$compose_bin" ] || compose_bin="$SCRIPT_DIR/compose-decision-prompt.py"
        compose_argv=(--answer-transaction --home "$MISSION_CONTROL_HOME" \
          --decision-alert "$SCRIPT_DIR/decision-alert" \
          --decision-id "$did" --choice "$choice")
        [ -n "$answer_source" ] && compose_argv+=(--source "$answer_source")
        [ -n "$answer_resume_chat" ] && compose_argv+=(--resume-chat-id "$answer_resume_chat")
        [ -n "$answer_resume_provider" ] && compose_argv+=(--resume-provider "$answer_resume_provider")
        python3 "$compose_bin" "${compose_argv[@]}" || exit $?
        # Refresh feed for UI; do not fail the answer if collectors are unavailable.
        "$SCRIPT_DIR/decision-alert" sync-snapshot --json >/dev/null 2>&1 || \
          engine collect --force decisions >/dev/null 2>&1 || true
        ;;
      alert-backfill)
        shift
        max_n=""
        while [ $# -gt 0 ]; do
          case "$1" in
            --max)
              [ $# -ge 2 ] || { echo "decide alert-backfill: --max needs a value" >&2; exit 2; }
              max_n="$2"; shift 2 ;;
            --max=*)
              max_n="${1#--max=}"; shift ;;
            --sender|--chat-id|--timeout)
              echo "decide alert-backfill: destination is fixed to the Control route; configure supported sender/timeout defaults in decision-alert" >&2
              exit 2 ;;
            -h|--help)
              echo "usage: dashboard decide alert-backfill [--max N]" >&2
              exit 0 ;;
            *)
              echo "decide alert-backfill: unknown argument: $1" >&2
              usage; exit 2 ;;
          esac
        done
        if [ -n "$max_n" ]; then
          case "$max_n" in *[!0-9]*|"") echo "decide alert-backfill: --max must be a positive integer" >&2; exit 2 ;; esac
          [ "$max_n" -ge 1 ] || { echo "decide alert-backfill: --max must be >= 1" >&2; exit 2; }
          decision_result="$("$SCRIPT_DIR/decision-alert" alert-backfill --max "$max_n" --json)" || exit $?
        else
          decision_result="$("$SCRIPT_DIR/decision-alert" alert-backfill --json)" || exit $?
        fi
        printf '%s\n' "$decision_result"
        ;;
      *) usage; exit 2 ;;
    esac
    ;;
  panel)
    do_panel "$@"
    ;;
  open)     do_open "$@" ;;
  install)  do_install "$@" ;;
  demo)     do_demo "$@" ;;
  ""|-h|--help|help) usage ;;
  *) usage; exit 2 ;;
esac
