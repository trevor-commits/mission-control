#!/usr/bin/env python3
"""Compose a deterministic, NEEDS-YOU-first Mission Control morning brief.

The composer reads one stable in-memory snapshot of local dashboard feeds. It
does not call a model, execute suggested actions, or advance delivery cursors.
Normal compose atomically writes latest.md + latest.json; --print is preview.
"""

import hashlib
import json
import os
import re
import subprocess
import sys
import time

from mission_control_common import (ACTION, IDENTIFIER, NARRATIVE, NOTIFICATION,
                                    DESKTOP_GLANCE_CTA, EgressCounters, feed_health,
                                    next_local_midnight, sanitize_chunks,
                                    sanitize_text, safe_text, same_local_day)

SCHEMA = 1
INPUTS = {
    "automation": {"cadence_s": 300, "required": True},
    "git": {"cadence_s": 900, "required": True},
    "chats": {"cadence_s": 1800, "required": True},
    "decisions": {"cadence_s": 300, "required": False},
    "usage": {"cadence_s": 1800, "allowed_cadences_s": (1800, 604800),
              "required": False},
}
SECTION_ORDER = (
    "NEEDS YOU", "What happened", "Possible follow-ups — Inferred", "Open work changes",
    "Machinery health", "Usage headroom",
)
_EGRESS_COUNTERS = EgressCounters()


def _reset_egress_counters():
    global _EGRESS_COUNTERS
    _EGRESS_COUNTERS = EgressCounters()


def _now():
    raw = os.environ.get("MORNING_BRIEF_NOW_EPOCH")
    try:
        return int(raw) if raw else int(time.time())
    except ValueError:
        return int(time.time())


def _state_home():
    return os.path.expanduser(os.environ.get(
        "MISSION_CONTROL_HOME", os.path.join("~", ".mission-control")))


def _brief_home():
    return os.path.join(_state_home(), "morning-brief")


def _bounded_int(name, default, minimum=1, maximum=100):
    try:
        value = int(os.environ.get(name, default))
    except ValueError:
        value = default
    return min(maximum, max(minimum, value))


def _load_json(path):
    try:
        with open(path) as handle:
            value = json.load(handle)
        return value if isinstance(value, dict) else None
    except (OSError, ValueError):
        return None


def _snapshot_inputs():
    base = os.path.join(_state_home(), "data")
    return {name: _load_json(os.path.join(base, name + ".json")) for name in INPUTS}


def _input_health(name, feed, now):
    declared = INPUTS[name]
    cadence = declared["cadence_s"]
    wire_cadence = feed.get("cadence_s") if isinstance(feed, dict) else None
    if (type(wire_cadence) is int or
            (type(wire_cadence) is float and wire_cadence.is_integer())):
        wire_cadence = int(wire_cadence)
        if wire_cadence in declared.get("allowed_cadences_s", (cadence,)):
            cadence = wire_cadence
    # A brief is delivered as fact, so its inputs must be current at 1x cadence
    # with no lenient aging tier — and a feed that is envelope-fresh but whose
    # full transcript ingest is stale (nested_stale) is not trustworthy either.
    h = feed_health(feed, cadence, now, stale_multiple=1, aging=False)
    data = feed.get("data") if isinstance(feed, dict) else None
    empty = not isinstance(data, dict) or not data
    if h["state"] == "missing":
        state = "missing"
    elif h["state"] == "error":
        state = "error"
    elif h["state"] == "skew":
        # A future generated_epoch is a clock-skew / invalid envelope, never a
        # trustworthy "fresh" input — surface it as its own visible warning.
        state = "skew"
    elif h["state"] == "fresh" and not h["nested_stale"] and not empty:
        state = "fresh"
    elif empty:
        state = "empty"
    else:
        state = "stale"
    return {
        "state": state,
        "required": bool(declared["required"]),
        "cadence_s": cadence,
        "age_s": h["age_s"],
        "generated_epoch": h["generated_epoch"],
        "ok": bool(isinstance(feed, dict) and feed.get("ok") is True),
    }


def _payload(feed):
    data = feed.get("data") if isinstance(feed, dict) else None
    return data if isinstance(data, dict) else {}


def _headline(text, limit):
    """Collapse a raw line to a scannable one-phone-screen headline.

    Table pipes and runs of whitespace are flattened; over-length text is cut
    at a word boundary and marked so the reader knows the full body (e.g. a
    DECISION NEEDED options table) still lives in the dashboard.
    """
    flat = re.sub(r"\s+", " ", str(text).replace("|", " ")).strip()
    if len(flat) <= limit:
        return flat
    clipped = flat[:limit].rstrip()
    if " " in clipped:
        clipped = clipped[:clipped.rfind(" ")].rstrip()
    return clipped + " … (options in dashboard)"


def _sanitize_line(text, trust="Confirmed", source="", action_cmd=None, clip=None):
    # Sanitize the RAW line against the shared egress policy BEFORE any clip, so
    # a secret/PII value that sits past a headline boundary still drops the whole
    # row instead of surviving inside a shortened "safe" headline.
    result = sanitize_text(text, NARRATIVE, counters=_EGRESS_COUNTERS)
    if result.dropped or not result.value.strip():
        return None
    # ponytail: drop upstream extraction noise — a raw worker handshake line is
    # never a real session outcome; the fix belongs in chat-graph, this is a guard.
    if "Spawned-by:" in result.value:
        return None
    value = result.value.strip()
    if clip is not None:
        value = _headline(value, clip)
    line = {
        "text": value,
        "trust": trust,
        "source": safe_text(source, IDENTIFIER, counters=_EGRESS_COUNTERS) if source else "",
    }
    if action_cmd:
        action = sanitize_text(action_cmd, ACTION, counters=_EGRESS_COUNTERS)
        if not action.dropped and action.value.strip():
            line["action_cmd"] = action.value.strip()
    return line


def _section(title, lines, collapsed=0):
    # Drop identical rendered lines within a section (e.g. repeated late-closeout
    # notices) — an exact duplicate carries no extra information. Provenance is
    # part of the identity: rows with the same text but different trust, source,
    # or nesting depth are distinct and must never silently collapse together.
    unique, seen = [], set()
    for line in lines:
        if not line:
            continue
        key = (line.get("text"), line.get("action_cmd"),
               line.get("trust"), line.get("source"), line.get("depth"))
        if key in seen:
            continue
        seen.add(key)
        unique.append(line)
    return {"title": title, "lines": unique, "collapsed_count": max(0, int(collapsed))}


def _read_delivery_cursor():
    value = _load_json(os.path.join(_brief_home(), "delivery-cursor.json")) or {}
    cursor = value.get("loose_end_changes") or [0, ""]
    try:
        stable = sanitize_text(str(cursor[1]), IDENTIFIER, counters=_EGRESS_COUNTERS)
        if stable.dropped:
            return 0, ""
        return int(cursor[0]), stable.value
    except (IndexError, TypeError, ValueError):
        return 0, ""


def _needs_you(snapshot, health, cap):
    # Every NEEDS YOU line is a scannable headline so the whole block fits one
    # phone screen without scroll; the action command and full body are kept.
    chars = _bounded_int("MORNING_BRIEF_NEEDS_YOU_CHARS", 160, minimum=40, maximum=400)
    lines = []
    decisions = _payload(snapshot.get("decisions"))
    for item in decisions.get("pinned") or []:
        if not isinstance(item, dict) or item.get("trust") != "structured":
            continue
        decision_id = safe_text(item.get("id") or "", IDENTIFIER,
                                counters=_EGRESS_COUNTERS)
        lines.append(_sanitize_line(
            item.get("text") or "A confirmed decision requires review.", clip=chars,
            source=item.get("provenance") or "decision queue",
            action_cmd=("dashboard decide dismiss %s" % decision_id)
            if decision_id else None))
    stale = [name for name in INPUTS if health[name]["required"] and
             health[name]["state"] != "fresh"]
    if stale:
        lines.append(_sanitize_line(
            "Required inputs are not current: %s. Treat this brief as incomplete."
            % ", ".join(sorted(stale)), source="input freshness"))

    automation = _payload(snapshot.get("automation"))
    for job in automation.get("jobs") or []:
        if not isinstance(job, dict) or job.get("state") != "red":
            continue
        name = job.get("name") or job.get("label") or "Background job"
        streak = job.get("failure_streak")
        suffix = " (failure streak %s)" % streak if isinstance(streak, int) and streak else ""
        lines.append(_sanitize_line(
            "%s is failing%s." % (name, suffix), clip=chars,
            source="automation-status", action_cmd=job.get("run_cmd")))

    chats = _payload(snapshot.get("chats"))
    for item in chats.get("loose_ends") or []:
        if not isinstance(item, dict) or item.get("severity") != "red":
            continue
        lines.append(_sanitize_line(
            "%s: %s" % (item.get("title") or "Open work",
                        item.get("text") or "needs review"), clip=chars,
            source="chat-graph", action_cmd=item.get("resolve_cmd")))

    # Drop rows the egress policy rejected (None) before the empty check so a
    # feed of only-sensitive candidates still shows the reassuring placeholder
    # and the collapsed count reflects renderable rows, not silent holes.
    lines = [line for line in lines if line]
    if not lines:
        lines.append(_sanitize_line("No confirmed operator decision is required from current inputs.",
                                    source="deterministic feeds"))
    collapsed = max(0, len(lines) - cap)
    return lines[:cap], collapsed, stale


def _possible_followups(snapshot, cap):
    """Render model-only suggestions outside the actionable NEEDS YOU block."""
    lines = []
    for item in _payload(snapshot.get("decisions")).get("inferred") or []:
        if (not isinstance(item, dict) or item.get("trust") != "inferred" or
                item.get("state") != "open"):
            continue
        lines.append(_sanitize_line(
            item.get("text") or "A possible follow-up needs review.",
            trust="Inferred", source=item.get("provenance") or "decision queue"))
    if not lines:
        lines.append(_sanitize_line(
            "No model-only follow-up is currently suggested.",
            trust="Inferred", source="decision queue"))
    return lines[:cap], max(0, len(lines) - cap)


def _recent_git(snapshot, top_n):
    commits = {}
    for repo in _payload(snapshot.get("git")).get("repos") or []:
        if not isinstance(repo, dict):
            continue
        repo_name = safe_text(repo.get("repo") or "unknown repo", IDENTIFIER,
                              counters=_EGRESS_COUNTERS)
        for commit in repo.get("recent_commits") or []:
            if not isinstance(commit, dict) or not commit.get("sha"):
                continue
            sha = safe_text(str(commit["sha"]), IDENTIFIER,
                            counters=_EGRESS_COUNTERS)
            key = (sha, repo_name)
            commits[key] = {
                "sha": sha, "repo": repo_name,
                "subject": commit.get("subject") or "(no subject)",
                "epoch": int(commit.get("epoch") or 0),
            }
    rows = sorted(commits.values(), key=lambda row: (-row["epoch"], row["repo"], row["sha"]))
    lines = [_sanitize_line(
        "%s %s — %s" % (row["repo"], row["sha"][:8], row["subject"]),
        source="scan-unfinished-work") for row in rows[:top_n]]
    if not lines:
        lines.append(_sanitize_line("No recent commits were reported by the Git snapshot.",
                                    source="scan-unfinished-work"))
    return lines, max(0, len(rows) - top_n)


def _recent_outcomes(snapshot, top_n):
    chats = _payload(snapshot.get("chats"))
    node_subjects = {}
    for node in chats.get("nodes") or []:
        if not isinstance(node, dict) or not node.get("id"):
            continue
        title = safe_text(node.get("title") or "Untitled session", NARRATIVE,
                          counters=_EGRESS_COUNTERS)
        repo = safe_text(node.get("repo") or "", IDENTIFIER,
                         counters=_EGRESS_COUNTERS)
        subject = title + (" [%s]" % repo if repo and repo.casefold() not in
                           title.casefold() else "")
        provider = safe_text(node.get("provider") or "unknown", IDENTIFIER,
                             counters=_EGRESS_COUNTERS)
        node_subjects[str(node["id"])] = subject
        node_subjects["%s:%s" % (provider, node["id"])] = subject
    cards = [card for card in (chats.get("outcomes") or []) if isinstance(card, dict)]
    outcome_keys = {
        "%s:%s" % (safe_text(card.get("provider") or "unknown", IDENTIFIER,
                             counters=_EGRESS_COUNTERS), card.get("session_id"))
        for card in cards if card.get("session_id")
    }
    candidates = []
    for card in cards:
        trust = "Confirmed" if card.get("method") == "tier1" else "Inferred"
        provider = safe_text(card.get("provider") or "unknown", IDENTIFIER,
                             counters=_EGRESS_COUNTERS)
        session_id = str(card.get("session_id") or "")
        node_key = "%s:%s" % (provider, session_id)
        anchors = card.get("anchors") if isinstance(card.get("anchors"), dict) else {}
        commits = anchors.get("commits") if isinstance(anchors.get("commits"), list) else []
        anchor = " (commit %s)" % safe_text(str(commits[0])[:12], IDENTIFIER,
                                             counters=_EGRESS_COUNTERS) if commits else ""
        title = safe_text(card.get("session_title") or "Untitled session", NARRATIVE,
                          counters=_EGRESS_COUNTERS)
        repo = safe_text(card.get("repo") or "", IDENTIFIER,
                         counters=_EGRESS_COUNTERS)
        subject = title + (" [%s]" % repo if repo and repo.casefold() not in title.casefold()
                           else "")
        node_subjects[node_key] = subject
        group, depth = node_key, 0
        relationship_subject = subject
        edges = [edge for edge in (chats.get("edges") or [])
                 if isinstance(edge, dict) and isinstance(edge.get("confidence"), (int, float))
                 and not isinstance(edge.get("confidence"), bool)
                 and float(edge["confidence"]) >= 0.7]
        # Prefer the explicit audit relationship over incidental spawn/continue
        # edges so the central "chat auditing another chat" case stays clear.
        for relation in ("audits", "spawned", "continues"):
            matched = False
            for edge in edges:
                source = str(edge.get("src") or "")
                target = str(edge.get("dst") or "")
                if relation == "audits" and edge.get("type") == relation and source == node_key:
                    group = target
                    relationship_subject = "%s — audit of %s" % (
                        subject, node_subjects.get(target) or "another session")
                    depth = 1 if target in outcome_keys else 0
                    matched = True
                elif relation == "spawned" and edge.get("type") == relation and target == node_key:
                    group = source
                    relationship_subject = "%s → %s" % (
                        node_subjects.get(source) or "Parent session", subject)
                    depth = 1 if source in outcome_keys else 0
                    matched = True
                elif relation == "continues" and edge.get("type") == relation and source == node_key:
                    group = target
                    relationship_subject = "%s → continued as %s" % (
                        node_subjects.get(target) or "Earlier session", subject)
                    depth = 1 if target in outcome_keys else 0
                    matched = True
                if matched:
                    break
            if matched:
                break
        residuals = [value for value in (card.get("left_open") or [])
                     if isinstance(value, str) and value.strip()]
        residual = (" " + " ".join(residuals)) if residuals else ""
        for text in card.get("did") or []:
            if isinstance(text, str) and text.strip():
                line = _sanitize_line(
                    relationship_subject + " — " + text + residual + anchor,
                    trust=trust, source="%s outcome" % provider)
                if line is not None:
                    line["depth"] = depth
                candidates.append({
                    "epoch": int(card.get("updated_at") or 0),
                    "stable": str(card.get("card_id") or card.get("session_id") or ""),
                    "group": group,
                    "depth": depth,
                    "line": line,
                })
    for update in chats.get("outcome_updates") or []:
        if not isinstance(update, dict) or update.get("change_type") != "late_update":
            continue
        update_provider = safe_text(update.get("provider") or "unknown", IDENTIFIER,
                                    counters=_EGRESS_COUNTERS)
        update_key = "%s:%s" % (update_provider, update.get("session_id") or "")
        update_subject = node_subjects.get(update_key) or "A session"
        candidates.append({
            "epoch": int(update.get("updated_at") or 0),
            "stable": str(update.get("id") or ""),
            "group": update_key,
            "depth": 0,
            "line": _sanitize_line(
                "%s received a late closeout update." % update_subject,
                trust="Confirmed" if update.get("method") == "tier1" else "Inferred",
                source="%s outcome" % update_provider),
        })
    group_epoch = {}
    for row in candidates:
        group_epoch[row.get("group") or row["stable"]] = max(
            row["epoch"], group_epoch.get(row.get("group") or row["stable"], 0))
    candidates.sort(key=lambda row: (
        -group_epoch.get(row.get("group") or row["stable"], row["epoch"]),
        row.get("group") or row["stable"], row.get("depth", 0),
        -row["epoch"], row["stable"]))
    lines = [row["line"] for row in candidates if row.get("line")]
    return lines[:top_n], max(0, len(lines) - top_n)


def _what_happened(snapshot, top_n):
    outcome_lines, outcome_hidden = _recent_outcomes(snapshot, top_n)
    git_lines, git_hidden = _recent_git(snapshot, top_n)
    if outcome_lines and len(git_lines) == 1 and git_lines[0].get("text", "").startswith(
            "No recent commits"):
        git_lines = []
    combined = outcome_lines + git_lines
    hidden = outcome_hidden + git_hidden + max(0, len(combined) - top_n)
    return combined[:top_n], hidden


# Resolution evidence types the chat-graph records that represent a genuine,
# evidence-backed resolution (explicit human/downstream marker or migrated
# resolved row). fork_dedup is a duplicate consolidation, not a resolution;
# source_absent is inferred from the item no longer appearing — both must not
# read as a plain "Resolved".
_EVIDENCE_BACKED = frozenset((
    "manual", "same_session_explicit", "downstream_explicit", "downstream", "legacy",
))


def _resolution_prefix(row):
    etype = str(row.get("resolution_evidence_type") or "")
    if etype in _EVIDENCE_BACKED:
        return "Resolved"
    if etype == "fork_dedup":
        return "Duplicate consolidated"
    if etype == "source_absent":
        return "Cleared (source absent)"
    return "Resolved (unverified)"


def _open_changes(snapshot, top_n, cursor):
    chats = _payload(snapshot.get("chats"))
    candidates = []
    for change in chats.get("loose_end_changes") or []:
        if not isinstance(change, dict):
            continue
        try:
            stable = sanitize_text(str(change.get("stable_id") or change.get("id") or ""),
                                   IDENTIFIER, counters=_EGRESS_COUNTERS)
            if stable.dropped or not stable.value:
                continue
            mark = (int(change.get("updated_at") or 0), stable.value)
        except (TypeError, ValueError):
            continue
        if mark <= cursor:
            continue
        row = dict(change)
        row["_mark"] = mark
        candidates.append(row)
    candidates.sort(key=lambda row: row["_mark"])
    high_water = max([cursor] + [row["_mark"] for row in candidates])
    labels = {"new": "New", "updated": "Updated", "reopened": "Reopened"}
    lines = []
    seen = set()
    for row in candidates:
        stable = str(row.get("stable_id") or row.get("id") or "")
        seen.add(stable)
        prefix = (_resolution_prefix(row) if row.get("change_type") == "resolved"
                  else labels.get(row.get("change_type"), "Updated"))
        lines.append(_sanitize_line(
            "%s — %s" % (prefix, row.get("text") or row.get("kind") or "open work"),
            source=row.get("source_node") or "chat-graph"))

    for item in chats.get("loose_ends") or []:
        if not isinstance(item, dict) or int(item.get("age_days") or 0) < 7:
            continue
        if str(item.get("id") or "") in seen:
            continue
        lines.append(_sanitize_line(
            "Aging %sd — %s" % (int(item.get("age_days") or 0), item.get("text") or "open work"),
            source=item.get("source_node") or "chat-graph",
            action_cmd=item.get("resolve_cmd")))
    if not lines:
        lines.append(_sanitize_line("No new, resolved, reopened, or aging open-work changes.",
                                    source="chat-graph"))
    collapsed = max(0, len(lines) - top_n)
    return lines[:top_n], collapsed, high_water


def _memory_health(now):
    """Read the memory layer's verdict, coverage, and freshness from what the
    nightly doctor already writes to disk. No new producer, no shell: the whole
    point of this — every memory failure this week was detected by something and
    read by nothing — is defeated if the reader itself is a moving part.

    Fail-open in every branch: any missing/garbled file yields None, and the
    brief renders without the line. Never raises, never blocks the brief."""
    root = os.path.expanduser(os.environ.get(
        "MORNING_BRIEF_MEMORY_HEALTH_DIR",
        os.path.join("~", ".codex", "chat-context-index", "nightly-doctor")))
    health = _load_json(os.path.join(root, "health.json"))
    if not health:
        return None
    details = health.get("details") if isinstance(health.get("details"), dict) else {}

    # Coverage lives in the doctor REPORT, not health.json, and a failed run
    # writes a 0-byte report -- so take the newest report that actually parsed
    # and carries a semantic block. Labelled with its own age below, because a
    # day-old coverage number in a daily brief is honest only if dated.
    coverage = coverage_age = None
    try:
        reports = sorted(
            (p for p in os.listdir(root) if p.endswith("-doctor.json")),
            reverse=True)
    except OSError:
        reports = []
    for name in reports[:10]:
        report = _load_json(os.path.join(root, name))
        semantic = (((report or {}).get("after") or {}).get("metrics") or {}).get("semantic")
        if isinstance(semantic, dict) and semantic.get("coverage_pct") is not None:
            coverage = semantic.get("coverage_pct")
            try:
                coverage_age = max(0, now - int(os.stat(os.path.join(root, name)).st_mtime))
            except OSError:
                coverage_age = None
            break

    return {
        "verdict": str(health.get("status") or "unknown"),
        "receipt_status": str(details.get("receipt_status") or "unknown"),
        "receipt_age_s": details.get("receipt_age_seconds"),
        "running": bool(details.get("running")),
        "coverage_pct": coverage,
        "coverage_age_s": coverage_age,
    }


def _fmt_age(seconds):
    if not isinstance(seconds, (int, float)) or seconds < 0:
        return "unknown age"
    seconds = int(seconds)
    if seconds < 3600:
        return "%sm old" % (seconds // 60)
    if seconds < 86400:
        return "%sh old" % (seconds // 3600)
    return "%sd old" % (seconds // 86400)


def _machinery(snapshot, health, top_n):
    lines = []
    memory = snapshot.get("memory")
    if isinstance(memory, dict):
        cov = memory.get("coverage_pct")
        cov_text = ("embedding coverage unknown" if cov is None
                    else "embedding coverage %.1f%% (%s)"
                    % (cov, _fmt_age(memory.get("coverage_age_s"))))
        # Prepended, so it survives the top_n cap -- the one line this whole
        # change exists to surface must never be the row that gets collapsed.
        lines.append(_sanitize_line(
            "Memory layer: last nightly check %s, %s, newest verdict %s (%s)."
            % (memory.get("receipt_status", "unknown"), cov_text,
               memory.get("verdict", "unknown"),
               _fmt_age(memory.get("receipt_age_s"))),
            source="cci nightly-doctor health"))
    elif memory == "unavailable":
        lines.append(_sanitize_line(
            "Memory layer: health unavailable.", source="cci nightly-doctor health"))
    for name in sorted(INPUTS):
        item = health[name]
        age = "unknown age" if item["age_s"] is None else "%ss old" % item["age_s"]
        lines.append(_sanitize_line("%s input is %s (%s)." % (name, item["state"], age),
                                    source="input freshness"))
    automation = _payload(snapshot.get("automation"))
    counts = automation.get("counts") or {}
    if counts:
        lines.append(_sanitize_line(
            "Automation reports %s red and %s green jobs."
            % (counts.get("red", 0), counts.get("green", 0)), source="automation-status"))
    outcome_health = _payload(snapshot.get("chats")).get("outcome_extraction_health") or {}
    if isinstance(outcome_health, dict) and outcome_health.get("day"):
        lines.append(_sanitize_line(
            "Outcome extraction status %s: %s successes, %s cache hits, %s defers, "
            "%s failures, %s budget skips (%s uncalibrated), %s disabled, %s provider, "
            "%s privacy, %s lock, and %s backoff skips, with %s escalations today."
            % (outcome_health.get("last_status", "unknown"),
               outcome_health.get("successes", 0), outcome_health.get("cache_hits", 0),
               outcome_health.get("deferred", 0), outcome_health.get("failures", 0),
               outcome_health.get("budget_skips", 0),
               outcome_health.get("uncalibrated_skips", 0),
               outcome_health.get("disabled_skips", 0),
               outcome_health.get("provider_skips", 0),
               outcome_health.get("privacy_skips", 0),
               outcome_health.get("lock_skips", 0),
               outcome_health.get("backoff_skips", 0),
               outcome_health.get("escalations", 0)),
            source="chat-graph extract-outcomes"))
    return lines[:top_n], max(0, len(lines) - top_n)


def _usage(snapshot, top_n):
    rows = []
    for provider in _payload(snapshot.get("usage")).get("providers") or []:
        if not isinstance(provider, dict):
            continue
        name = provider.get("provider") or "unknown"
        window = provider.get("window") or "window"
        used = provider.get("used_pct")
        confidence = provider.get("confidence") or "unknown"
        if isinstance(used, (int, float)):
            text = "%s %s: %.1f%% used (%s source)." % (name, window, float(used), confidence)
        else:
            text = "%s %s: usage unavailable (%s source)." % (name, window, confidence)
        rows.append(_sanitize_line(text, source="usage-snapshot"))
    if not rows:
        rows.append(_sanitize_line("Usage headroom is unavailable from current inputs.",
                                   source="usage-snapshot"))
    return rows[:top_n], max(0, len(rows) - top_n)


def _render_markdown(sidecar):
    out = ["# Mission Control Morning Brief", "",
           "Brief ID: `%s`" % sidecar["brief_id"], "",
           DESKTOP_GLANCE_CTA, ""]
    if sidecar["stale_required_inputs"]:
        out.extend(["**STALE DATA WARNING:** Required inputs are incomplete or stale.", ""])
    for section in sidecar["sections"]:
        out.extend(["## %s" % section["title"], ""])
        for line in section["lines"]:
            indent = "  " * max(0, min(1, int(line.get("depth") or 0)))
            source = line.get("source")
            suffix = " _(%s)_" % source if source else ""
            out.append("%s- **%s:** %s%s" % (indent, line["trust"], line["text"], suffix))
            if line.get("action_cmd"):
                out.append("  - Action: `%s`" % line["action_cmd"].replace("`", ""))
        if section["collapsed_count"]:
            out.append("- +%s more: dashboard" % section["collapsed_count"])
        out.append("")
    return "\n".join(out).rstrip() + "\n"


def _atomic_write(path, content):
    parent = os.path.dirname(path)
    os.makedirs(parent, mode=0o700, exist_ok=True)
    os.chmod(parent, 0o700)
    tmp = "%s.tmp.%d" % (path, os.getpid())
    flags = os.O_WRONLY | os.O_CREAT | os.O_TRUNC
    fd = os.open(tmp, flags, 0o600)
    try:
        with os.fdopen(fd, "w") as handle:
            handle.write(content)
            handle.flush()
            os.fsync(handle.fileno())
        os.replace(tmp, path)
        os.chmod(path, 0o600)
    finally:
        try:
            os.remove(tmp)
        except OSError:
            pass


def _atomic_json(path, value):
    _atomic_write(path, json.dumps(value, ensure_ascii=True, indent=2,
                                   sort_keys=True) + "\n")


# Same-local-day validity is shared with the deadman via the common module so a
# brief cannot be "valid" to one and "stale" to the other.
_same_local_day = same_local_day


def _chat_id():
    configured = os.environ.get("MORNING_BRIEF_CHAT_ID", "").strip()
    if re.match(r"^-?\d+$", configured):
        return configured
    path = os.path.expanduser(os.environ.get(
        "MOBILE_CONNECT_CONFIG", "~/.mobile-connect/config"))
    try:
        with open(path) as handle:
            for line in handle:
                match = re.match(r"^\s*ALLOWED_USER_ID\s*=\s*['\"]?(-?\d+)['\"]?\s*$", line)
                if match:
                    return match.group(1)
    except OSError:
        pass
    return None


def _sender_bin():
    return os.path.expanduser(os.environ.get(
        "MORNING_BRIEF_SEND_BIN",
        "/Users/gillettes/Coding Projects/mobile-connect/mobile-connect.sh"))


def _send_message(message):
    sender, chat_id = _sender_bin(), _chat_id()
    if not chat_id or not os.path.isfile(sender) or not os.access(sender, os.X_OK):
        return False
    try:
        completed = subprocess.run([sender, "send", chat_id, message],
                                   stdout=subprocess.DEVNULL,
                                   stderr=subprocess.DEVNULL, timeout=30)
        return completed.returncode == 0
    except (OSError, subprocess.TimeoutExpired):
        return False


def _split_utf8(value, limit):
    out, current, size = [], [], 0
    for char in value:
        width = len(char.encode("utf-8"))
        if current and size + width > limit:
            out.append("".join(current)); current, size = [], 0
        current.append(char); size += width
    if current:
        out.append("".join(current))
    return out


def _chunk_markdown(markdown, limit):
    # Reserve room for identity header, then preserve line boundaries whenever
    # possible. Oversized lines are split on valid UTF-8 character boundaries.
    body_limit = max(80, int(limit) - 100)
    units = []
    for line in markdown.splitlines(True):
        units.extend(_split_utf8(line, body_limit))
    bodies, current, size = [], [], 0
    for unit in units:
        width = len(unit.encode("utf-8"))
        if current and size + width > body_limit:
            bodies.append("".join(current).rstrip()); current, size = [], 0
        current.append(unit); size += width
    if current:
        bodies.append("".join(current).rstrip())
    return [body for body in bodies if body]


def _receipt_path(brief_id):
    safe_id = re.sub(r"[^A-Za-z0-9_.-]", "_", str(brief_id))
    return os.path.join(_brief_home(), "delivery", safe_id + ".json")


def _delivery_chunks(brief_id, markdown):
    try:
        limit = int(os.environ.get("MORNING_BRIEF_CHUNK_BYTES", "3500"))
    except ValueError:
        limit = 3500
    limit = min(3900, max(200, limit))
    # Screen the complete notification before division so a secret/PII value
    # cannot evade detection by straddling two otherwise-safe chunk bodies.
    whole = sanitize_text(markdown, NOTIFICATION, counters=_EGRESS_COUNTERS)
    if whole.dropped:
        return None
    bodies = _chunk_markdown(whole.value, limit)
    scrubbed = sanitize_chunks(bodies, counters=_EGRESS_COUNTERS)
    if len(scrubbed) != len(bodies) or not scrubbed:
        return None
    total, out = len(scrubbed), []
    for index, body in enumerate(scrubbed, 1):
        digest = hashlib.sha256(body.encode("utf-8")).hexdigest()
        header = "Morning Brief %s · chunk %d/%d · %s" % (
            brief_id, index, total, digest[:12])
        out.append({"index": index, "content_hash": digest,
                    "message": header + "\n\n" + body})
    return out


def _update_latest_delivery(sidecar, state, confirmed, total):
    sidecar["delivery"] = {"state": state, "confirmed_chunks": confirmed,
                           "total_chunks": total}
    _atomic_json(os.path.join(_brief_home(), "latest.json"), sidecar)


def _acquire_delivery_lock():
    os.makedirs(_brief_home(), mode=0o700, exist_ok=True)
    lock = os.path.join(_brief_home(), "delivery.lock")
    deadline = time.monotonic() + 60
    while True:
        try:
            os.mkdir(lock, 0o700)
            return lock
        except FileExistsError:
            try:
                if time.time() - os.path.getmtime(lock) > 600:
                    os.rmdir(lock)
                    continue
            except OSError:
                pass
            if time.monotonic() >= deadline:
                return None
            time.sleep(0.05)


def deliver():
    lock = _acquire_delivery_lock()
    if not lock:
        sys.stderr.write("morning-brief: delivery lock busy\n")
        return 75
    try:
        return _deliver_locked()
    finally:
        try:
            os.rmdir(lock)
        except OSError:
            pass


def _deliver_locked():
    _reset_egress_counters()
    now = _now()
    latest_path = os.path.join(_brief_home(), "latest.json")
    sidecar = _load_json(latest_path)
    prior_receipt = (_load_json(_receipt_path(sidecar.get("brief_id")))
                     if sidecar and sidecar.get("brief_id") else None)
    try:
        compose_age = now - int(sidecar.get("generated_epoch") or 0) if sidecar else 10**12
        max_compose_age = int(os.environ.get("MORNING_BRIEF_SEND_MAX_COMPOSE_AGE_S", "3600"))
    except (TypeError, ValueError):
        compose_age, max_compose_age = 10**12, 3600
    retrying = bool(prior_receipt and prior_receipt.get("state") in
                    ("failed", "partial", "pending"))
    if (not sidecar or not _same_local_day(sidecar.get("generated_epoch"), now) or
            (not retrying and prior_receipt is None and
             (compose_age > max_compose_age or not sidecar.get("markdown_sha256")))):
        rc = _compose_locked(preview=False)
        if rc:
            return rc
        sidecar = _load_json(latest_path)
        _reset_egress_counters()
    if not sidecar or not sidecar.get("brief_id"):
        sys.stderr.write("morning-brief: delivery unavailable\n")
        return 1
    brief_id = sidecar["brief_id"]
    receipt_path = _receipt_path(brief_id)
    receipt = _load_json(receipt_path)
    if receipt and receipt.get("state") == "delivered":
        _update_latest_delivery(sidecar, "delivered", receipt.get("confirmed_chunks", 0),
                                receipt.get("total_chunks", 0))
        print("delivery already complete: %s" % brief_id)
        return 0
    try:
        with open(os.path.join(_brief_home(), "latest.md")) as handle:
            markdown = handle.read()
    except OSError:
        sys.stderr.write("morning-brief: delivery unavailable\n")
        return 1
    actual_hash = hashlib.sha256(markdown.encode("utf-8")).hexdigest()
    if sidecar.get("markdown_sha256") != actual_hash:
        sys.stderr.write("morning-brief: delivery content mismatch\n")
        return 1
    chunks = _delivery_chunks(brief_id, markdown)
    sidecar.setdefault("egress_counters", {})["delivery"] = _EGRESS_COUNTERS.snapshot()
    if not chunks:
        _atomic_json(latest_path, sidecar)
        sys.stderr.write("morning-brief: notification content rejected\n")
        return 1
    expected = [{"index": row["index"], "content_hash": row["content_hash"],
                 "state": "pending", "attempts": 0} for row in chunks]
    if not receipt or receipt.get("total_chunks") != len(chunks) or [
            row.get("content_hash") for row in receipt.get("chunks", [])] != [
                row["content_hash"] for row in expected]:
        receipt = {"schema": 1, "brief_id": brief_id, "state": "pending",
                   "confirmed_chunks": 0, "total_chunks": len(chunks),
                   "chunks": expected, "created_at": now, "updated_at": now}
        _atomic_json(receipt_path, receipt)

    failed = False
    for message, state in zip(chunks, receipt["chunks"]):
        if state.get("state") == "confirmed":
            continue
        state["attempts"] = int(state.get("attempts") or 0) + 1
        state["last_attempt_at"] = now
        if _send_message(message["message"]):
            state["state"] = "confirmed"
            state["confirmed_at"] = now
            state.pop("last_error", None)
        else:
            state["state"] = "failed"
            state["last_error"] = "sender_failed"
            failed = True
        receipt["confirmed_chunks"] = sum(
            1 for row in receipt["chunks"] if row.get("state") == "confirmed")
        receipt["updated_at"] = now
        receipt["state"] = "failed" if failed else "partial"
        _atomic_json(receipt_path, receipt)
        if failed:
            break

    complete = receipt["confirmed_chunks"] == receipt["total_chunks"]
    if complete:
        receipt["state"] = "delivered"
        receipt["delivered_at"] = now
        receipt["updated_at"] = now
        _atomic_json(receipt_path, receipt)
        mark = sidecar.get("selection_high_water", {}).get("loose_end_changes") or [0, ""]
        _atomic_json(os.path.join(_brief_home(), "delivery-cursor.json"), {
            "schema": 1, "brief_id": brief_id, "delivered_at": now,
            "loose_end_changes": mark,
        })
        _update_latest_delivery(sidecar, "delivered", receipt["confirmed_chunks"],
                                receipt["total_chunks"])
        print("delivered %s (%d chunks)" % (brief_id, receipt["total_chunks"]))
        return 0
    _update_latest_delivery(sidecar, "failed", receipt["confirmed_chunks"],
                            receipt["total_chunks"])
    sys.stderr.write("morning-brief: delivery incomplete\n")
    return 1


def _migrate_valid_until(existing):
    """Backfill valid_until on a same-day delivered brief composed before the
    field existed, so the dashboard's next collect stops aging out today's brief
    on the 5-minute poll cadence. The horizon is next local midnight from the
    brief's own generated_epoch (same-local-day semantics) — no re-send, delivery
    idempotency untouched. Idempotent: a stamped sidecar is left as-is.
    """
    gen = existing.get("generated_epoch")
    if type(gen) is not int or gen <= 0:
        return False
    vu = existing.get("valid_until")
    if isinstance(vu, int) and vu > 0:
        return False
    existing["valid_until"] = next_local_midnight(gen)
    _atomic_write(os.path.join(_brief_home(), "latest.json"),
                  json.dumps(existing, ensure_ascii=True, indent=2,
                             sort_keys=True) + "\n")
    return True


def _compose_locked(preview=False):
    _reset_egress_counters()
    now = _now()
    if not preview:
        existing = _load_json(os.path.join(_brief_home(), "latest.json"))
        existing_id = existing.get("brief_id") if existing else None
        receipt = _load_json(_receipt_path(existing_id)) if existing_id else None
        delivery_state = ((receipt or {}).get("state") or
                          (existing or {}).get("delivery", {}).get("state"))
        if (existing and _same_local_day(existing.get("generated_epoch"), now) and
                delivery_state in ("pending", "partial", "failed", "delivered")):
            if delivery_state == "delivered" and _migrate_valid_until(existing):
                print("migrated valid_until on %s" % existing_id)
            print("compose deferred while delivery state is %s: %s" %
                  (delivery_state, existing_id))
            return 0
    snapshot = _snapshot_inputs()
    # Test seam proves input selection is a snapshot. Fixed argv; never a shell.
    hook = os.environ.get("MORNING_BRIEF_TEST_AFTER_SNAPSHOT_HOOK")
    if hook and os.path.isfile(hook) and os.access(hook, os.X_OK):
        subprocess.run([hook], check=False, timeout=5)

    # Collect memory-layer health alongside the input snapshot. A try/except in
    # addition to _memory_health's own fail-open branches, so nothing about the
    # memory layer can ever delay or break the brief: worst case is the one-word
    # "unavailable" note, never a missing brief.
    try:
        snapshot["memory"] = _memory_health(now)
    except Exception:
        snapshot["memory"] = "unavailable"
    health = {name: _input_health(name, snapshot[name], now) for name in INPUTS}
    top_n = _bounded_int("MORNING_BRIEF_TOP_N", 8)
    needs_cap = _bounded_int("MORNING_BRIEF_NEEDS_YOU_MAX", 3, maximum=10)
    cursor = _read_delivery_cursor()
    needs, needs_collapsed, stale = _needs_you(snapshot, health, needs_cap)
    happened, happened_collapsed = _what_happened(snapshot, top_n)
    possible, possible_collapsed = _possible_followups(snapshot, top_n)
    open_lines, open_collapsed, high_water = _open_changes(snapshot, top_n, cursor)
    machinery, machinery_collapsed = _machinery(snapshot, health, top_n)
    usage, usage_collapsed = _usage(snapshot, top_n)
    sections = [
        _section("NEEDS YOU", needs, needs_collapsed),
        _section("What happened", happened, happened_collapsed),
        _section("Possible follow-ups — Inferred", possible, possible_collapsed),
        _section("Open work changes", open_lines, open_collapsed),
        _section("Machinery health", machinery, machinery_collapsed),
        _section("Usage headroom", usage, usage_collapsed),
    ]
    identity = json.dumps({"now": now, "inputs": health, "sections": sections},
                          ensure_ascii=True, sort_keys=True)
    brief_id = time.strftime("%Y%m%d", time.localtime(now)) + "-" + hashlib.sha256(
        identity.encode("utf-8")).hexdigest()[:12]
    sidecar = {
        "schema": SCHEMA,
        "brief_id": brief_id,
        "generated_at": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime(now)),
        "generated_epoch": now,
        # A brief is a daily product: valid until the next local midnight, not
        # aged out on the dashboard's 5-minute poll cadence. Dashboard status and
        # index.html read this so a same-day brief is never flagged stale.
        "valid_until": next_local_midnight(now),
        "inputs": health,
        "stale_required_inputs": sorted(stale),
        "selection_high_water": {"loose_end_changes": [high_water[0], high_water[1]]},
        "sections": sections,
        "delivery": {"state": "not_sent", "confirmed_chunks": 0, "total_chunks": 0},
        "egress_counters": {"compose": _EGRESS_COUNTERS.snapshot()},
    }
    markdown = _render_markdown(sidecar)
    sidecar["markdown_sha256"] = hashlib.sha256(markdown.encode("utf-8")).hexdigest()
    if preview:
        sys.stdout.write(markdown)
        return 0
    _atomic_write(os.path.join(_brief_home(), "latest.md"), markdown)
    _atomic_write(os.path.join(_brief_home(), "latest.json"),
                  json.dumps(sidecar, ensure_ascii=True, indent=2, sort_keys=True) + "\n")
    dated = os.path.join(_brief_home(), time.strftime("%Y-%m-%d.md", time.localtime(now)))
    _atomic_write(dated, markdown)
    _atomic_json(os.path.join(_brief_home(), "last-compose.json"), {
        "schema": 1, "run_key": brief_id, "brief_id": brief_id,
        "completed_at": now, "result": "composed",
    })
    print("composed %s" % brief_id)
    return 0


def compose(preview=False):
    if preview:
        return _compose_locked(preview=True)
    lock = _acquire_delivery_lock()
    if not lock:
        sys.stderr.write("morning-brief: state lock busy\n")
        return 75
    try:
        return _compose_locked(preview=False)
    finally:
        try:
            os.rmdir(lock)
        except OSError:
            pass


def main(argv):
    allowed = {"--print", "--send"}
    unknown = [arg for arg in argv if arg not in allowed]
    if unknown:
        sys.stderr.write("usage: morning-brief [--print|--send]\n")
        return 2
    if "--print" in argv and "--send" in argv:
        sys.stderr.write("usage: morning-brief [--print|--send]\n")
        return 2
    if "--send" in argv:
        return deliver()
    return compose(preview="--print" in argv)


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
