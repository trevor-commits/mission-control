#!/usr/bin/env python3
"""Plan deterministic outcome coverage and Tier 2 load without model calls."""

import argparse
import importlib.machinery
import importlib.util
import json
import math
import os
import sqlite3
import sys
import time

from outcome_sources import PROVIDERS, read_messages, recent_sources

HERE = os.path.dirname(os.path.abspath(__file__))
LOADER = importlib.machinery.SourceFileLoader("mission_chat_graph", os.path.join(HERE, "chat-graph"))
SPEC = importlib.util.spec_from_loader(LOADER.name, LOADER)
CHAT_GRAPH = importlib.util.module_from_spec(SPEC)
LOADER.exec_module(CHAT_GRAPH)

GRAMMARS = ("reply_v5", "codex_closeout", "audit_report", "handoff_packet", "unstructured")
MODELED_OUTPUT_TOKENS_PER_CALL = 256


def _graph_evidence():
    """Return repo-linked and lineage-linked session ids without creating a DB."""
    configured = os.environ.get("OUTCOME_COVERAGE_GRAPH_DB")
    path = os.path.expanduser(configured) if configured else os.path.join(
        os.path.expanduser(os.environ.get("CHAT_GRAPH_HOME", "~/.chat-graph")), "graph.db")
    repos, lineage = set(), set()
    if not os.path.isfile(path):
        return repos, lineage, False
    try:
        con = sqlite3.connect("file:%s?mode=ro" % path, uri=True, timeout=5)
        tables = {row[0] for row in con.execute(
            "SELECT name FROM sqlite_master WHERE type='table'")}
        if "sessions" in tables:
            repos = {str(row[0]) for row in con.execute(
                "SELECT id FROM sessions WHERE COALESCE(repo,'')<>''")}
        if "edges" in tables:
            for src, dst in con.execute("""SELECT src,dst FROM edges
                WHERE status='active' AND type IN ('spawned','audits','continues')"""):
                lineage.add(str(src)); lineage.add(str(dst))
        con.close()
        return repos, lineage, True
    except sqlite3.Error:
        return set(), set(), False


def _number_env(name):
    raw = os.environ.get(name)
    if raw in (None, ""):
        return None
    try:
        return float(raw)
    except ValueError:
        return None


def build_report(days):
    sources, source_status = recent_sources(
        days, max_messages=CHAT_GRAPH.TIER1_MAX_MESSAGES,
        env_prefix="OUTCOME_COVERAGE")
    repo_sessions, lineage_sessions, graph_present = _graph_evidence()
    providers = {provider: {"sessions": 0, "tail_bytes": 0, "tail_tokens_estimate": 0,
                            "structured": 0, "unparseable": 0, "no_assistant_tail": 0,
                            "tier2_eligible": 0, "eligible_structured": 0,
                            "eligible_unstructured": 0}
                 for provider in PROVIDERS}
    grammars = {grammar: 0 for grammar in GRAMMARS}
    errors, packet_tails = 0, 0
    eligible_calls, eligible_tokens, total_bytes = 0, 0, 0
    eligible_reasons = {"repo": 0, "lineage": 0, "commit": 0}
    for provider, sid, source, _mtime_ns in sources:
        try:
            messages = read_messages(source, CHAT_GRAPH.read_assistant_messages)
            card = CHAT_GRAPH.tier1_parse_outcome(sid, provider, messages)
        except (OSError, UnicodeDecodeError, ValueError):
            errors += 1
            continue
        tail_bytes = int(card["source_span"]["bytes"])
        token_estimate = int(math.ceil(tail_bytes / 4.0)) if tail_bytes else 0
        providers[provider]["sessions"] += 1
        providers[provider]["tail_bytes"] += tail_bytes
        providers[provider]["tail_tokens_estimate"] += token_estimate
        total_bytes += tail_bytes
        if card["source_span"]["message_count"] == 0:
            providers[provider]["no_assistant_tail"] += 1
            continue
        grammar = card["grammar"] if card["grammar"] in grammars else "unstructured"
        grammars[grammar] += 1
        if grammar == "handoff_packet":
            packet_tails += 1
        if grammar == "unstructured":
            providers[provider]["unparseable"] += 1
        else:
            providers[provider]["structured"] += 1
        reasons = []
        if sid in repo_sessions:
            reasons.append("repo")
        if sid in lineage_sessions:
            reasons.append("lineage")
        if card.get("anchors", {}).get("commits"):
            reasons.append("commit")
        if reasons:
            providers[provider]["tier2_eligible"] += 1
            key = "eligible_unstructured" if grammar == "unstructured" else "eligible_structured"
            providers[provider][key] += 1
            eligible_calls += 1
            eligible_tokens += token_estimate
            for reason in reasons:
                eligible_reasons[reason] += 1

    calls_day = eligible_calls / float(days)
    input_day = eligible_tokens / float(days)
    output_window = eligible_calls * MODELED_OUTPUT_TOKENS_PER_CALL
    output_day = output_window / float(days)
    call_cap = _number_env("OUTCOME_COVERAGE_DAILY_CALL_CAP")
    token_cap = _number_env("OUTCOME_COVERAGE_DAILY_TOKEN_CAP")
    input_price = _number_env("OUTCOME_COVERAGE_MODELED_INPUT_USD_PER_MILLION")
    output_price = _number_env("OUTCOME_COVERAGE_MODELED_OUTPUT_USD_PER_MILLION")
    equivalent_day = None
    if input_price is not None and output_price is not None:
        equivalent_day = (input_day * input_price + output_day * output_price) / 1_000_000.0

    projection = {
        "basis": "modeled",
        "billing_route": "subscription-backed-or-unknown",
        "eligible_calls_window": eligible_calls,
        "input_tokens_window": eligible_tokens,
        "output_tokens_window": output_window,
        "calls_day": round(calls_day, 3),
        "input_tokens_day": round(input_day, 3),
        "output_tokens_day": round(output_day, 3),
        "calls_month_30d": round(calls_day * 30, 3),
        "input_tokens_month_30d": round(input_day * 30, 3),
        "output_tokens_month_30d": round(output_day * 30, 3),
        "charged_api_dollars": None,
        "api_equivalent_usd_day": (round(equivalent_day, 6)
                                    if equivalent_day is not None else None),
    }
    quota = {
        "daily_call_cap": call_cap,
        "daily_token_cap": token_cap,
        "modeled_call_headroom": (round(call_cap - calls_day, 3) if call_cap is not None else None),
        "modeled_input_token_headroom": (round(token_cap - input_day, 3)
                                          if token_cap is not None else None),
    }
    return {
        "schema": 1,
        "mode": "plan",
        "generated_epoch": int(time.time()),
        "window_days": days,
        "model_calls_made": 0,
        "providers": providers,
        "source_status": source_status,
        "graph_evidence_present": graph_present,
        "grammar_counts": grammars,
        "eligible_reason_counts": eligible_reasons,
        "packet_tails": packet_tails,
        "unparseable_sessions": sum(row["unparseable"] for row in providers.values()),
        "no_assistant_tail_sessions": sum(row["no_assistant_tail"]
                                          for row in providers.values()),
        "eligible_model_calls": eligible_calls,
        "tail_bytes": total_bytes,
        "tail_tokens_estimate": int(math.ceil(total_bytes / 4.0)) if total_bytes else 0,
        "read_errors": errors,
        "projection": projection,
        "quota": quota,
    }


def main(argv):
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--days", type=int, default=7)
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args(argv)
    if args.days <= 0 or args.days > 365:
        parser.error("--days must be between 1 and 365")
    report = build_report(args.days)
    if args.json:
        json.dump(report, sys.stdout, sort_keys=True, indent=2)
        sys.stdout.write("\n")
    else:
        print("Outcome coverage: %d sessions / %d days / zero model calls" %
              (sum(row["sessions"] for row in report["providers"].values()), args.days))
        print("Tier 2 eligible: %d (modeled %.3f calls/day)" %
              (report["eligible_model_calls"], report["projection"]["calls_day"]))
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
