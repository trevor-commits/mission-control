#!/usr/bin/env python3
"""chat-graph — records how chats connect (ER-087 mission-control, Part A core).

Owns a standalone SQLite DB at $CHAT_GRAPH_HOME/graph.db (dir chmod 700). This
packet = schema + structured collectors + manual commands + durability plumbing.
Transcript scanning/export = next packet; seams are left clean.

python3 stdlib only. All state + source roots honor env overrides so the tool
runs write-sandboxed and its tests use mktemp dirs. See docs/MISSION_CONTROL_PLAN.md
§"Part A" + §"Hardening addenda" for the authoritative design.
"""
import glob, hashlib, json, os, re, shutil, sqlite3, subprocess, sys, time
from collections import deque

from mission_control_common import (ACTION, NARRATIVE, EgressCounters,
                                    safe_text, sanitize_text)

SCHEMA_VERSION = 7
STALE_INGEST_S = 30 * 60  # show/doctor staleness threshold
LOCK_STALE_S = 30 * 60      # ingest.lock older than this is treated as crashed
_INGEST_SKIPPED = False     # set when export's catch-up ingest could not acquire lock
CHAT_PROVIDERS = frozenset(("claude", "codex", "cursor", "hermes", "copilot"))

# ---- env resolution -------------------------------------------------------
def _env(name, default):
    return os.environ.get(name) or os.path.expanduser(default)

HOME_DIR      = lambda: _env("CHAT_GRAPH_HOME", "~/.chat-graph")
CROSS_AGENT   = lambda: _env("CHAT_GRAPH_CROSS_AGENT_ROOT", "~/.cross-agent")
SESSION_INDEX = lambda: _env("CHAT_GRAPH_SESSION_INDEX", "~/.codex/session_index.jsonl")
CHAT_SOURCE   = lambda: _env("CHAT_GRAPH_CHAT_SOURCE", "~/.codex/scripts/chat-source")
CODING_ROOT   = lambda: _env("CHAT_GRAPH_CODING_ROOT", "/Users/gillettes/Coding Projects")
NIGHTLY_GLOB  = lambda: _env("CHAT_GRAPH_NIGHTLY_REPORT_GLOB", "~/.claude/nightly-review/reports/*.md")
HERMES_STATE_DB = lambda: _env("CHAT_GRAPH_HERMES_STATE_DB", "~/.hermes/state.db")
TIER1_PARSER_VERSION = 5

def db_path():      return os.path.join(HOME_DIR(), "graph.db")
def journal_path(): return os.path.join(HOME_DIR(), "journal", "manual.jsonl")
def lock_path():    return os.path.join(HOME_DIR(), "ingest.lock")
def marker_path():  return os.path.join(HOME_DIR(), "last-ingest")
def scanlog_path(): return os.path.join(HOME_DIR(), "logs", "scan-errors.log")

def ensure_dir(path, mode=0o700):
    os.makedirs(path, exist_ok=True)
    os.chmod(path, mode)  # makedirs mode is umask-masked; force it

# ---- shared field-aware boundary -----------------------------------------
def redact(s):
    return safe_text(s or "", NARRATIVE)

# ---- edge model -----------------------------------------------------------
EDGE_TYPES = ("audits", "spawned", "continues", "signaled",
              "references", "same_issue", "governs", "related_manual")
UNDIRECTED = ("related_manual",)

def canon(a, b, etype):
    """Undirected types canonicalize pair order; directed keep it."""
    if etype in UNDIRECTED and a > b:
        return b, a
    return a, b

# ---- DB open + migrations -------------------------------------------------
def connect():
    ensure_dir(HOME_DIR())
    con = sqlite3.connect(db_path())
    con.execute("PRAGMA journal_mode=WAL")
    con.execute("PRAGMA busy_timeout=5000")
    con.row_factory = sqlite3.Row
    _migrate(con)
    return con

def _edge_unique_has_source(con):
    """True if the edges UNIQUE index already includes `source` (v2 shape)."""
    for idx in con.execute("PRAGMA index_list('edges')").fetchall():
        if idx["unique"]:
            idx_name = idx["name"]
            if not re.match(r'^[A-Za-z0-9_]+$', idx_name or ""):
                continue
            cols = [r["name"] for r in con.execute(
                "PRAGMA index_info(%s)" % (idx_name,)).fetchall()]
            if "source" in cols:
                return True
    return False

def _rebuild_edges_v2(con):
    """Rebuild edges with UNIQUE(src,dst,type,source), preserving every row
    (status/confidence/evidence intact). v1's coarser key means <=1 row per
    (src,dst,type,source), so the copy never collides on the finer key."""
    con.execute("ALTER TABLE edges RENAME TO edges_v1")
    con.execute("""CREATE TABLE edges(
        src TEXT, dst TEXT, type TEXT, source TEXT,
        confidence REAL, evidence TEXT, note TEXT,
        status TEXT DEFAULT 'active',
        UNIQUE(src, dst, type, source))""")
    con.execute("""INSERT INTO edges(src, dst, type, source, confidence, evidence, note, status)
                   SELECT src, dst, type, source, confidence, evidence, note, status
                   FROM edges_v1""")
    con.execute("DROP TABLE edges_v1")

def _node_kind(sid, provider):
    if str(sid or "").startswith("repo:") or provider == "repo":
        return "repo"
    if provider in CHAT_PROVIDERS:
        return "chat"
    return "unknown"

def _safe_provider(provider, node_kind=None):
    if node_kind == "repo" or provider == "repo":
        return "repo"
    return provider if provider in CHAT_PROVIDERS else "unknown"

def _open_end_schema_v5(con):
    cols = {r["name"] for r in con.execute("PRAGMA table_info('open_ends')")}
    required = {"item_key", "updated_at", "resolution_evidence_type",
                "resolution_evidence_ref", "last_change_type"}
    if not required.issubset(cols):
        return False
    for idx in con.execute("PRAGMA index_list('open_ends')").fetchall():
        if not idx["unique"]:
            continue
        name = idx["name"]
        if not re.match(r"^[A-Za-z0-9_]+$", name or ""):
            continue
        names = [r["name"] for r in con.execute("PRAGMA index_info(%s)" % name)]
        if names == ["session_id", "kind", "item_key"]:
            return True
    return False

def _create_open_ends_v5(con):
    con.execute("""CREATE TABLE open_ends(
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        session_id TEXT, kind TEXT, text TEXT, text_hash TEXT,
        item_key TEXT NOT NULL, resolved_at INTEGER, first_seen_at INTEGER,
        updated_at INTEGER, resolution_evidence_type TEXT,
        resolution_evidence_ref TEXT, last_change_type TEXT,
        UNIQUE(session_id, kind, item_key))""")
    con.execute("CREATE INDEX IF NOT EXISTS idx_open_ends_updated ON open_ends(updated_at, item_key)")

def _rebuild_open_ends_v5(con):
    """Rebuild the v4 table around kind-salted stable identity, preserving rows."""
    now = int(time.time())
    con.execute("ALTER TABLE open_ends RENAME TO open_ends_v4")
    _create_open_ends_v5(con)
    rows = con.execute("SELECT * FROM open_ends_v4 ORDER BY id").fetchall()
    for row in rows:
        kind = row["kind"] or "open"
        text_hash = row["text_hash"] or hashlib.sha1(
            (row["text"] or "").encode("utf-8", "replace")).hexdigest()
        item_key = hashlib.sha1(("%s:legacy:%s" % (kind, text_hash)).encode("utf-8")).hexdigest()
        first_seen = row["first_seen_at"] or now
        resolved = row["resolved_at"]
        updated = resolved or first_seen
        con.execute("""INSERT INTO open_ends(
            id, session_id, kind, text, text_hash, item_key, resolved_at,
            first_seen_at, updated_at, resolution_evidence_type,
            resolution_evidence_ref, last_change_type)
            VALUES(?,?,?,?,?,?,?,?,?,?,?,?)""",
            (row["id"], row["session_id"], kind, row["text"], text_hash,
             item_key, resolved, first_seen, updated,
             "legacy" if resolved else None, "v4-migration" if resolved else None,
             "resolved" if resolved else "new"))
    con.execute("DROP TABLE open_ends_v4")

def _outcome_unique_has_variant(con):
    """True when prompt/model variants can coexist within an outcome lane."""
    for idx in con.execute("PRAGMA index_list('session_outcomes')").fetchall():
        if not idx["unique"]:
            continue
        name = idx["name"]
        if not re.match(r"^[A-Za-z0-9_]+$", name or ""):
            continue
        names = [r["name"] for r in con.execute("PRAGMA index_info(%s)" % name)]
        if names == ["session_id", "tail_hash", "method", "variant"]:
            return True
    return False

def _create_session_outcomes_v7(con):
    con.execute("""CREATE TABLE session_outcomes(
        id TEXT PRIMARY KEY, session_id TEXT NOT NULL, provider TEXT,
        tail_hash TEXT NOT NULL, outcome_json TEXT NOT NULL,
        extraction_status TEXT, finalized INTEGER DEFAULT 0,
        updated_at INTEGER, method TEXT NOT NULL DEFAULT 'tier1',
        variant TEXT NOT NULL DEFAULT 'tier1', confidence REAL,
        source_start TEXT, source_end TEXT, source_span TEXT,
        evidence_fingerprint TEXT, created_at INTEGER,
        UNIQUE(session_id, tail_hash, method, variant))""")

def _rebuild_session_outcomes_v7(con):
    """Allow immutable prompt/model variants for the same source tail."""
    columns = {row["name"] for row in con.execute(
        "PRAGMA table_info('session_outcomes')")}
    con.execute("ALTER TABLE session_outcomes RENAME TO session_outcomes_legacy")
    _create_session_outcomes_v7(con)
    variant = ("COALESCE(NULLIF(variant,''),CASE WHEN method='tier2' "
               "THEN 'legacy:'||id ELSE 'tier1' END)" if "variant" in columns else
               "CASE WHEN method='tier2' THEN 'legacy:'||id ELSE 'tier1' END")
    con.execute("""INSERT INTO session_outcomes(
        id,session_id,provider,tail_hash,outcome_json,extraction_status,finalized,
        updated_at,method,variant,confidence,source_start,source_end,source_span,
        evidence_fingerprint,created_at)
        SELECT id,session_id,provider,tail_hash,outcome_json,extraction_status,finalized,
        updated_at,COALESCE(NULLIF(method,''),'tier1'),%s,confidence,source_start,source_end,
        source_span,evidence_fingerprint,created_at FROM session_outcomes_legacy""" % variant)
    con.execute("DROP TABLE session_outcomes_legacy")

def _migrate(con):
    # meta must exist before the future-version guard can read the version, but
    # CREATE TABLE IF NOT EXISTS on an already-present meta is a pure no-op.
    con.execute("CREATE TABLE IF NOT EXISTS meta(key TEXT PRIMARY KEY, value TEXT)")
    row = con.execute("SELECT value FROM meta WHERE key='schema_version'").fetchone()
    ver = int(row["value"]) if row else 0
    # Future-version guard FIRST — before ANY DDL/migration — so newer-than-code
    # code never mutates (and, via executescript's implicit commit, persists a
    # partial migration of) a DB it does not understand.
    if ver > SCHEMA_VERSION:
        sys.stderr.write("chat-graph: db schema_version %d newer than code %d "
                         "— upgrade chat-graph or use a fresh DB\n" % (ver, SCHEMA_VERSION))
        sys.exit(3)
    con.executescript("""
      CREATE TABLE IF NOT EXISTS sessions(
        id TEXT PRIMARY KEY, provider TEXT, title TEXT, repo TEXT,
        first_prompt TEXT, last_activity TEXT,
        closeout_seen INTEGER DEFAULT 0, open_end_count INTEGER DEFAULT 0,
        first_seen_at INTEGER, node_kind TEXT);
      CREATE TABLE IF NOT EXISTS edges(
        src TEXT, dst TEXT, type TEXT, source TEXT,
        confidence REAL, evidence TEXT, note TEXT,
        status TEXT DEFAULT 'active',
        UNIQUE(src, dst, type, source));
      CREATE TABLE IF NOT EXISTS suppressions(
        src TEXT, dst TEXT, type TEXT, PRIMARY KEY(src, dst, type));
      CREATE TABLE IF NOT EXISTS session_topics(
        session_id TEXT, code TEXT, UNIQUE(session_id, code));
      CREATE TABLE IF NOT EXISTS open_ends(
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        session_id TEXT, kind TEXT, text TEXT, text_hash TEXT,
        item_key TEXT NOT NULL, resolved_at INTEGER, first_seen_at INTEGER,
        updated_at INTEGER, resolution_evidence_type TEXT,
        resolution_evidence_ref TEXT, last_change_type TEXT,
        UNIQUE(session_id, kind, item_key));
      CREATE TABLE IF NOT EXISTS session_outcomes(
        id TEXT PRIMARY KEY, session_id TEXT NOT NULL, provider TEXT,
        tail_hash TEXT NOT NULL, outcome_json TEXT NOT NULL,
        extraction_status TEXT, finalized INTEGER DEFAULT 0,
        updated_at INTEGER, method TEXT NOT NULL DEFAULT 'tier1',
        variant TEXT NOT NULL DEFAULT 'tier1', confidence REAL,
        source_start TEXT, source_end TEXT, source_span TEXT,
        evidence_fingerprint TEXT, created_at INTEGER,
        UNIQUE(session_id, tail_hash, method, variant));
      CREATE TABLE IF NOT EXISTS session_outcome_observations(
        observation_id INTEGER PRIMARY KEY AUTOINCREMENT,
        session_id TEXT NOT NULL, outcome_id TEXT NOT NULL,
        tail_hash TEXT NOT NULL, observed_at INTEGER NOT NULL,
        finalized INTEGER DEFAULT 0, evidence_fingerprint TEXT,
        UNIQUE(session_id, observation_id));
      CREATE INDEX IF NOT EXISTS idx_outcome_observation_session
        ON session_outcome_observations(session_id, observation_id);
      CREATE TABLE IF NOT EXISTS outcome_resolution_markers(
        marker_ref TEXT PRIMARY KEY, session_id TEXT NOT NULL,
        item_key TEXT NOT NULL, marker_type TEXT NOT NULL,
        applied_at INTEGER NOT NULL);
      CREATE TABLE IF NOT EXISTS outcome_extraction_cache(
        cache_key TEXT PRIMARY KEY, session_id TEXT NOT NULL, provider TEXT NOT NULL,
        model TEXT NOT NULL, sanitized_tail_hash TEXT NOT NULL,
        result_json TEXT NOT NULL, created_at INTEGER NOT NULL, updated_at INTEGER NOT NULL);
      CREATE INDEX IF NOT EXISTS idx_outcome_cache_session
        ON outcome_extraction_cache(session_id, sanitized_tail_hash);
      CREATE TABLE IF NOT EXISTS outcome_extraction_health(
        day TEXT PRIMARY KEY, calls INTEGER NOT NULL DEFAULT 0,
        successes INTEGER NOT NULL DEFAULT 0,
        input_tokens INTEGER NOT NULL DEFAULT 0,
        output_tokens INTEGER NOT NULL DEFAULT 0,
        cache_hits INTEGER NOT NULL DEFAULT 0,
        deferred INTEGER NOT NULL DEFAULT 0,
        failures INTEGER NOT NULL DEFAULT 0,
        budget_skips INTEGER NOT NULL DEFAULT 0,
        provider_skips INTEGER NOT NULL DEFAULT 0,
        disabled_skips INTEGER NOT NULL DEFAULT 0,
        privacy_skips INTEGER NOT NULL DEFAULT 0,
        uncalibrated_skips INTEGER NOT NULL DEFAULT 0,
        lock_skips INTEGER NOT NULL DEFAULT 0,
        backoff_skips INTEGER NOT NULL DEFAULT 0,
        escalations INTEGER NOT NULL DEFAULT 0,
        total_latency_ms INTEGER NOT NULL DEFAULT 0,
        last_status TEXT, updated_at INTEGER NOT NULL DEFAULT 0);
      CREATE TABLE IF NOT EXISTS outcome_extraction_attempts(
        session_id TEXT NOT NULL, provider TEXT NOT NULL, tail_hash TEXT NOT NULL,
        variant TEXT NOT NULL, last_status TEXT NOT NULL,
        attempts INTEGER NOT NULL DEFAULT 0, last_attempt_at INTEGER NOT NULL,
        next_retry_at INTEGER NOT NULL,
        PRIMARY KEY(session_id,provider,tail_hash,variant));
      CREATE TABLE IF NOT EXISTS collector_state(
        collector TEXT PRIMARY KEY, cursor TEXT, last_run INTEGER,
        row_count INTEGER DEFAULT 0);
      CREATE TABLE IF NOT EXISTS file_cursors(
        path TEXT PRIMARY KEY, mtime INTEGER, size INTEGER,
        parser_version INTEGER DEFAULT 0);
    """)
    # additive columns (idempotent; ALTER has no IF NOT EXISTS pre-3.35)
    for col, decl in (("first_msg_uuid", "TEXT"), ("enriched_at", "INTEGER"),
                      ("node_kind", "TEXT")):
        try:
            con.execute("ALTER TABLE sessions ADD COLUMN %s %s" % (col, decl))
        except sqlite3.OperationalError:
            pass
    try:
        con.execute("ALTER TABLE file_cursors ADD COLUMN parser_version INTEGER DEFAULT 0")
    except sqlite3.OperationalError:
        pass
    try:
        con.execute("ALTER TABLE outcome_extraction_health ADD COLUMN backoff_skips INTEGER NOT NULL DEFAULT 0")
    except sqlite3.OperationalError:
        pass
    open_cols = {r["name"] for r in con.execute("PRAGMA table_info('open_ends')")}
    if "first_seen_at" not in open_cols:
        con.execute("ALTER TABLE open_ends ADD COLUMN first_seen_at INTEGER")
    if not _open_end_schema_v5(con):
        _rebuild_open_ends_v5(con)
    con.execute("CREATE INDEX IF NOT EXISTS idx_open_ends_updated ON open_ends(updated_at, item_key)")
    if not _outcome_unique_has_variant(con):
        _rebuild_session_outcomes_v7(con)
    if _get_meta(con, "outcome_observations_backfilled", "0") != "1":
        if con.execute("SELECT COUNT(*) FROM session_outcome_observations").fetchone()[0] == 0:
            con.execute("""INSERT INTO session_outcome_observations(
                session_id,outcome_id,tail_hash,observed_at,finalized,evidence_fingerprint)
                SELECT session_id,id,tail_hash,COALESCE(created_at,updated_at,?),
                       finalized,evidence_fingerprint FROM session_outcomes
                ORDER BY COALESCE(created_at,updated_at,0),rowid""", (int(time.time()),))
        _set_meta(con, "outcome_observations_backfilled", "1")
    con.execute("UPDATE open_ends SET first_seen_at=COALESCE(first_seen_at, ?), "
                "updated_at=COALESCE(updated_at, resolved_at, first_seen_at, ?), "
                "last_change_type=COALESCE(last_change_type, CASE WHEN resolved_at IS NULL "
                "THEN 'new' ELSE 'resolved' END)", (int(time.time()), int(time.time())))
    con.execute("UPDATE sessions SET node_kind=CASE "
                "WHEN id LIKE 'repo:%' OR provider='repo' THEN 'repo' "
                "WHEN provider IN ('claude','codex','cursor','hermes','copilot') THEN 'chat' "
                "ELSE 'unknown' END WHERE node_kind IS NULL OR node_kind='' ")
    # v1->v2: edges uniqueness gained `source` so a strong (e.g. delegations) and a
    # weak (e.g. titles) edge for the same (src,dst,type) coexist. A pre-existing v1
    # edges table keeps its old UNIQUE(src,dst,type) until rebuilt here. Detect via
    # the unique index columns (formatting-proof; whitespace in the DDL doesn't lie).
    if not _edge_unique_has_source(con):
        _rebuild_edges_v2(con)
    # v2->v3: the suppressions table is now the SOURCE-INDEPENDENT authority for
    # unlink (a per-row status='suppressed' sentinel could not block a later
    # collector inserting the same (src,dst,type) under a different source). Backfill
    # from every existing suppressed row — all of which trace to _apply_unlink.
    if ver < 3:
        con.execute("INSERT OR IGNORE INTO suppressions(src, dst, type) "
                    "SELECT src, dst, type FROM edges WHERE status='suppressed'")
    # linear idempotent forward migrations would chain here as versions grow.
    if ver < SCHEMA_VERSION:
        con.execute("INSERT OR REPLACE INTO meta VALUES('schema_version', ?)",
                    (str(SCHEMA_VERSION),))
    con.commit()

# ---- session nodes --------------------------------------------------------
def touch_session(con, sid, provider=None, title=None, first_prompt=None):
    if not sid:
        return
    now = int(time.time())
    con.execute("INSERT OR IGNORE INTO sessions(id, first_seen_at) VALUES(?, ?)", (sid, now))
    for col, val in (("provider", provider), ("title", title), ("first_prompt", first_prompt)):
        if val:
            con.execute("UPDATE sessions SET %s=? WHERE id=? AND (%s IS NULL OR %s='')"
                        % (col, col, col), (val, sid))
    effective = provider
    if not effective:
        row = con.execute("SELECT provider FROM sessions WHERE id=?", (sid,)).fetchone()
        effective = row["provider"] if row else None
    con.execute("UPDATE sessions SET node_kind=? WHERE id=?",
                (_node_kind(sid, effective), sid))

def display_title(row):
    """Untitled fallback chain: title -> first_prompt(60) -> (untitled) <id8>."""
    t = (row["title"] or "").strip()
    if t:
        return redact(t)
    fp = (row["first_prompt"] or "").strip()
    if fp:
        return redact(fp[:60])
    return "(untitled) %s" % (row["id"] or "")[:8]

# ---- edge write primitives (upsert NEVER writes status) -------------------
def upsert_edge(con, src, dst, etype, source, confidence, evidence, note=None):
    s, d = canon(src, dst, etype)
    con.execute("""INSERT INTO edges(src, dst, type, source, confidence, evidence, note, status)
       VALUES(?,?,?,?,?,?,?, 'active')
       ON CONFLICT(src, dst, type, source) DO UPDATE SET
         confidence=max(edges.confidence, excluded.confidence),
         evidence=excluded.evidence, note=excluded.note""",
       (s, d, etype, source, confidence, json.dumps(evidence, sort_keys=True), note))

def _apply_link(con, a, b, etype, note):
    # re-linking clears any standing suppression for this exact pair/type so the
    # edge is authoritative again (collector rows under any source reappear).
    s, d = canon(a, b, etype)
    con.execute("DELETE FROM suppressions WHERE src=? AND dst=? AND type=?", (s, d, etype))
    upsert_edge(con, a, b, etype, "manual", 1.0, {"manual": True}, note)

def _apply_unlink(con, a, b, etype):
    types = [etype] if etype else [r["type"] for r in con.execute(
        "SELECT DISTINCT type FROM edges WHERE (src=? AND dst=?) OR (src=? AND dst=?)",
        (a, b, b, a))]
    if not types:
        types = ["related_manual"]  # sentinel needs a type
    for t in types:
        s, d = canon(a, b, t)
        # suppressions is the SOURCE-INDEPENDENT authority: one row hides this
        # (src,dst,type) regardless of which collector/source (re)inserts it.
        con.execute("INSERT OR IGNORE INTO suppressions(src, dst, type) VALUES(?,?,?)",
                    (s, d, t))
        # keep the per-row status='suppressed' belt-and-suspenders too.
        cur = con.execute("UPDATE edges SET status='suppressed' "
                          "WHERE src=? AND dst=? AND type=?", (s, d, t))
        if cur.rowcount == 0:
            # pre-insert a suppressed sentinel so future collectors land on the
            # conflict key (src,dst,type) and cannot resurrect it.
            con.execute("INSERT OR IGNORE INTO edges(src, dst, type, source, confidence, "
                        "evidence, status) VALUES(?,?,?, 'manual', 0.0, '{}', 'suppressed')",
                        (s, d, t))

def _resolve_open_end(con, sid, text_hash, evidence_type, evidence_ref):
    now = int(time.time())
    con.execute("""UPDATE open_ends SET resolved_at=?, updated_at=?,
                resolution_evidence_type=?, resolution_evidence_ref=?,
                last_change_type='resolved'
                WHERE session_id=? AND text_hash=? AND resolved_at IS NULL""",
                (now, now, evidence_type, evidence_ref, sid, text_hash))


def _resolve_open_end_key(con, sid, item_key, evidence_type, evidence_ref):
    """Resolve one exact parsed item; shared text must never fan resolution out."""
    now = int(time.time())
    return con.execute("""UPDATE open_ends SET resolved_at=?, updated_at=?,
                resolution_evidence_type=?, resolution_evidence_ref=?,
                last_change_type='resolved'
                WHERE session_id=? AND kind='chat_open_end' AND item_key=?
                  AND resolved_at IS NULL""",
                (now, now, evidence_type, evidence_ref, sid, item_key)).rowcount

def _apply_resolve(con, sid, text_hash):
    _resolve_open_end(con, sid, text_hash, "manual", "journal")

# ---- manual journal (durability keystone) ---------------------------------
def journal_append(rec):
    ensure_dir(os.path.dirname(journal_path()))
    rec = dict(rec, ts=int(time.time()))
    with open(journal_path(), "a") as f:
        f.write(json.dumps(rec, sort_keys=True) + "\n")
        f.flush()
        os.fsync(f.fileno())

def journal_replay(con):
    if not os.path.exists(journal_path()):
        return
    with open(journal_path()) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                r = json.loads(line)
            except ValueError:
                continue
            op = r.get("op")
            if op == "link":
                _apply_link(con, r["a"], r["b"], r["type"], r.get("note"))
            elif op == "unlink":
                _apply_unlink(con, r["a"], r["b"], r.get("type"))
            elif op == "resolve":
                _apply_resolve(con, r["a"], r["b"])
    con.commit()

# ---- chat-source bridge (best-effort, degraded never fatal) ---------------
_STALE_PROVIDERS = set()

def chat_source(*args, timeout=8):
    exe = CHAT_SOURCE()
    if not (exe and os.path.exists(exe)):
        return None
    try:
        out = subprocess.run([exe] + list(args), capture_output=True, text=True,
                             timeout=timeout)
        if out.returncode != 0:
            return None
        return out.stdout
    except Exception:
        return None

def describe(sid):
    """Return dict of chat-source describe fields, or None (degraded)."""
    out = chat_source("describe", sid)
    if out is None:
        _STALE_PROVIDERS.add("chat-source")
        return None
    meta = {}
    for ln in out.splitlines():
        if ":" in ln:
            k, _, v = ln.partition(":")
            meta[k.strip()] = v.strip()
    return meta

# ---- collectors -----------------------------------------------------------
def _iter_json(paths):
    for p in paths:
        try:
            with open(p) as f:
                yield p, json.load(f)
        except Exception:
            continue  # tolerate malformed/absent — never fatal

def collect_delegations(con):
    import glob
    n = 0
    root = os.path.join(CROSS_AGENT(), "delegations")
    for path, data in _iter_json(sorted(glob.glob(os.path.join(root, "*", "state.json")))):
        gov = (data.get("governor") or {}).get("id")
        worker = data.get("worker_child_id")
        if not (gov and worker):
            continue
        hv = data.get("handshake_verified")
        conf = 1.0 if hv == "yes" else 0.8
        touch_session(con, gov, provider=(data.get("governor") or {}).get("provider"))
        touch_session(con, worker, provider=data.get("to"))
        upsert_edge(con, gov, worker, "spawned", "delegations", conf,
                    {"path": path, "handshake": data.get("handshake")})
        n += 1
    return n

def collect_mailbox(con):
    import glob
    n = 0
    root = os.path.join(CROSS_AGENT(), "mailbox")
    pats = [os.path.join(root, "*", box, "*.json") for box in ("inbox", "read")]
    files = sorted(f for pat in pats for f in glob.glob(pat))
    for path, data in _iter_json(files):
        frm, to = data.get("from"), data.get("to")
        if not frm or frm == "unknown" or not to:
            continue
        touch_session(con, frm, provider=data.get("from_provider"))
        touch_session(con, to)
        upsert_edge(con, frm, to, "signaled", "mailbox", 1.0,
                    {"path": path, "schema": data.get("schema")})
        n += 1
    return n

_AUDIT_RE  = re.compile(r"^audit:\s*(.+)$", re.IGNORECASE)
_WORKER_RE = re.compile(r"^worker:\s*(.+?)\s+-\s+", re.IGNORECASE)

def _norm_title(t):
    """Normalize a title for drift-tolerant matching: drop a trailing parenthetical
    (e.g. ' (fork)') and a trailing ' - <suffix>' dash-suffix. Real titles drift like
    'Where was I?' -> 'Where was I? - Chronicle'."""
    t = (t or "").strip()
    t = re.sub(r"\s*\([^)]*\)\s*$", "", t)   # trailing (...) incl (fork)
    t = re.sub(r"\s+-\s+.+$", "", t)          # trailing ' - <suffix>'
    return t.strip()

def _title_index(con):
    """Matcher struct over session titles: exact(lower)->[(id,seen)],
    norm(lower)->[(id,seen)], and rows [(id,title,seen)] for prefix scans."""
    exact, norm, rows = {}, {}, []
    for r in con.execute("SELECT id, title, first_seen_at FROM sessions WHERE title IS NOT NULL AND title != ''"):
        title = r["title"].strip(); seen = r["first_seen_at"] or 0
        exact.setdefault(title.lower(), []).append((r["id"], seen))
        norm.setdefault(_norm_title(title).lower(), []).append((r["id"], seen))
        rows.append((r["id"], title, seen))
    return {"exact": exact, "norm": norm, "rows": rows}

def collect_titles(con):
    # 1. load id -> title from the session index JSONL, plus best-effort `list`.
    titles = {}
    idx = SESSION_INDEX()
    if os.path.exists(idx):
        with open(idx) as f:
            for ln in f:
                try:
                    r = json.loads(ln)
                except ValueError:
                    continue
                if r.get("id") and r.get("thread_name"):
                    titles[r["id"]] = r["thread_name"]
    for sid, title in titles.items():
        touch_session(con, sid, title=title)
    # carry-over fix: NEVER call the >2-min `chat-source list`. Lazily enrich a
    # small batch of sessions missing title/repo via per-session `describe`.
    _enrich_sessions(con)
    # 2. match title-drift patterns against the title index.
    tindex = _title_index(con)
    n = 0
    for sid, title in titles.items():
        m = _AUDIT_RE.match(title.strip())
        if m:
            n += _match_and_link(con, sid, m.group(1), tindex, "audits", "auditor")
            continue
        m = _WORKER_RE.match(title.strip())
        if m:
            n += _match_and_link(con, sid, m.group(1), tindex, "spawned", "worker")
    return n

def _match_and_link(con, this_id, name, tindex, etype, role):
    """Match an audited/parent NAME against session titles with graded confidence:
    exact 0.7 -> normalized 0.7 -> unique prefix 0.6; multiple candidates at any
    tier collapse to most-recent 0.5 'ambiguous title'; no match -> no edge."""
    key = name.strip().lower()
    def others(cands):
        return [c for c in cands if c[0] != this_id]
    cands, conf, note = others(tindex["exact"].get(key, [])), 0.7, None
    if not cands:
        cands, note = others(tindex["norm"].get(_norm_title(name).lower(), [])), "normalized"
    if not cands:
        # prefix: NAME is a prefix of a session title (title >= 8 chars guards noise).
        cands = [(sid, seen) for (sid, title, seen) in tindex["rows"]
                 if sid != this_id and len(title) >= 8 and title.lower().startswith(key)]
        conf, note = 0.6, "prefix"
    if not cands:
        return 0
    if len(cands) == 1:
        target = cands[0][0]
    else:
        target = max(cands, key=lambda c: c[1])[0]  # most-recent
        conf, note = 0.5, "ambiguous title"
    # audits: auditor(this)->audited(target); spawned via worker: source(target)->worker(this)
    if role == "auditor":
        src, dst = this_id, target
    else:
        src, dst = target, this_id
    upsert_edge(con, src, dst, etype, "titles", conf,
                {"matched_title": name}, note)
    return 1

_RESOLVABLE_ID_RE = re.compile(
    r"(^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-)"          # 8-4-... UUID (Claude/Copilot)
    r"|(^019[0-9a-f]{5})"                          # Codex/Cursor 019... thread ids
    r"|(^\d{8}_\d{6}_[0-9a-f]{6}$)")               # Hermes YYYYMMDD_HHMMSS_hex
def _looks_resolvable(sid):
    """True if `sid` has the shape of a real provider session id chat-source can
    resolve. Synthetic ids (workflow 'agent-*', test 'x:1') return False so they
    never re-enter the enrichment retry pool (sweep FIX 4)."""
    return bool(sid and _RESOLVABLE_ID_RE.match(sid))

def _enrich_sessions(con, limit=50):
    """Lazy per-session `chat-source describe` enrichment (carry-over fix for the
    dead `list` bridge). ≤`limit` newest sessions missing title/repo, refreshed at
    most weekly; abort after 3 consecutive describe failures -> degraded."""
    now = int(time.time())
    week_ago = now - 7 * 24 * 3600
    rows = con.execute(
        "SELECT id FROM sessions "
        "WHERE ((title IS NULL OR title='') OR (repo IS NULL OR repo='')) "
        "AND (enriched_at IS NULL OR enriched_at < ?) "
        "ORDER BY first_seen_at DESC LIMIT ?", (week_ago, limit)).fetchall()
    fails = 0
    for r in rows:
        # sweep FIX 4: synthetic / non-resolvable ids (e.g. workflow 'agent-*' ids)
        # will NEVER resolve via chat-source -> without this they re-enter the pool
        # every run and 3 of them trip the 'degraded' banner on EVERY ingest. Stamp
        # them enriched (no metadata) so they leave the pool and don't count as fails.
        if not _looks_resolvable(r["id"]):
            con.execute("UPDATE sessions SET enriched_at=? WHERE id=?", (now, r["id"]))
            continue
        meta = describe(r["id"])
        if meta is None:
            fails += 1
            # backoff: stamp enriched_at so a persistently-unresolvable REAL id is not
            # retried EVERY run (weekly cadence via the enriched_at<week_ago filter) —
            # otherwise the same failures re-trip 'degraded' on every ingest (sweep FIX 4).
            con.execute("UPDATE sessions SET enriched_at=? WHERE id=?", (now, r["id"]))
            if fails >= 3:
                _STALE_PROVIDERS.add("chat-source")
                break
            continue
        fails = 0
        con.execute(
            "UPDATE sessions SET title=COALESCE(NULLIF(title,''),?), "
            "repo=COALESCE(NULLIF(repo,''),?), provider=COALESCE(NULLIF(provider,''),?), "
            "enriched_at=? WHERE id=?",
            (meta.get("title"), meta.get("repo"), meta.get("provider"), now, r["id"]))
    con.commit()

COLLECTORS = {
    "delegations": collect_delegations,
    "mailbox": collect_mailbox,
    "titles": collect_titles,
}

