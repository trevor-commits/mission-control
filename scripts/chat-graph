CURSOR_ROOT = lambda: _env("CHAT_GRAPH_CURSOR_ROOT", "~/.cursor/projects")
HERMES_ROOT = lambda: _env("CHAT_GRAPH_HERMES_ROOT", "~/.hermes/sessions")
COPILOT_ROOT = lambda: _env("CHAT_GRAPH_COPILOT_ROOT", "~/.copilot/session-state")
def _default_register():
    gi = os.path.expanduser("~/Coding Projects/global-implementations/ENFORCEMENT_REQUESTS.md")
    if os.path.isfile(gi):
        return gi
    return os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))),
                        "ENFORCEMENT_REQUESTS.md")

REGISTER    = lambda: _env("CHAT_GRAPH_REGISTER", _default_register())

MAX_FILE_BYTES = 200 * 1024 * 1024
TOPIC_CAP = 8
TIER1_MAX_MESSAGES = 12
TIER1_MAX_BYTES = 32 * 1024

_UUID_RE = re.compile(r"[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}")
_CODE_RE = re.compile(r"\b(?:ER|GR|HB|HR)-\d{3}\b")
_SPAWNED_BY_RE    = re.compile(r"Spawned-by:\s*parent_provider=(\S+)\s+parent_id=(\S+)")
_SPAWNED_CHILD_RE = re.compile(r"Spawned-child:\s*provider=(\S+)\s+child_id=(\S+)")
_HANDOFF_RE = re.compile(r"Handoff:\s*(.+)")
_EXPLICIT_RESOLVED_RE = re.compile(r"(?im)^\s*Resolved:\s*([0-9a-f]{40})\s*$")
_EXPLICIT_RESOLVES_RE = re.compile(r"(?im)^\s*Resolves:\s*([0-9a-f]{40})\s*$")
_EXPLICIT_ANSWERS_RE = re.compile(r"(?im)^\s*Answers:\s*([0-9a-f]{40})\s*$")
# line prefilter: skip json.loads unless the raw line could carry a signal.
_PREFILTER = ("Spawned-", "Session Closeout", "ER-", "GR-")

def _prefilter(line):
    for s in _PREFILTER:
        if s in line:
            return True
    return bool(_UUID_RE.search(line))

def _sha1(s):
    return hashlib.sha1((s or "").encode("utf-8", "replace")).hexdigest()

def _open_hash(kind, source_key, text):
    return _sha1("%s:%s:%s" % (kind, source_key, text))

def _open_item_key(kind, sid, source_key):
    return _sha1("%s:%s:%s" % (kind, sid, source_key))

def _upsert_open_end(con, sid, kind, text, source_key=None, text_hash=None):
    now = int(time.time())
    source_key = source_key or text_hash or text
    item_key = _open_item_key(kind, sid, source_key)
    # Compatibility hash stays content-oriented so resumed/forked sessions can
    # deduplicate the same open item. Kind salting prevents cross-kind collision;
    # stable per-source identity lives separately in item_key.
    h = text_hash or _sha1("%s:%s" % (kind, text))
    row = con.execute("SELECT text, text_hash, resolved_at, last_change_type FROM open_ends "
                      "WHERE session_id=? AND kind=? AND item_key=?",
                      (sid, kind, item_key)).fetchone()
    if row is None:
        con.execute("""INSERT INTO open_ends(
                    session_id, kind, text, text_hash, item_key, first_seen_at,
                    updated_at, last_change_type) VALUES(?,?,?,?,?,?,?,'new')""",
                    (sid, kind, text, h, item_key, now, now))
    else:
        changed = row["text"] != text or row["text_hash"] != h
        reopened = row["resolved_at"] is not None
        change_type = "reopened" if reopened else ("updated" if changed else row["last_change_type"])
        updated = now if reopened or changed else None
        con.execute("""UPDATE open_ends SET resolved_at=NULL, text=?, text_hash=?,
                    updated_at=COALESCE(?, updated_at),
                    resolution_evidence_type=NULL, resolution_evidence_ref=NULL,
                    last_change_type=?
                    WHERE session_id=? AND kind=? AND item_key=?""",
                    (text, h, updated, change_type, sid, kind, item_key))
    return h

def _reconcile_open_kind(con, kind, active):
    """active maps (session_id, source_key) -> text. Missing source signals resolve."""
    active_items = set()
    for sid, source_key in active:
        _upsert_open_end(con, sid, kind, active[(sid, source_key)], source_key=source_key)
        active_items.add((sid, _open_item_key(kind, sid, source_key)))
    if kind == "chat_open_end":
        return
    for o in con.execute("SELECT session_id, text_hash, item_key FROM open_ends "
                         "WHERE kind=? AND resolved_at IS NULL", (kind,)).fetchall():
        if (o["session_id"], o["item_key"]) not in active_items:
            _resolve_open_end(con, o["session_id"], o["text_hash"],
                              "source_absent", kind)

def _reconcile_open_session_kind(con, sid, kind, active):
    """Per-transcript reconciliation; never resolves another session's signals."""
    active_items = set()
    for source_key, text in active.items():
        _upsert_open_end(con, sid, kind, text, source_key=source_key)
        active_items.add(_open_item_key(kind, sid, source_key))
    if kind == "chat_open_end":
        return
    for row in con.execute("SELECT text_hash, item_key FROM open_ends WHERE session_id=? "
                           "AND kind=? AND resolved_at IS NULL", (sid, kind)).fetchall():
        if row["item_key"] not in active_items:
            _resolve_open_end(con, sid, row["text_hash"], "source_absent", kind)

def _loose_action(kind):
    return {
        "closeout_handoff": "finish the handoff or connect the next chat",
        "register_unverified": "verify the tracked change",
        "todo_open": "check the repo todo item or mark it done",
        "nightly_finding": "review the nightly note and either fix or dismiss it",
        "repo_dirty": "open Git and decide whether to commit, push, merge, or ignore",
        "register_open": "land or verify the tracked request",
    }.get(kind or "", "decide whether this is still real work")

def _loose_severity(kind, text, age_days):
    low = (text or "").lower()
    try:
        age = int(age_days or 0)
    except (TypeError, ValueError):
        age = 0
    if kind in ("register_open", "register_unverified") and re.search(r"\b(p0|security|secret|token)\b", low):
        return "red"
    if kind == "repo_dirty" and ("detached" in low or "diverged" in low or "merge conflict" in low):
        return "red"
    if kind == "nightly_finding" and re.search(r"fail|failed|failure|blocked", low):
        return "red"
    if kind == "closeout_handoff" and age >= 21:
        return "grey"
    return "amber"

def _provider_key(provider, sid):
    pfx = "%s:" % (provider or "unknown")
    return sid if str(sid).startswith(pfx) else "%s%s" % (pfx, sid)

def _msg_text(rec):
    """Text of a user/assistant message ONLY. None for tool_result/system/other —
    hook/tool text must never feed signal extraction."""
    if not isinstance(rec, dict):
        return None
    msg, payload, data = rec.get("message"), rec.get("payload"), rec.get("data")
    role, typ, content = rec.get("role"), rec.get("type"), None
    if isinstance(msg, dict):
        role = role or msg.get("role"); content = msg.get("content")
    elif isinstance(payload, dict):
        role = role or payload.get("role"); content = payload.get("content")
    elif isinstance(data, dict) and typ in ("assistant.message", "user.message"):
        role = "assistant" if typ == "assistant.message" else "user"
        content = data.get("content")
    elif "content" in rec:
        content = rec.get("content")
    if role not in ("user", "assistant") and typ not in ("user", "assistant"):
        return None
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        parts = []
        for b in content:
            if isinstance(b, dict) and b.get("type") in ("text", "input_text", "output_text"):
                parts.append(b.get("text") or "")
            elif isinstance(b, str):
                parts.append(b)
        return "\n".join(parts)
    return None

def _assistant_role(rec):
    """Return True only for a first-party assistant message, never tool output."""
    if not isinstance(rec, dict):
        return False
    msg, payload = rec.get("message"), rec.get("payload")
    role, typ = rec.get("role"), rec.get("type")
    if isinstance(msg, dict):
        role = role or msg.get("role")
    elif isinstance(payload, dict):
        role = role or payload.get("role")
    return role == "assistant" or typ in ("assistant", "assistant.message")


def _user_role(rec):
    if not isinstance(rec, dict):
        return False
    msg, payload = rec.get("message"), rec.get("payload")
    role, typ = rec.get("role"), rec.get("type")
    if isinstance(msg, dict):
        role = role or msg.get("role")
    elif isinstance(payload, dict):
        role = role or payload.get("role")
    return role == "user" or typ in ("user", "user.message")

def _utf8_tail(value, limit):
    data = (value or "").encode("utf-8", "replace")
    if len(data) <= limit:
        return value or ""
    data = data[-limit:]
    while data:
        try:
            return data.decode("utf-8")
        except UnicodeDecodeError:
            data = data[1:]
    return ""


def _assistant_message_ref(rec, raw):
    for key in ("uuid", "id", "message_id", "platform_message_id", "timestamp"):
        value = rec.get(key) if isinstance(rec, dict) else None
        if value not in (None, ""):
            return _sha1("assistant-message:%s" % value)
    payload = rec.get("payload") if isinstance(rec, dict) else None
    if isinstance(payload, dict):
        for key in ("id", "message_id", "timestamp"):
            if payload.get(key) not in (None, ""):
                return _sha1("assistant-message:%s" % payload[key])
    return _sha1("assistant-message-content:%s" % raw)

def bounded_assistant_tail(messages, max_messages=TIER1_MAX_MESSAGES,
                           max_bytes=TIER1_MAX_BYTES, counters=None):
    """Return a sanitized, chronological assistant tail within both hard caps."""
    counters = counters if counters is not None else EgressCounters()
    selected, remaining = [], max(0, int(max_bytes))
    for rec in reversed(list(messages or [])):
        if len(selected) >= max(0, int(max_messages)) or remaining <= 0:
            break
        if not _assistant_role(rec):
            continue
        raw = _msg_text(rec)
        if raw is None:
            continue
        separator = 2 if selected else 0
        available = max(0, remaining - separator)
        raw = _utf8_tail(raw, available)
        if not raw:
            continue
        narrative = sanitize_text(raw, NARRATIVE, counters=counters)
        text = _utf8_tail(narrative.value, available)
        raw = _utf8_tail(raw, available)
        field_bytes = max(len(text.encode("utf-8")), len(raw.encode("utf-8")))
        selected.append({"role": "assistant", "content": text,
                         "action_content": raw,
                         "message_ref": _assistant_message_ref(rec, raw)})
        remaining -= field_bytes + separator
    selected.reverse()
    return selected

def read_assistant_messages(path, max_messages=TIER1_MAX_MESSAGES):
    """Read only the bounded assistant-message window from one JSONL transcript."""
    tail = deque(maxlen=max(1, int(max_messages)))
    with open(path, errors="strict") as f:
        for raw in f:
            raw = raw.strip()
            if not raw:
                continue
            try:
                rec = json.loads(raw)
            except ValueError:
                continue
            if _assistant_role(rec) and _msg_text(rec) is not None:
                tail.append(rec)
    return list(tail)

def _section_lines(text, heading):
    """Extract simple Markdown/plain-text section lines up to the next heading."""
    names = ("Re", "Answer", "Done", "Problems", "Next", "Details", "Outcome",
             "Verification", "Status", "Findings", "Residual risk", "Needs you")
    line_re = re.compile(r"(?im)^\s*(?:#{1,6}\s*)?(?:🔴\s*)?(?:\*\*)?%s"
                         r"(?:\*\*)?\s*:?[ \t]*$" % re.escape(heading))
    match = line_re.search(text or "")
    if not match:
        return []
    end = len(text)
    following = re.compile(r"(?im)^\s*(?:#{1,6}\s*)?(?:🔴\s*)?(?:\*\*)?"
                           r"(?:%s)(?:\*\*)?(?:\s*:[ \t]*.*|[ \t]*)$" %
                           "|".join(re.escape(n) for n in names))
    next_match = following.search(text, match.end())
    if next_match:
        end = next_match.start()
    out = []
    for raw in text[match.end():end].splitlines():
        line = re.sub(r"^\s*(?:[-*]|\d+[.)])\s+", "", raw).strip()
        if line:
            out.append(line)
    return out

def _prefixed_value_lines(text, heading):
    pattern = re.compile(r"(?im)^\s*(?:[-*]\s*)?%s\s*:\s*(.+?)\s*$" % re.escape(heading))
    return [m.group(1).strip() for m in pattern.finditer(text or "") if m.group(1).strip()]

def _structured_commands(text, counters=None):
    commands = []
    command_prefix = re.compile(
        r"^(?:(?:bash|sh|zsh|python3?|node|git|pnpm|npm|yarn|pytest|codex|"
        r"claude|chat-graph|cd|export|curl)(?:\s|$)|\./|/)", re.I)

    def add(value, allow_any=False):
        value = re.sub(r"^\s*\$\s*", "", value or "").strip()
        if (not value or value.startswith("#") or
                (not allow_any and not command_prefix.match(value))):
            return
        result = sanitize_text(value, ACTION, counters=counters)
        if not result.dropped and result.value not in commands:
            commands.append(result.value)

    for match in re.finditer(r"`([^`\r\n]{1,1000})`", text or ""):
        add(match.group(1))
    for match in re.finditer(
            r"```(?:bash|sh|zsh|shell)[ \t]*\n(.*?)\n?```", text or "",
            re.I | re.S):
        continued = ""
        for line in match.group(1).splitlines():
            if len(commands) >= 20:
                break
            value = line.strip()
            if not value or value.startswith("#"):
                continue
            if value.endswith("\\"):
                continued += value[:-1].rstrip() + " "
                continue
            add(continued + value, allow_any=True)
            continued = ""
        if continued and len(commands) < 20:
            add(continued.rstrip(), allow_any=True)
    return commands[:20]

def _structured_commits(text):
    commits = []
    pattern = re.compile(r"(?im)^\s*(?:[-*]\s*)?(?:Commit(?:s)?|SHA)\s*:\s*(.+)$")
    for line in pattern.findall(text or ""):
        for commit in re.findall(r"(?<![0-9a-f])[0-9a-f]{7,40}(?![0-9a-f])", line, re.I):
            value = commit.lower()
            if value not in commits:
                commits.append(value)
    return commits[:20]

def _structured_ids(text):
    ids = []
    for value in _UUID_RE.findall(text or "") + _CODE_RE.findall(text or ""):
        if value not in ids:
            ids.append(value)
    return ids[:40]

def _narrative_items(lines):
    """Keep claims, not status/commit/verification metadata, in `did`."""
    return [line for line in lines
            if not re.match(r"(?i)^(?:status|commit(?:s)?|sha|push|provenance|verification)\s*:",
                            line)][:20]


def _coherent_needs_you_items(lines):
    """Collapse one operator request block into one readable decision.

    Exact commands remain in structured anchors. Narrative cards keep the
    human instruction and omit fence/label/command fragments so one numbered
    procedure never becomes a dozen unrelated decisions.
    """
    narrative = []
    in_fence = False
    command = re.compile(
        r"^(?:```|Run:|Confirm:|cd\s|\./|/|(?:bash|sh|zsh|python3?|node|git|"
        r"pnpm|npm|yarn|pytest|codex|claude|chat-graph)(?:\s|$))", re.I)
    for value in lines:
        value = re.sub(r"\s+", " ", value or "").strip()
        if value.startswith("```"):
            in_fence = not in_fence
            continue
        if in_fence:
            continue
        if not value or command.match(value):
            continue
        narrative.append(value)
    if not narrative:
        return ["Review the source chat for the exact operator action."] if lines else []
    return [" ".join(narrative)[:2000]]


def _tier1_source_key(grammar, heading, text, occurrences):
    normalized = re.sub(r"\s+", " ", text or "").strip().casefold()
    digest = _sha1(normalized)
    key = (heading, digest)
    occurrence = occurrences.get(key, 0)
    occurrences[key] = occurrence + 1
    return "tier1:%s:%s:%s:%d" % (grammar, heading, digest, occurrence)

def _outcome_grammar(text):
    if (re.search(r"(?im)^\s*Goal\s*:\s*\S", text) and
            re.search(r"(?im)^\s*Runner\s*:\s*\S", text) and
            re.search(r"(?im)^\s*Model\s*:\s*\S", text)):
        return "handoff_packet", "authored_handoff"
    if (re.search(r"(?im)^\s*(?:#{1,6}\s*)?(?:\*\*)?Audited Chat(?:\*\*)?\s*$", text) or
            (re.search(r"(?im)^\s*(?:#{1,6}\s*)?(?:\*\*)?Findings(?:\*\*)?\s*$", text) and
             re.search(r"(?im)review(?: result)?\s*:", text))):
        return "audit_report", "audit_report"
    if (re.search(r"(?im)^\s*(?:#{1,6}\s*)?(?:\*\*)?Re\s*:(?:\*\*)?", text) and
            re.search(r"(?im)^\s*(?:#{1,6}\s*)?(?:\*\*)?Done(?:\*\*)?\s*:?[ \t]*$", text)):
        return "reply_v5", "execution_closeout"
    if (re.search(r"(?im)^\s*(?:#{1,6}\s*)?(?:\*\*)?(?:Outcome|Session Closeout)"
                  r"(?:\*\*)?\s*:?[ \t]*$", text) or
            (re.search(r"(?im)^\s*(?:[-*]\s*)?Status\s*:\s*\S", text) and
             re.search(r"(?im)^\s*(?:[-*]\s*)?(?:Commit|Verification|Provenance)\s*:", text))):
        return "codex_closeout", "execution_closeout"
    return "unstructured", "unstructured"

def tier1_parse_outcome(session_id, provider, messages):
    """Parse a deterministic outcome card from a bounded assistant-only tail.

    This function performs no I/O, model, or network work. Narrative and anchors
    are derived only from the supplied structured source text.
    """
    counters = EgressCounters()
    tail = bounded_assistant_tail(messages, counters=counters)
    texts = [m["content"] for m in tail]
    action_texts = [m["action_content"] for m in tail]
    joined = "\n\n".join(texts)
    tail_bytes = len(joined.encode("utf-8"))
    selected_index = len(texts) - 1
    selected_text = texts[-1] if texts else ""
    grammar, classification = _outcome_grammar(selected_text)
    if grammar == "unstructured":
        # Tool chatter is already excluded, but a later conversational assistant
        # turn can follow a real closeout. Keep the newest structured card in the
        # bounded window while hashing the full tail for cache/version identity.
        for index in range(len(texts) - 2, -1, -1):
            candidate_grammar, candidate_class = _outcome_grammar(texts[index])
            if candidate_grammar != "unstructured":
                selected_index, selected_text = index, texts[index]
                grammar, classification = candidate_grammar, candidate_class
                break
    safe_provider = provider if provider in CHAT_PROVIDERS else "unknown"
    card_id = _sha1("outcome-card:%s" % session_id)
    did = []
    open_work = []
    occurrences = {}

    if classification == "authored_handoff":
        did = ["Authored a handoff packet"]
    elif classification == "audit_report":
        did = ["Completed an audit report"]
    elif grammar == "reply_v5":
        did = _narrative_items(_section_lines(selected_text, "Done"))
        for heading in ("Needs you", "Problems", "Next"):
            section = heading.lower().replace(" ", "_")
            values = _section_lines(selected_text, heading)[:20]
            if heading == "Needs you":
                values = _coherent_needs_you_items(values)
            for value in values:
                source_key = _tier1_source_key(grammar, section, value, occurrences)
                open_work.append({
                    "item_key": _open_item_key("chat_open_end", session_id, source_key),
                    "source_key": source_key,
                    "section": section,
                    "text": safe_text(value, NARRATIVE, counters=counters),
                })
    elif grammar == "codex_closeout":
        did = _narrative_items(_section_lines(selected_text, "Outcome"))
        if not did:
            did = _narrative_items(_prefixed_value_lines(selected_text, "Outcome"))
        if not did:
            did = ["Reported a structured execution closeout"]
        for heading in ("Problems", "Next"):
            section = heading.lower()
            for value in _section_lines(selected_text, heading)[:20]:
                source_key = _tier1_source_key(grammar, section, value, occurrences)
                open_work.append({
                    "item_key": _open_item_key("chat_open_end", session_id, source_key),
                    "source_key": source_key,
                    "section": section,
                    "text": safe_text(value, NARRATIVE, counters=counters),
                })

    finalized = False
    if grammar in ("reply_v5", "audit_report", "handoff_packet"):
        finalized = True
    elif grammar == "codex_closeout":
        finalized = bool(re.search(
            r"(?im)^\s*(?:[-*]\s*)?Status\s*:\s*(?:complete|completed|done|pass|passed|review-clean)\s*$",
            selected_text))

    selected_action_text = action_texts[selected_index] if action_texts else ""
    anchors = {
        "commits": _structured_commits(selected_text),
        "commands": _structured_commands(selected_action_text, counters=counters),
        "ids": _structured_ids(selected_text),
    }
    markers = [
        {"type": marker_type, "item_key": item_key,
         "marker_ref": "%s:%s:%s" % (message["message_ref"], marker_type, item_key),
         "message_index": message_index}
        for message_index, message in enumerate(tail)
        for marker_type, regex in (("same_session", _EXPLICIT_RESOLVED_RE),
                                   ("downstream", _EXPLICIT_RESOLVES_RE))
        for item_key in regex.findall(message["action_content"])
    ]
    tail_hash = _sha1(json.dumps({
        "parser_version": TIER1_PARSER_VERSION,
        "narrative": joined,
        "anchors": anchors,
        "markers": markers,
        "selected_message_ref": (tail[selected_index]["message_ref"] if tail else None),
    }, ensure_ascii=True, sort_keys=True))
    evidence = {
        "grammar": grammar,
        "did": did,
        "open_work": open_work,
        "anchors": anchors,
    }
    return {
        "card_id": card_id,
        "session_id": session_id,
        "provider": safe_provider,
        "parser_version": TIER1_PARSER_VERSION,
        "classification": classification,
        "grammar": grammar,
        "did": did,
        "open_work": open_work,
        "anchors": anchors,
        "tail_hash": tail_hash,
        "extraction_status": "structured" if grammar != "unstructured" else "unparsed",
        "finalized": finalized,
        "method": "tier1",
        "confidence": 1.0 if grammar != "unstructured" else 0.0,
        "source_span": {"message_count": len(tail), "bytes": tail_bytes,
                        "selected_message_index": selected_index,
                        "selected_is_latest": selected_index == len(texts) - 1,
                        "selected_message_ref": (tail[selected_index]["message_ref"]
                                                 if tail else None),
                        "selected_content_hash": (_sha1(selected_text)
                                                  if tail else None),
                        "selected_bytes": len(selected_text.encode("utf-8"))},
        "evidence_fingerprint": _sha1(json.dumps(evidence, sort_keys=True)),
        "egress_counters": counters.snapshot(),
        "resolution_markers": markers,
    }

def _apply_outcome_resolutions(con, sid, card):
    current_open_keys = {
        item.get("item_key") for item in (card.get("open_work") or [])
        if isinstance(item, dict) and item.get("item_key")
    }
    for marker in card.get("resolution_markers") or []:
        if not isinstance(marker, dict):
            continue
        item_key = marker.get("item_key")
        marker_type = marker.get("type")
        marker_ref = marker.get("marker_ref")
        if (not item_key or not marker_ref or con.execute(
                "SELECT 1 FROM outcome_resolution_markers WHERE marker_ref=?",
                (marker_ref,)).fetchone()):
            continue
        if (marker_type == "same_session" and
                int(marker.get("message_index", -1)) < int(
                    card.get("source_span", {}).get("selected_message_index", -1))):
            continue
        if (marker_type == "same_session" and
                int(marker.get("message_index", -1)) == int(
                    card.get("source_span", {}).get("selected_message_index", -1)) and
                item_key in current_open_keys):
            # One selected card cannot both reopen and resolve the same key.
            # Preserve it as open until a non-contradictory later marker.
            continue
        resolved_sid = None
        if marker_type == "same_session":
            if _resolve_open_end_key(con, sid, item_key,
                                     "same_session_explicit", sid):
                resolved_sid = sid
        elif marker_type == "downstream":
            row = con.execute("""SELECT o.session_id FROM open_ends o
            WHERE o.item_key=? AND o.resolved_at IS NULL AND o.session_id != ?
              AND EXISTS(
                SELECT 1 FROM edges e
                WHERE e.status='active' AND e.confidence >= 0.95
                  AND e.type IN ('spawned','continues')
                  AND ((e.type='spawned' AND e.src=o.session_id AND e.dst=?)
                    OR (e.type='continues' AND e.src=? AND e.dst=o.session_id))
                  AND NOT EXISTS(SELECT 1 FROM suppressions s
                    WHERE s.src=e.src AND s.dst=e.dst AND s.type=e.type))
            ORDER BY o.id LIMIT 1""", (item_key, sid, sid, sid)).fetchone()
            if row and _resolve_open_end_key(
                    con, row["session_id"], item_key, "downstream_explicit", sid):
                resolved_sid = row["session_id"]
        if resolved_sid:
            con.execute("""INSERT INTO outcome_resolution_markers(
                marker_ref,session_id,item_key,marker_type,applied_at)
                VALUES(?,?,?,?,?)""",
                (marker_ref, resolved_sid, item_key, marker_type, int(time.time())))

def _persist_tier1_outcome(con, sid, provider, messages, path):
    card = tier1_parse_outcome(sid, provider, messages)
    if card["source_span"]["message_count"] == 0:
        return None
    now = int(time.time())
    version_id = _sha1("outcome-version:%s:%s" % (sid, card["tail_hash"]))
    prior_observation = con.execute("""SELECT o.tail_hash,v.outcome_json
        FROM session_outcome_observations o
        JOIN session_outcomes v ON v.id=o.outcome_id
        WHERE o.session_id=? AND v.method='tier1'
        ORDER BY o.observation_id DESC LIMIT 1""",
        (sid,)).fetchone()
    exists = con.execute("""SELECT id FROM session_outcomes
        WHERE session_id=? AND tail_hash=? AND method='tier1'""",
                         (sid, card["tail_hash"])).fetchone()
    if not exists:
        con.execute("""INSERT INTO session_outcomes(
                    id, session_id, provider, tail_hash, outcome_json,
                    extraction_status, finalized, updated_at, method, variant, confidence,
                    source_start, source_end, source_span, evidence_fingerprint, created_at)
                    VALUES(?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)""",
                    (version_id, sid, card["provider"], card["tail_hash"],
                     json.dumps(card, sort_keys=True), card["extraction_status"],
                     1 if card["finalized"] else 0, now, "tier1", "tier1",
                     card["confidence"],
                     "assistant-tail", "assistant-tail-end",
                     json.dumps(card["source_span"], sort_keys=True),
                     card["evidence_fingerprint"], now))
    if prior_observation is None or prior_observation["tail_hash"] != card["tail_hash"]:
        con.execute("""INSERT INTO session_outcome_observations(
            session_id,outcome_id,tail_hash,observed_at,finalized,evidence_fingerprint)
            VALUES(?,?,?,?,?,?)""",
            (sid, version_id, card["tail_hash"], now,
             1 if card["finalized"] else 0, card["evidence_fingerprint"]))
    prior_selected = None
    prior_card = None
    if prior_observation is not None:
        try:
            prior_card = json.loads(prior_observation["outcome_json"])
            prior_selected = prior_card.get("source_span", {}).get(
                "selected_message_ref")
        except (TypeError, ValueError):
            prior_selected, prior_card = None, None
    prior_parser_version = int((prior_card or {}).get("parser_version") or 1)
    parser_changed = prior_parser_version < TIER1_PARSER_VERSION
    same_selected_source = bool(
        prior_selected and
        prior_selected == card["source_span"].get("selected_message_ref") and
        (prior_card or {}).get("source_span", {}).get("selected_content_hash") and
        (prior_card or {}).get("source_span", {}).get("selected_content_hash") ==
        card["source_span"].get("selected_content_hash"))
    # Persist a genuinely new structured closeout even if harmless chatter
    # follows it; do not reuse an older selected closeout merely because the
    # surrounding bounded tail changed.
    if (prior_observation is None or
            prior_selected != card["source_span"].get("selected_message_ref") or
            parser_changed):
        for item in card.get("open_work", []):
            _upsert_open_end(con, sid, "chat_open_end", item["text"],
                             source_key=item["source_key"])
    old_needs = [item for item in (prior_card or {}).get("open_work", [])
                 if isinstance(item, dict) and item.get("section") == "needs_you"]
    new_needs = [item for item in card.get("open_work", [])
                 if isinstance(item, dict) and item.get("section") == "needs_you"]
    migration_compaction = (
        parser_changed and same_selected_source and
        (prior_card or {}).get("grammar") == "reply_v5" and
        card.get("grammar") == "reply_v5" and
        len(old_needs) >= 1 and len(new_needs) == 1 and
        {item.get("item_key") for item in old_needs} !=
        {item.get("item_key") for item in new_needs})
    if migration_compaction:
        current_keys = {item.get("item_key") for item in card.get("open_work", [])}
        for old_item in old_needs:
            old_key = old_item.get("item_key") if isinstance(old_item, dict) else None
            if old_key and old_key not in current_keys:
                _resolve_open_end_key(
                    con, sid, old_key, "parser_migration",
                    "tier1:v%d-to-v%d" % (prior_parser_version, TIER1_PARSER_VERSION))
    _apply_outcome_resolutions(con, sid, card)
    return card

def _rec_uuid(rec):
    for k in ("uuid", "id", "message_id"):
        if rec.get(k):
            return rec[k]
    p = rec.get("payload")
    return p.get("id") if isinstance(p, dict) else None

_REGISTER_CACHE = {}
def _register_status(code):
    """'verified' / 'unverified' / None(no row). Register file parsed once."""
    rows = _REGISTER_CACHE.get("rows")
    if rows is None:
        rows = {}
        try:
            with open(REGISTER()) as f:
                for ln in f:
                    for m in _CODE_RE.finditer(ln):
                        c = m.group(0)
                        v = bool(re.search(r"verified", ln, re.I))
                        if c not in rows or v:
                            rows[c] = "verified" if v else "unverified"
        except OSError:
            pass
        _REGISTER_CACHE["rows"] = rows
    return rows.get(code)

def _log_scan_error(path, lineno, reason):
    ensure_dir(os.path.dirname(scanlog_path()))
    with open(scanlog_path(), "a") as f:
        f.write("%d %s:%d: %s\n" % (int(time.time()), path, lineno, reason))

def _set_meta(con, k, v):
    con.execute("INSERT OR REPLACE INTO meta VALUES(?,?)", (k, str(v)))

def _get_meta(con, k, default=None):
    r = con.execute("SELECT value FROM meta WHERE key=?", (k,)).fetchone()
    return r["value"] if r else default

def _enumerate_files():
    """(path, provider, sid, mtime_ns, size), newest-first."""
    newest = {}
    specs = (
        ("claude", CLAUDE_ROOT(), "*.jsonl"),
        ("codex", CODEX_ROOT(), "rollout-*.jsonl"),
        ("cursor", CURSOR_ROOT(), "*.jsonl"),
        ("copilot", COPILOT_ROOT(), "*.jsonl"),
    )
    for provider, root, pattern in specs:
        if not os.path.isdir(root):
            continue
        for path in glob.glob(os.path.join(root, "**", pattern), recursive=True):
            if provider in ("claude", "cursor") and "subagents" in os.path.relpath(
                    path, root).split(os.sep):
                continue
            try:
                st = os.stat(path)
            except OSError:
                continue
            match = _UUID_RE.search(path)
            name = os.path.basename(path)
            stem = name[:-6] if name.endswith(".jsonl") else name
            if match:
                sid = match.group(0)
            elif provider == "copilot" and stem == "events":
                sid = os.path.basename(os.path.dirname(path))
            elif provider == "codex" and stem.startswith("rollout-"):
                sid = stem[len("rollout-"):]
            else:
                sid = stem
            key = (provider, sid)
            current = newest.get(key)
            row = (path, provider, sid, st.st_mtime_ns, st.st_size)
            if current is None or st.st_mtime_ns > current[3]:
                newest[key] = row
    out = list(newest.values())
    out.sort(key=lambda t: t[3], reverse=True)
    return out


def _scan_hermes_state(con, full=False):
    """Ingest changed Hermes sessions from its real read-only SQLite store."""
    path = HERMES_STATE_DB()
    if not os.path.isfile(path):
        return 0
    stored_parser = int(_get_meta(con, "hermes_parser_version", 0) or 0)
    parser_upgrade = stored_parser < TIER1_PARSER_VERSION
    cursor = 0 if full or parser_upgrade else int(
        _get_meta(con, "hermes_message_cursor", 0) or 0)
    try:
        source = sqlite3.connect("file:%s?mode=ro" % path, uri=True, timeout=5)
        source.row_factory = sqlite3.Row
        # Pin one read snapshot and its exact high-water before discovering
        # changed sessions. A concurrent insert after this point belongs to the
        # next ingest and must never be advanced past unseen.
        source.execute("BEGIN")
        max_row = source.execute(
            "SELECT COALESCE(MAX(id),0) AS n FROM messages").fetchone()
        high_water = int(max_row["n"])
        stored_anchor = _get_meta(con, "hermes_message_cursor_anchor")
        if cursor:
            anchor_row = source.execute("""SELECT id,session_id,role,content,
                timestamp,active FROM messages WHERE id=?""", (cursor,)).fetchone()
            current_anchor = (_sha1(json.dumps([
                anchor_row["id"], anchor_row["session_id"], anchor_row["role"],
                anchor_row["content"], anchor_row["timestamp"], anchor_row["active"],
            ], ensure_ascii=True)) if anchor_row else None)
            # A replaced/restored database may restart IDs or reuse the prior
            # high-water. Missing or changed anchor evidence forces one bounded
            # rebuild instead of silently skipping the restored corpus.
            if high_water < cursor or not stored_anchor or current_anchor != stored_anchor:
                cursor = 0
        rows = source.execute("""SELECT DISTINCT session_id FROM messages
            WHERE active=1 AND role='assistant' AND id>? AND id<=?
            ORDER BY session_id""", (cursor, high_water)).fetchall()
        scanned = 0
        for session in rows:
            sid = session["session_id"]
            meta = source.execute("""SELECT title,cwd,started_at FROM sessions
                WHERE id=?""", (sid,)).fetchone()
            tail = source.execute("""SELECT id,role,content,timestamp FROM messages
                WHERE session_id=? AND active=1 AND role='assistant' AND id<=?
                ORDER BY id DESC LIMIT ?""",
                (sid, high_water, TIER1_MAX_MESSAGES)).fetchall()
            messages = [dict(row) for row in reversed(tail)]
            if not messages:
                continue
            touch_session(con, sid, provider="hermes",
                          title=(meta["title"] if meta else None))
            last_activity = int(float(messages[-1].get("timestamp") or 0))
            repo = os.path.basename((meta["cwd"] if meta else "") or "")
            con.execute("""UPDATE sessions SET last_activity=?,
                repo=COALESCE(NULLIF(repo,''),?) WHERE id=?""",
                (str(last_activity), repo, sid))
            _persist_tier1_outcome(con, sid, "hermes", messages, path)
            scanned += 1
        _set_meta(con, "hermes_message_cursor", high_water)
        high_row = source.execute("""SELECT id,session_id,role,content,
            timestamp,active FROM messages WHERE id=?""", (high_water,)).fetchone()
        high_anchor = (_sha1(json.dumps([
            high_row["id"], high_row["session_id"], high_row["role"],
            high_row["content"], high_row["timestamp"], high_row["active"],
        ], ensure_ascii=True)) if high_row else "")
        _set_meta(con, "hermes_message_cursor_anchor", high_anchor)
        _set_meta(con, "hermes_parser_version", TIER1_PARSER_VERSION)
        source.rollback()
        source.close()
        return scanned
    except sqlite3.Error:
        _STALE_PROVIDERS.add("hermes")
        return 0

def _scan_one(con, path, provider, sid, known, mtime_s):
    """Scan one transcript file into the DB. Returns (n_signals, n_line_errors)."""
    blob_parts, spawn_targets, first_uuid = [], set(), None
    assistant_tail = deque(maxlen=TIER1_MAX_MESSAGES)
    answer_markers = []
    record_positions = {}
    n_lerr, got_first = 0, False
    with open(path, errors="strict") as f:
        for lineno, raw in enumerate(f, 1):
            passed = _prefilter(raw)
            s = raw.strip()
            if not s:
                continue
            try:
                rec = json.loads(s)
            except ValueError:
                if passed:
                    n_lerr += 1
                    _log_scan_error(path, lineno, "json decode error")
                continue
            txt = _msg_text(rec)
            if txt is None:
                continue
            if _assistant_role(rec):
                assistant_tail.append(rec)
                record_positions[_assistant_message_ref(rec, txt)] = lineno
            elif _user_role(rec):
                for item_key in _EXPLICIT_ANSWERS_RE.findall(txt):
                    answer_markers.append((item_key, _assistant_message_ref(rec, txt), lineno))
            if not got_first:
                u = _rec_uuid(rec)
                if u:
                    first_uuid, got_first = u, True
            if passed:
                blob_parts.append(txt)
    blob = "\n".join(blob_parts)
    n_sig, open_now, topic_counts = 0, {}, {}
    for m in _SPAWNED_BY_RE.finditer(blob):
        parent = m.group(2); spawn_targets.add(parent)
        touch_session(con, parent, provider=m.group(1))
        upsert_edge(con, parent, sid, "spawned", "spawn_header", 1.0, {"path": path}); n_sig += 1
    for m in _SPAWNED_CHILD_RE.finditer(blob):
        child = m.group(2); spawn_targets.add(child)
        touch_session(con, child, provider=m.group(1))
        upsert_edge(con, sid, child, "spawned", "spawn_header", 0.95, {"path": path}); n_sig += 1
    for tok in set(_UUID_RE.findall(blob)):
        if tok != sid and tok in known and tok not in spawn_targets:
            upsert_edge(con, sid, tok, "references", "scan", 0.9, {"path": path}); n_sig += 1
    for m in _CODE_RE.finditer(blob):
        c = m.group(0); topic_counts[c] = topic_counts.get(c, 0) + 1
    for c in sorted(topic_counts, key=lambda k: (-topic_counts[k], k))[:TOPIC_CAP]:
        con.execute("INSERT OR IGNORE INTO session_topics(session_id, code) VALUES(?,?)", (sid, c))
        n_sig += 1
        if _register_status(c) == "unverified":
            open_now.setdefault("register_unverified", {})["register:%s" % c] = c
    if "Session Closeout" in blob:
        m = _HANDOFF_RE.search(blob)
        if m:
            txt = m.group(1).strip()
            if len(txt) > 3 and txt.lower() not in ("none", "n/a", "na", "-"):
                open_now.setdefault("closeout_handoff", {})["closeout_handoff"] = txt
                con.execute("UPDATE sessions SET closeout_seen=1 WHERE id=?", (sid,))
    # Reconcile only source-backed scanner kinds. `chat_open_end` is deliberately
    # absent: a finalized extraction omitting an item is never resolution proof.
    closeout_seen = con.execute("SELECT closeout_seen FROM sessions WHERE id=?", (sid,)).fetchone()
    if open_now.get("closeout_handoff") or (closeout_seen and closeout_seen["closeout_seen"]):
        _reconcile_open_session_kind(con, sid, "closeout_handoff",
                                     open_now.get("closeout_handoff", {}))
    _reconcile_open_session_kind(con, sid, "register_unverified",
                                 open_now.get("register_unverified", {}))
    n_sig += sum(len(v) for v in open_now.values())
    con.execute("UPDATE sessions SET provider=COALESCE(NULLIF(provider,''),?), "
                "last_activity=?, first_msg_uuid=COALESCE(first_msg_uuid,?) WHERE id=?",
                (provider, str(mtime_s), first_uuid, sid))
    persisted_card = None
    if assistant_tail:
        persisted_card = _persist_tier1_outcome(con, sid, provider, list(assistant_tail), path)
    selected_ref = ((persisted_card or {}).get("source_span") or {}).get(
        "selected_message_ref")
    selected_position = record_positions.get(selected_ref, -1)
    for item_key, marker_ref, marker_position in answer_markers:
        if marker_position <= selected_position:
            continue
        evidence_ref = "%s:answer:%s" % (sid, marker_ref)
        if con.execute("SELECT 1 FROM outcome_resolution_markers WHERE marker_ref=?",
                       (evidence_ref,)).fetchone():
            continue
        if _resolve_open_end_key(con, sid, item_key, "answering_user_turn", evidence_ref):
            con.execute("""INSERT INTO outcome_resolution_markers(
                marker_ref,session_id,item_key,marker_type,applied_at)
                VALUES(?,?,?,?,?)""",
                (evidence_ref, sid, item_key, "answering_user_turn", int(time.time())))
    return n_sig, n_lerr

def _resume_fork(con):
    """Sessions sharing a first-message uuid -> continues (later->earlier) 1.0;
    dedupe unresolved open_ends across the fork group by text_hash."""
    now = int(time.time())
    groups = {}
    for r in con.execute("SELECT id, first_msg_uuid, last_activity FROM sessions "
                        "WHERE first_msg_uuid IS NOT NULL AND first_msg_uuid != ''"):
        try:
            la = int(r["last_activity"] or 0)
        except (TypeError, ValueError):
            la = 0
        groups.setdefault(r["first_msg_uuid"], []).append((r["id"], la))
    for members in groups.values():
        if len(members) < 2:
            continue
        members.sort(key=lambda m: m[1])  # earliest first
        earliest = members[0][0]
        for mid, _ in members[1:]:
            upsert_edge(con, mid, earliest, "continues", "resume-fork", 1.0, {})
        seen = set()
        for mid, _ in members:
            for o in con.execute("SELECT text_hash FROM open_ends WHERE session_id=? "
                                "AND resolved_at IS NULL", (mid,)).fetchall():
                th = o["text_hash"]
                if th in seen:
                    _resolve_open_end(con, mid, th, "fork_dedup", earliest)
                else:
                    seen.add(th)

def _progress(i, total, errors, elapsed, tty):
    pct = int(100 * i / total) if total else 100
    eta = "?"
    if i and total:
        rem = (elapsed / i) * (total - i)
        eta = "%dm%02ds" % (int(rem) // 60, int(rem) % 60)
    msg = "[scan] %d/%d · %d%% · ETA %s · errors %d" % (i, total, pct, eta, errors)
    sys.stderr.write(("\r" + msg) if tty else (msg + "\n"))
    sys.stderr.flush()

def scan_transcripts(con, full=False, limit_files=None):
    """One incremental pass. Returns (files_errored, files_considered)."""
    ensure_dir(os.path.dirname(scanlog_path()))
    files = _enumerate_files()
    cur = {r["path"]: (r["mtime"], r["size"], int(r["parser_version"] or 0))
           for r in con.execute(
               "SELECT path, mtime, size, parser_version FROM file_cursors")}
    todo = [t for t in files if full or cur.get(t[0]) != (
        t[3], t[4], TIER1_PARSER_VERSION)]
    if limit_files is not None:
        todo = todo[:limit_files]
    if not todo:
        sys.stderr.write("[scan] 0 new/changed files\n")
    known = set(t[2] for t in files)
    for r in con.execute("SELECT id FROM sessions"):
        known.add(r["id"])
    known.discard(None)
    total, ferr, scanned, yield_n = len(todo), 0, 0, 0
    start, t_last, tty = time.time(), time.time(), sys.stderr.isatty()
    for i, (path, provider, sid, mtime, size) in enumerate(todo, 1):
        if size > MAX_FILE_BYTES:
            sys.stderr.write("[scan] skip >200MB: %s\n" % path)
            _log_scan_error(path, 0, "file >200MB skipped")
            continue
        touch_session(con, sid, provider=provider)
        try:
            n_sig, _ = _scan_one(con, path, provider, sid, known, mtime // 1_000_000_000)
        except (OSError, UnicodeDecodeError) as e:
            ferr += 1
            _log_scan_error(path, 0, "file error: %s" % e)
            con.rollback()
            continue
        con.execute("""INSERT INTO file_cursors(path,mtime,size,parser_version)
                    VALUES(?,?,?,?) ON CONFLICT(path) DO UPDATE SET
                    mtime=excluded.mtime,size=excluded.size,
                    parser_version=excluded.parser_version""",
                    (path, mtime, size, TIER1_PARSER_VERSION))
        con.commit()  # ONE transaction per file -> Ctrl-C-safe, resumable
        scanned += 1
        if n_sig > 0:
            yield_n += 1
        if time.time() - t_last >= 2 or i == total:
            _progress(i, total, ferr, time.time() - start, tty)
            t_last = time.time()
    hermes_scanned = _scan_hermes_state(con, full=full)
    _resume_fork(con)
    _set_meta(con, "scan_files_scanned", scanned + hermes_scanned)
    _set_meta(con, "scan_files_yield", yield_n)
    con.commit()
    return ferr, total

# ---- export + validate ----------------------------------------------------
def _resume_cmd(provider, sid):
    if provider == "codex":
        return "codex resume %s" % sid
    if provider == "claude":
        return "claude --resume %s" % sid
    if provider == "repo":
        return ""
    return "chat-source full %s" % sid

_REPO_ANNOTATIONS_CACHE = None
def _repo_annotations():
    """From `scan-unfinished-work --json` (env CHAT_GRAPH_SCAN_CMD override).
    Returns (annotations_list, notes_list)."""
    global _REPO_ANNOTATIONS_CACHE
    if _REPO_ANNOTATIONS_CACHE is not None:
        return _REPO_ANNOTATIONS_CACHE
    cmd = os.environ.get("CHAT_GRAPH_SCAN_CMD")
    exe = cmd.split() if cmd else None
    if not exe:
        default = os.path.join(os.path.dirname(os.path.abspath(__file__)), "scan-unfinished-work")
        if os.path.exists(default):
            exe = [default, "--json"]
    if not exe:
        return [], ["scan-unfinished-work absent"]
    try:
        out = subprocess.run(exe, capture_output=True, text=True, timeout=120)
        if out.returncode not in (0, 1):
            _REPO_ANNOTATIONS_CACHE = ([], ["scan-unfinished-work exit %d" % out.returncode])
            return _REPO_ANNOTATIONS_CACHE
        data = json.loads(out.stdout)
        if isinstance(data, dict):
            data = data.get("repos") or data.get("data") or []
        _REPO_ANNOTATIONS_CACHE = (data if isinstance(data, list) else [], [])
        return _REPO_ANNOTATIONS_CACHE
    except Exception as e:
        _REPO_ANNOTATIONS_CACHE = ([], ["scan-unfinished-work failed: %s" % e])
        return _REPO_ANNOTATIONS_CACHE

def _repo_node(con, repo):
    sid = "repo:%s" % repo
    touch_session(con, sid, provider="repo", title="Repo: %s" % repo, first_prompt="Repository work ledger")
    con.execute("UPDATE sessions SET repo=COALESCE(NULLIF(repo,''), ?) WHERE id=?", (repo, sid))
    return sid

def _repo_paths_from_env():
    roots = os.environ.get("CHAT_GRAPH_REPO_ROOTS")
    if not roots:
        return None
    return [p for p in roots.split(os.pathsep) if p]

def _tracked_repo_paths():
    env_paths = _repo_paths_from_env()
    if env_paths is not None:
        return env_paths
    paths = set()
    here_repo = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    for p in (here_repo, os.path.join(CODING_ROOT(), "global-implementations")):
        if os.path.isdir(p):
            paths.add(p)
    repos, _ = _repo_annotations()
    for r in repos:
        name = r.get("repo") if isinstance(r, dict) else None
        if name:
            p = os.path.join(CODING_ROOT(), name)
            if os.path.isdir(p):
                paths.add(p)
    return sorted(paths)

def collect_todo_open(con):
    active, n = {}, 0
    for repo_path in _tracked_repo_paths():
        todo = os.path.join(repo_path, "todo.md")
        if not os.path.isfile(todo):
            continue
        repo = os.path.basename(repo_path)
        sid = _repo_node(con, repo)
        in_work, cap = False, 0
        try:
            with open(todo, errors="replace") as f:
                for line in f:
                    hm = re.match(r"^\s*##+\s+(.+?)\s*$", line)
                    if hm:
                        h = hm.group(1).lower()
                        in_work = (("work" in h or "active" in h or "todo" in h)
                                   and not re.search(r"completed|done|history|log|evidence|suggest|feedback|linear", h))
                        continue
                    if not in_work:
                        continue
                    m = re.match(r"^\s*-\s+\[\s\]\s+(.+?)\s*$", line)
                    if not m:
                        continue
                    item = re.sub(r"\s+", " ", m.group(1)).strip()
                    if not item:
                        continue
                    text = "%s: %s" % (repo, item[:220])
                    cap += 1
                    active[(sid, "todo:%s:%d" % (repo, cap))] = text
                    if cap >= 50:
                        break
        except OSError:
            continue
    _reconcile_open_kind(con, "todo_open", active)
    return len(active) + n

def collect_nightly_findings(con):
    files = sorted(glob.glob(os.path.expanduser(NIGHTLY_GLOB())),
                   key=lambda p: os.path.getmtime(p) if os.path.exists(p) else 0,
                   reverse=True)
    active = {}
    if files:
        path = files[0]
        sid = _repo_node(con, "nightly-review")
        try:
            with open(path, errors="replace") as f:
                for lineno, line in enumerate(f, 1):
                    s = line.strip()
                    if not re.match(r"^[-*]\s+", s):
                        continue
                    if not re.search(r"loose end|fail|failed|failure|blocked|needs|open", s, re.I):
                        continue
                    repo_m = re.search(r"(?:Coding Projects/|repo[:=]\s*`?)([A-Za-z0-9_.-]+)", s)
                    item_sid = _repo_node(con, repo_m.group(1)) if repo_m else sid
                    text = re.sub(r"\s+", " ", re.sub(r"^[-*]\s+", "", s))[:240]
                    active[(item_sid, "%s:%d" % (path, lineno))] = text
        except OSError:
            pass
    _reconcile_open_kind(con, "nightly_finding", active)
    return len(active)

def collect_repo_dirty(con):
    repos, _ = _repo_annotations()
    active = {}
    for r in repos:
        if not isinstance(r, dict):
            continue
        repo = r.get("repo") or ""
        if not repo:
            continue
        sid = _repo_node(con, repo)
        items = []
        if r.get("dirty"):
            items.append(("dirty", "%s: %s files uncommitted" % (repo, r.get("dirty_files", "?"))))
        if int(r.get("ahead") or 0) > 0:
            items.append(("ahead", "%s: %s unpushed commits" % (repo, r.get("ahead"))))
        if r.get("detached"):
            items.append(("detached", "%s: detached HEAD needs a decision" % repo))
        for b in r.get("branches") or []:
            name = b.get("name") if isinstance(b, dict) else ""
            age = b.get("age_days") if isinstance(b, dict) else None
            if name:
                items.append(("branch:%s" % name,
                              "%s: branch %s is %sd old and unmerged" %
                              (repo, name, age if age is not None else "?")))
        for source_key, text in items:
            active[(sid, source_key)] = text
    _reconcile_open_kind(con, "repo_dirty", active)
    return len(active)

def collect_register_open(con):
    active = {}
    try:
        with open(REGISTER(), errors="replace") as f:
            for line in f:
                if "ER-" not in line or not line.lstrip().startswith("|"):
                    continue
                codes = _CODE_RE.findall(line)
                if not codes:
                    continue
                low = line.lower()
                if re.search(r"\|\s*(verified|landed|done|closed)\s*\|", low):
                    continue
                sid = _repo_node(con, "global-implementations")
                text = re.sub(r"\s+", " ", line.strip(" |\n"))[:240]
                for code in codes[:1]:
                    active[(sid, code)] = text
    except OSError:
        pass
    _reconcile_open_kind(con, "register_open", active)
    return len(active)

# Every open-work source reconciles into open_ends. Collectors must not keep a
# parallel list file; dashboard readers consume export.data.loose_ends only.
COLLECTORS.update({
    "todo_open": collect_todo_open,
    "nightly_finding": collect_nightly_findings,
    "repo_dirty": collect_repo_dirty,
    "register_open": collect_register_open,
})

def _scan_errors_24h():
    p = scanlog_path()
    if not os.path.exists(p):
        return 0
    cut, n = time.time() - 24 * 3600, 0
    with open(p) as f:
        for ln in f:
            try:
                if int(ln.split(" ", 1)[0]) >= cut:
                    n += 1
            except (ValueError, IndexError):
                continue
    return n

def _last_full_ingest_epoch():
    p = marker_path()
    if not os.path.exists(p):
        return None
    try:
        return int(os.path.getmtime(p))
    except OSError:
        return None

def _truthy(raw):
    return str(raw).strip().lower() not in ("", "0", "false", "no", "off", "disabled")

def _tier2_export_providers():
    """Return providers whose inferred cards may supersede Tier 1 in exports."""
    state_home = os.path.expanduser(os.environ.get(
        "MISSION_CONTROL_HOME", "~/.mission-control"))
    try:
        with open(os.path.join(state_home, "outcome-extractor", "config.json")) as handle:
            config = json.load(handle)
    except (OSError, ValueError):
        config = None
    if isinstance(config, dict) and config.get("schema") == (
            "mission-control/outcome-extractor-config/v1"):
        # Persistent off and calibrated provider scope dominate inherited
        # positive environment state. Environment may only tighten to off.
        if config.get("enabled") is not True:
            return set()
        call_cap = config.get("daily_call_cap")
        token_cap = config.get("daily_token_cap")
        if (not isinstance(call_cap, int) or isinstance(call_cap, bool) or
                not 1 <= call_cap <= 100 or
                not isinstance(token_cap, int) or isinstance(token_cap, bool) or
                not 1 <= token_cap <= 10000000):
            return set()
        providers = config.get("providers") if isinstance(
            config.get("providers"), dict) else {}
        if (set(providers) != set(CHAT_PROVIDERS) or
                any(not isinstance(providers[name], bool) for name in CHAT_PROVIDERS)):
            return set()
        enabled = {provider for provider in CHAT_PROVIDERS
                   if providers.get(provider) is True}
    elif _truthy(os.environ.get("MORNING_BRIEF_LLM_TESTING", "0")):
        enabled = set(CHAT_PROVIDERS)
    else:
        return set()
    if not _truthy(os.environ.get("MORNING_BRIEF_LLM", "1")):
        return set()
    return {provider for provider in enabled
            if _truthy(os.environ.get(
                "MORNING_BRIEF_LLM_%s" % provider.upper(), "1"))}

def _outcome_export(con, cutoff):
    """Return current observed cards plus bounded observation-change events."""
    tier2_providers = _tier2_export_providers()
    grouped = {}
    rows = con.execute("""SELECT o.observation_id,o.session_id,o.tail_hash,
                       o.observed_at,o.finalized AS observed_finalized,
                       o.evidence_fingerprint AS observed_fingerprint,
                       v.id,v.provider,v.outcome_json,v.extraction_status,
                       v.method,v.confidence,v.source_start,v.source_end,v.source_span
                       FROM session_outcome_observations o
                       JOIN session_outcomes v ON v.id=o.outcome_id
                       ORDER BY o.session_id,o.observation_id""").fetchall()
    for row in rows:
        grouped.setdefault(row["session_id"], []).append(row)
    latest, updates = [], []
    for sid in sorted(grouped):
        previous, latest_card = None, None
        for row in grouped[sid]:
            if (row["method"] or "tier1") == "tier2" and row["provider"] not in tier2_providers:
                continue
            try:
                card = json.loads(row["outcome_json"])
            except (TypeError, ValueError):
                continue
            card["provider"] = _safe_provider(row["provider"], "chat")
            card["tail_hash"] = row["tail_hash"]
            card["extraction_status"] = row["extraction_status"] or card.get("extraction_status")
            card["finalized"] = bool(row["observed_finalized"])
            card["updated_at"] = row["observed_at"]
            card["method"] = row["method"] or card.get("method")
            card["confidence"] = row["confidence"]
            card["evidence_fingerprint"] = row["observed_fingerprint"]
            card.pop("resolution_markers", None)
            # Evidence changes within one extraction lane are late updates.
            # A Tier-2 rewrite of the same source tail is enrichment, while
            # appended chatter that preserves the selected structured evidence
            # is also not a late closeout.
            lane_enrichment = bool(
                previous is not None and previous["tail_hash"] == row["tail_hash"] and
                (previous["method"] or "tier1") != (row["method"] or "tier1"))
            changed = (previous is not None and
                       (bool(previous["observed_finalized"]) != bool(row["observed_finalized"]) or
                        (previous["observed_fingerprint"] != row["observed_fingerprint"] and
                         not lane_enrichment)))
            if changed and row["observed_at"] >= cutoff:
                updates.append({
                    "id": "%s:observation:%s" % (
                        card.get("card_id") or sid, row["observation_id"]),
                    "stable_id": card.get("card_id") or _sha1("outcome-card:%s" % sid),
                    "session_id": sid,
                    "provider": card["provider"],
                    "change_type": "late_update",
                    "previous_tail_hash": previous["tail_hash"],
                    "tail_hash": row["tail_hash"],
                    "previous_finalized": bool(previous["observed_finalized"]),
                    "finalized": bool(row["observed_finalized"]),
                    "updated_at": row["observed_at"],
                    "method": row["method"] or "tier1",
                })
            previous, latest_card = row, card
        if latest_card is not None:
            meta = con.execute("SELECT id,title,first_prompt,repo FROM sessions WHERE id=?",
                               (sid,)).fetchone()
            if meta is not None:
                # These are deterministic graph facts, not model-generated
                # narrative.  The composer applies the shared egress policy.
                latest_card["session_title"] = display_title(meta)
                latest_card["repo"] = meta["repo"] or ""
            latest.append(latest_card)
    updates.sort(key=lambda item: (item.get("updated_at") or 0, item["id"]))
    return latest, updates[-500:]

def _build_export(con, ingest_skipped=False):
    now = int(time.time())
    last_full = _last_full_ingest_epoch()
    session_identity = {
        r["id"]: (_safe_provider(r["provider"], r["node_kind"]),
                  r["node_kind"] or _node_kind(r["id"], r["provider"]))
        for r in con.execute("SELECT id, provider, node_kind FROM sessions")}
    prov_of = {sid: ident[0] for sid, ident in session_identity.items()}
    kind_of = {sid: ident[1] for sid, ident in session_identity.items()}
    node_meta = {}
    nodes = []
    for r in con.execute("SELECT * FROM sessions"):
        opens = [{"kind": o["kind"], "text": redact(o["text"] or ""), "text_hash": o["text_hash"],
                  "item_key": o["item_key"], "first_seen_at": o["first_seen_at"],
                  "updated_at": o["updated_at"]}
                 for o in con.execute("SELECT kind, text, text_hash, item_key, first_seen_at, updated_at FROM open_ends "
                                      "WHERE session_id=? AND resolved_at IS NULL", (r["id"],))]
        try:
            la = int(r["last_activity"])
        except (TypeError, ValueError):
            la = None
        node_kind = r["node_kind"] or _node_kind(r["id"], r["provider"])
        prov = _safe_provider(r["provider"], node_kind)
        node_meta[r["id"]] = {
            "provider": prov,
            "node_kind": node_kind,
            "title": display_title(r),
            "repo": r["repo"] or "",
        }
        nodes.append({
            "provider": prov, "node_kind": node_kind,
            "id": r["id"], "title": node_meta[r["id"]]["title"],
            "repo": r["repo"] or "",
            "last_activity": (time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime(la)) if la else ""),
            "first_seen_at": r["first_seen_at"],
            "live": la is not None and (now - la) < 30 * 60,
            "closeout_seen": bool(r["closeout_seen"]),
            "open_ends": opens,
            "resume_cmd": _resume_cmd(prov, r["id"]) if node_kind == "chat" else "",
            "view_cmd": "chat-source full %s" % r["id"] if node_kind == "chat" else "",
        })
    loose_ends = []
    for o in con.execute("SELECT session_id, kind, text, text_hash, item_key, first_seen_at, updated_at "
                         "FROM open_ends "
                         "WHERE resolved_at IS NULL ORDER BY COALESCE(first_seen_at, 0), id"):
        meta = node_meta.get(o["session_id"], {})
        first_seen = o["first_seen_at"] or now
        age_days = max(0, int((now - int(first_seen)) // 86400))
        text = redact(o["text"] or "")
        kind = o["kind"] or "open"
        loose_ends.append({
            "id": "%s:%s" % (o["session_id"], o["item_key"]),
            "kind": kind,
            "source_node": _provider_key(meta.get("provider"), o["session_id"]),
            "title": meta.get("title") or o["session_id"],
            "repo": meta.get("repo") or "",
            "text": text,
            "text_hash": o["text_hash"],
            "item_key": o["item_key"],
            "first_seen_at": first_seen,
            "updated_at": o["updated_at"] or first_seen,
            "action_hint": _loose_action(kind),
            "age_days": age_days,
            "severity": _loose_severity(kind, text, age_days),
            "resolve_cmd": "chat-graph resolve %s %s" % (o["session_id"], o["text_hash"]),
        })
    loose_end_changes = []
    cutoff = now - 7 * 86400
    for o in con.execute("""SELECT session_id, kind, text, text_hash, item_key,
                         first_seen_at, updated_at, resolved_at, last_change_type,
                         resolution_evidence_type, resolution_evidence_ref
                         FROM open_ends WHERE COALESCE(updated_at, first_seen_at, 0) >= ?
                         ORDER BY COALESCE(updated_at, first_seen_at, 0) DESC, item_key DESC
                         LIMIT 500""", (cutoff,)):
        meta = node_meta.get(o["session_id"], {})
        updated = o["updated_at"] or o["first_seen_at"] or now
        loose_end_changes.append({
            "id": "%s:%s" % (o["session_id"], o["item_key"]),
            "stable_id": "%s:%s" % (o["session_id"], o["item_key"]),
            "source_id": o["session_id"],
            "source_node": _provider_key(meta.get("provider"), o["session_id"]),
            "kind": o["kind"] or "open",
            "item_key": o["item_key"],
            "text": redact(o["text"] or ""),
            "text_hash": o["text_hash"],
            "change_type": o["last_change_type"] or ("resolved" if o["resolved_at"] else "new"),
            "updated_at": updated,
            "resolved_at": o["resolved_at"],
            "resolution_evidence_type": o["resolution_evidence_type"],
            "resolution_evidence_ref": o["resolution_evidence_ref"],
        })
    outcomes, outcome_updates = _outcome_export(con, cutoff)
    outcome_egress = {}
    for card in outcomes:
        for key, value in (card.get("egress_counters") or {}).items():
            if isinstance(value, int):
                outcome_egress[key] = outcome_egress.get(key, 0) + value
    edges = []
    excluded_lineage = 0
    # suppressions is source-independent: hide any (src,dst,type) an unlink
    # suppressed, regardless of which source's row is currently active.
    for e in con.execute(
            "SELECT e.* FROM edges e WHERE e.status='active' "
            "AND NOT EXISTS(SELECT 1 FROM suppressions s "
            "WHERE s.src=e.src AND s.dst=e.dst AND s.type=e.type)"):
        if (kind_of.get(e["src"]) != "chat" or kind_of.get(e["dst"]) != "chat" or
                prov_of.get(e["src"]) not in CHAT_PROVIDERS or
                prov_of.get(e["dst"]) not in CHAT_PROVIDERS):
            excluded_lineage += 1
            continue
        edge = {"src": "%s:%s" % (prov_of.get(e["src"], "unknown"), e["src"]),
                "dst": "%s:%s" % (prov_of.get(e["dst"], "unknown"), e["dst"]),
                "type": e["type"], "source": e["source"],
                "confidence": e["confidence"], "note": e["note"]}
        if e["confidence"] is not None and e["confidence"] < 0.7:
            edge["unlink_cmd"] = "chat-graph unlink %s %s --type %s" % (e["src"], e["dst"], e["type"])
        edges.append(edge)
    tmap = {}
    for r in con.execute("SELECT code, session_id FROM session_topics"):
        tmap.setdefault(r["code"], []).append(r["session_id"])
    topics = [{"code": c, "sessions": sorted(m)} for c, m in sorted(tmap.items()) if len(m) >= 2]
    repo_annotations, notes = _repo_annotations()
    scanned = int(_get_meta(con, "scan_files_scanned", 0) or 0)
    yld = int(_get_meta(con, "scan_files_yield", 0) or 0)
    lt = time.localtime(now)
    midnight = now - (lt.tm_hour * 3600 + lt.tm_min * 60 + lt.tm_sec)
    health_row = con.execute("""SELECT day,calls,successes,input_tokens,output_tokens,
        cache_hits,deferred,failures,budget_skips,provider_skips,disabled_skips,
        privacy_skips,uncalibrated_skips,lock_skips,backoff_skips,escalations,total_latency_ms,
        last_status,updated_at FROM outcome_extraction_health
        ORDER BY day DESC LIMIT 1""").fetchone()
    outcome_health = dict(health_row) if health_row else {
        "day": None, "calls": 0, "successes": 0, "input_tokens": 0,
        "output_tokens": 0, "cache_hits": 0, "deferred": 0, "failures": 0,
        "budget_skips": 0, "provider_skips": 0, "disabled_skips": 0,
        "privacy_skips": 0, "uncalibrated_skips": 0, "lock_skips": 0,
        "backoff_skips": 0,
        "escalations": 0, "total_latency_ms": 0, "last_status": "never",
        "updated_at": None,
    }
    counts = {
        "new_today": con.execute("SELECT COUNT(*) c FROM sessions WHERE first_seen_at >= ?",
                                 (midnight,)).fetchone()["c"],
        "scan_errors_24h": _scan_errors_24h(),
        "signal_yield": "%d/%d" % (yld, scanned),
        "last_full_ingest_epoch": last_full,
        "last_full_ingest_age_s": (now - last_full if last_full is not None else None),
        "ingest_skipped": bool(ingest_skipped),
        "unknown_provider_nodes": sum(1 for n in nodes if n["node_kind"] == "unknown"),
        "excluded_lineage_edges": excluded_lineage,
        "outcome_cards": len(outcomes),
        "outcome_updates": len(outcome_updates),
        "unknown_outcome_providers": sum(1 for card in outcomes
                                         if card.get("provider") == "unknown"),
    }
    return {
        "schema": 1, "feed": "chats",
        "generated_at": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime(now)),
        "generated_epoch": now, "cadence_s": 1800, "ok": True, "error": None,
        "data": {"nodes": nodes, "edges": edges, "topics": topics,
                 "outcomes": outcomes, "outcome_updates": outcome_updates,
                 "outcome_egress_counters": outcome_egress,
                 "outcome_extraction_health": outcome_health,
                 "loose_ends": loose_ends, "loose_end_changes": loose_end_changes,
                 "repo_annotations": repo_annotations,
                 "stale_providers": sorted(_STALE_PROVIDERS), "notes": notes, "counts": counts},
    }

def cmd_export(args):
    global _INGEST_SKIPPED
    out = args[args.index("--out") + 1] if "--out" in args else None
    # --catchup-limit N (default 1500): a stale export triggers a catch-up ingest;
    # bound its file scan with --limit-files so export ALWAYS reaches os.rename within
    # a feed timeout. Cursors let successive ticker fires extend coverage. 0 = unbounded.
    catchup = int(args[args.index("--catchup-limit") + 1]) if "--catchup-limit" in args else 1500
    age = _ingest_age()
    ingest_skipped = False
    if age is None or age > STALE_INGEST_S:  # ONLY catch-up-on-query entry point
        cmd_ingest(["--limit-files", str(catchup)] if catchup > 0 else [])
        ingest_skipped = _INGEST_SKIPPED
    con = connect()
    data = _build_export(con, ingest_skipped=ingest_skipped)
    con.close()
    dest = out or os.path.join(HOME_DIR(), "export", "graph.json")
    ensure_dir(os.path.dirname(dest))
    tmp = "%s.tmp.%d" % (dest, os.getpid())
    with open(tmp, "w") as f:
        json.dump(data, f, ensure_ascii=True, indent=2)  # ascii escapes emoji/U+2028
        f.flush(); os.fsync(f.fileno())
    os.rename(tmp, dest)  # atomic: readers never see a partial file
    print("exported %s" % dest)
    return 0

def cmd_validate_export(args):
    if not args:
        sys.stderr.write("usage: chat-graph validate-export <file>\n"); return 1
    try:
        with open(args[0]) as f:
            d = json.load(f)
    except Exception as e:
        print("FAIL: cannot read/parse: %s" % e); return 1
    errs = []
    for k in ("schema", "feed", "generated_at", "generated_epoch", "cadence_s", "ok", "data"):
        if k not in d:
            errs.append("missing envelope key: %s" % k)
    if d.get("schema") != 1:
        errs.append("schema != 1")
    data = d.get("data") or {}
    for k in ("nodes", "edges", "topics", "outcomes", "outcome_updates",
              "outcome_extraction_health", "loose_ends", "loose_end_changes", "counts"):
        if k not in data:
            errs.append("missing data key: %s" % k)
    if "outcomes" in data and not isinstance(data.get("outcomes"), list):
        errs.append("data.outcomes is not a list")
    if "outcome_updates" in data and not isinstance(data.get("outcome_updates"), list):
        errs.append("data.outcome_updates is not a list")
    if "outcome_extraction_health" in data and not isinstance(
            data.get("outcome_extraction_health"), dict):
        errs.append("data.outcome_extraction_health is not an object")
    if "loose_ends" in data and not isinstance(data.get("loose_ends"), list):
        errs.append("data.loose_ends is not a list")
    if "loose_end_changes" in data and not isinstance(data.get("loose_end_changes"), list):
        errs.append("data.loose_end_changes is not a list")
    for n in data.get("nodes", []):
        if not n.get("id"):
            errs.append("node missing id")
        if not (n.get("title") or "").strip():
            errs.append("node %s has empty title" % n.get("id"))
        if n.get("node_kind") not in ("chat", "repo", "unknown"):
            errs.append("node %s has invalid node_kind" % n.get("id"))
        if n.get("provider") not in CHAT_PROVIDERS | {"repo", "unknown"}:
            errs.append("node %s has unsafe provider" % n.get("id"))
    for e in data.get("edges", []):
        if any(k not in e for k in ("src", "dst", "type", "source", "confidence")):
            errs.append("edge missing required field: %r" % e); continue
        c = e.get("confidence")
        if not isinstance(c, (int, float)) or not (0.0 <= c <= 1.0):
            errs.append("edge confidence out of range: %r" % c)
    for o in data.get("loose_ends", []):
        missing = [k for k in ("id", "kind", "source_node", "title", "text", "action_hint",
                               "age_days", "severity", "resolve_cmd") if k not in o]
        if missing:
            errs.append("loose_end missing %s: %r" % (",".join(missing), o)); continue
        if o.get("severity") not in ("red", "amber", "grey", "green"):
            errs.append("loose_end severity out of range: %r" % o.get("severity"))
        if not isinstance(o.get("age_days"), int):
            errs.append("loose_end age_days is not an int: %r" % o.get("age_days"))
    for c in data.get("loose_end_changes", []):
        missing = [k for k in ("id", "stable_id", "source_id", "kind", "item_key",
                               "change_type", "updated_at") if k not in c]
        if missing:
            errs.append("loose_end_change missing %s: %r" % (",".join(missing), c)); continue
        if c.get("change_type") not in ("new", "updated", "resolved", "reopened"):
            errs.append("loose_end_change invalid change_type: %r" % c.get("change_type"))
    for card in data.get("outcomes", []):
        missing = [k for k in ("card_id", "session_id", "provider", "classification",
                               "grammar", "tail_hash", "finalized", "method") if k not in card]
        if missing:
            errs.append("outcome missing %s: %r" % (",".join(missing), card)); continue
        if card.get("provider") not in CHAT_PROVIDERS | {"unknown"}:
            errs.append("outcome has unsafe provider: %r" % card.get("provider"))
    for update in data.get("outcome_updates", []):
        missing = [k for k in ("id", "stable_id", "session_id", "change_type",
                               "previous_tail_hash", "tail_hash", "updated_at")
                   if k not in update]
        if missing:
            errs.append("outcome_update missing %s: %r" % (",".join(missing), update))
    if errs:
        for e in errs:
            print("FAIL: %s" % e)
        return 1
    print("ok: %s valid (%d nodes, %d edges)" % (args[0], len(data.get("nodes", [])),
                                                 len(data.get("edges", []))))
    return 0

# ---- ingest (mkdir-locked) ------------------------------------------------
def _acquire_ingest_lock():
    """mkdir lock; stale locks (>LOCK_STALE_S) from a crashed ingest are removed."""
    lp = lock_path()
    try:
        os.mkdir(lp)
        return True
    except FileExistsError:
        try:
            age = time.time() - os.path.getmtime(lp)
            if age > LOCK_STALE_S:
                os.rmdir(lp)
                os.mkdir(lp)
                sys.stderr.write("chat-graph: removed stale ingest lock (%.0f min old)\n"
                                 % (age / 60))
                return True
        except OSError:
            pass
        print("chat-graph: ingest lock held — another ingest is running, skipping")
        return False

def cmd_ingest(args):
    global _INGEST_SKIPPED
    _INGEST_SKIPPED = False
    only = args[args.index("--collector") + 1] if "--collector" in args else None
    full = "--full" in args
    limit = int(args[args.index("--limit-files") + 1]) if "--limit-files" in args else None
    ensure_dir(HOME_DIR())
    ensure_dir(os.path.dirname(journal_path()))  # healthy home always has journal/ + logs/
    ensure_dir(os.path.dirname(scanlog_path()))
    if not _acquire_ingest_lock():
        _INGEST_SKIPPED = True
        return 0
    try:
        con = connect()
        # structured collectors run before the scan so `stats` shows edges fast.
        if only != "scan":
            names = [only] if only else list(COLLECTORS)
            for name in names:
                fn = COLLECTORS.get(name)
                if not fn:
                    sys.stderr.write("chat-graph: unknown collector %r\n" % name)
                    return 2
                rows = fn(con)
                con.execute("INSERT INTO collector_state(collector, cursor, last_run, row_count) "
                            "VALUES(?, NULL, ?, ?) ON CONFLICT(collector) DO UPDATE SET "
                            "last_run=excluded.last_run, row_count=excluded.row_count",
                            (name, int(time.time()), rows))
            con.commit()
        if only is None or only == "scan":
            ferr, total = scan_transcripts(con, full=full, limit_files=limit)
            if total and ferr > 0.2 * total:
                con.close()
                sys.stderr.write("chat-graph: scan aborted — >20%% of files errored (%d/%d)\n"
                                 % (ferr, total))
                return 1
        con.close()
        # --limit-files caps a partial pass: cursors written, but NO completion marker.
        if limit is None:
            with open(marker_path(), "w") as f:
                f.write(str(int(time.time())))
        if _STALE_PROVIDERS:
            print("chat-graph: ingested (degraded providers: %s)" % ",".join(sorted(_STALE_PROVIDERS)))
        else:
            print("chat-graph: ingest complete")
        return 0
    finally:
        try:
            os.rmdir(lock_path())
        except OSError:
            pass

# ---- id resolution --------------------------------------------------------
def known_ids(con):
    ids = set()
    for r in con.execute("SELECT id FROM sessions"):
        ids.add(r["id"])
    for r in con.execute("SELECT src FROM edges UNION SELECT dst FROM edges"):
        ids.add(r["src"])
    ids.discard(None)
    return ids

def resolve_id(con, needle):
    ids = known_ids(con)
    if needle in ids:
        return needle
    hits = sorted(i for i in ids if i.startswith(needle))
    if len(hits) == 1:
        return hits[0]
    if len(hits) > 1:
        sys.stderr.write("chat-graph: ambiguous id %r, candidates:\n  %s\n"
                         % (needle, "\n  ".join(hits[:5])))
        sys.exit(2)
    # unknown but usable (e.g. manual link to a not-yet-ingested id) — warn so a
    # mistyped prefix isn't silently written as a wrong key.
    sys.stderr.write("note: %r not found in graph; using as-is\n" % needle)
    return needle

# ---- manual commands ------------------------------------------------------
def cmd_link(args):
    a, b = args[0], args[1]
    etype = args[args.index("--type") + 1] if "--type" in args else "related_manual"
    note = args[args.index("--note") + 1] if "--note" in args else None
    if etype not in EDGE_TYPES:
        sys.stderr.write("chat-graph: unknown edge type %r (%s)\n" % (etype, ", ".join(EDGE_TYPES)))
        return 2
    con = connect()
    a, b = resolve_id(con, a), resolve_id(con, b)  # canonicalize BEFORE journal/db
    journal_append({"op": "link", "a": a, "b": b, "type": etype, "note": note})
    _apply_link(con, a, b, etype, note)
    con.commit(); con.close()
    print("linked %s %s %s" % (a, b, etype))
    return 0

def cmd_unlink(args):
    a, b = args[0], args[1]
    etype = args[args.index("--type") + 1] if "--type" in args else None
    con = connect()
    a, b = resolve_id(con, a), resolve_id(con, b)  # canonicalize BEFORE journal/db
    journal_append({"op": "unlink", "a": a, "b": b, "type": etype})
    _apply_unlink(con, a, b, etype)
    con.commit(); con.close()
    print("unlinked %s %s %s" % (a, b, etype or "(all types)"))
    return 0

def cmd_resolve(args):
    sid, text_hash = args[0], args[1]
    con = connect()
    sid = resolve_id(con, sid)  # canonicalize BEFORE journal/db (text_hash stays literal)
    journal_append({"op": "resolve", "a": sid, "b": text_hash})
    _apply_resolve(con, sid, text_hash)
    con.commit(); con.close()
    print("resolved open-end %s on %s" % (text_hash, sid))
    return 0

# ---- read commands --------------------------------------------------------
def _ingest_age():
    try:
        return time.time() - os.path.getmtime(marker_path())
    except OSError:
        return None

def cmd_show(args):
    con = connect()
    sid = resolve_id(con, args[0])
    row = con.execute("SELECT * FROM sessions WHERE id=?", (sid,)).fetchone()
    print("=== %s ===" % sid[:8])
    if row:
        print("  id:      %s" % sid)
        print("  provider: %s" % (row["provider"] or "-"))
        print("  title:   %s" % display_title(row))
        print("  repo:    %s" % (row["repo"] or "-"))
    else:
        print("  id:      %s" % sid)
        print("  (no cached session metadata)")
    print("  neighbors:")
    neigh = con.execute(
        "SELECT e.src, e.dst, e.type, e.source, e.confidence, e.status, e.note FROM edges e "
        "WHERE (e.src=? OR e.dst=?) AND e.status='active' "
        "AND NOT EXISTS(SELECT 1 FROM suppressions s "
        "WHERE s.src=e.src AND s.dst=e.dst AND s.type=e.type) "
        "ORDER BY e.type", (sid, sid)).fetchall()
    if not neigh:
        print("    (none)")
    last_type = None
    for e in neigh:
        if e["type"] != last_type:
            print("    [%s]" % e["type"]); last_type = e["type"]
        other = e["dst"] if e["src"] == sid else e["src"]
        arrow = "->" if e["src"] == sid else "<-"
        tag = " (%s)" % e["note"] if e["note"] else ""
        print("      %s %s  conf=%.2f src=%s%s" % (arrow, other[:8], e["confidence"], e["source"], tag))
    opens = con.execute("SELECT kind, text, text_hash FROM open_ends "
                        "WHERE session_id=? AND resolved_at IS NULL", (sid,)).fetchall()
    print("  open ends:")
    if not opens:
        print("    (none)")
    for o in opens:
        print("    [%s] %s (%s)" % (o["kind"] or "?", redact(o["text"] or ""), o["text_hash"]))
    con.close()
    age = _ingest_age()
    if age is not None and age > STALE_INGEST_S:
        print("warning: last ingest %d min ago — run 'chat-graph ingest' to refresh" % int(age // 60))
    return 0

def cmd_stats(args):
    con = connect()
    print("collectors:")
    for r in con.execute("SELECT collector, cursor, last_run, row_count FROM collector_state ORDER BY collector"):
        when = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime(r["last_run"])) if r["last_run"] else "never"
        print("  %-12s rows=%-4d cursor=%s last_run=%s" % (r["collector"], r["row_count"], r["cursor"] or "-", when))
    for label, sql in (("sessions", "SELECT COUNT(*) c FROM sessions"),
                       ("edges (active)", "SELECT COUNT(*) c FROM edges WHERE status='active'"),
                       ("edges (suppressed)", "SELECT COUNT(*) c FROM edges WHERE status='suppressed'"),
                       ("topics", "SELECT COUNT(*) c FROM session_topics"),
                       ("open_ends", "SELECT COUNT(*) c FROM open_ends")):
        print("  %-20s %d" % (label, con.execute(sql).fetchone()["c"]))
    scanned = int(_get_meta(con, "scan_files_scanned", 0) or 0)
    yld = int(_get_meta(con, "scan_files_yield", 0) or 0)
    print("  %-20s %d/%d" % ("signal_yield", yld, scanned))
    print("  %-20s %d" % ("scan_errors_24h", _scan_errors_24h()))
    if scanned > 100 and yld == 0:
        print("  warning: %d files scanned, 0 signals — scanner may be blind" % scanned)
    if _STALE_PROVIDERS:
        print("  stale_providers: %s" % ",".join(sorted(_STALE_PROVIDERS)))
    con.close()
    return 0

def cmd_doctor(args):
    problems = 0
    def check(ok, msg):
        nonlocal problems
        print(("ok:   " if ok else "FAIL: ") + msg)
        if not ok:
            problems += 1
    def warn(ok, msg):  # advisory: prints but never fails doctor (sweep FIX 7)
        print(("ok:   " if ok else "WARN: ") + msg)
    home = HOME_DIR()
    check(os.path.isdir(home), "home dir exists: %s" % home)
    if os.path.isdir(home):
        mode = os.stat(home).st_mode & 0o777
        check(mode == 0o700, "home dir perms 700 (got %o)" % mode)
    jdir = os.path.dirname(journal_path())
    check(os.path.isdir(jdir), "journal dir exists: %s" % jdir)
    if os.path.exists(journal_path()):
        check(os.access(journal_path(), os.R_OK), "journal readable")
    exe = CHAT_SOURCE()
    check(bool(exe and os.path.exists(exe)), "chat-source present: %s" % exe)
    try:
        con = connect()
        qc = con.execute("PRAGMA quick_check").fetchone()[0]
        check(qc == "ok", "db quick_check: %s" % qc)
        con.close()
    except Exception as e:
        check(False, "db open: %s" % e)
    age = _ingest_age()
    check(age is None or age <= STALE_INGEST_S,
          "last-ingest age: %s" % ("never" if age is None else "%dm" % int(age // 60)))
    try:
        free_gb = shutil.disk_usage(home).free / 1e9
        check(free_gb > 1.0, "free disk > 1 GB (%.1f GB)" % free_gb)
    except Exception as e:
        check(False, "disk usage: %s" % e)
    errs = 0
    if os.path.exists(scanlog_path()):
        with open(scanlog_path()) as f:
            errs = sum(1 for _ in f)
    # sweep FIX 7: transient scan-error log lines (e.g. one malformed transcript, or a
    # /tmp test file) must NOT fail doctor — the scanner already skips bad lines by
    # design. WARN for a modest count; FAIL only when it's large enough to signal a
    # structural scan problem (matches the scanner's >20-file abort posture).
    if errs > 20:
        check(False, "scan-error count: %d (large — likely a structural scan problem)" % errs)
    else:
        warn(errs == 0, "scan-error count: %d (transient; run reindex to clear the log)" % errs)
    return 1 if problems else 0

def cmd_rebuild(args):
    # fresh schema + collectors + replay journal in recorded order.
    try:
        os.remove(db_path())
    except OSError:
        pass
    for wal in (db_path() + "-wal", db_path() + "-shm"):
        try:
            os.remove(wal)
        except OSError:
            pass
    rc = cmd_ingest([])
    if rc not in (0,):
        return rc
    con = connect()
    journal_replay(con)
    con.close()
    print("chat-graph: rebuild complete")
    return 0

def cmd_self_test(args):
    here = os.path.dirname(os.path.abspath(__file__))
    test = os.path.join(here, "chat-graph.test.sh")
    print("self-test: %s" % test)
    return subprocess.call(["bash", test])

def cmd_extract_outcomes(args):
    # Import only for the explicit command. Ingest and export never load or call
    # the model lane, preserving their deterministic/collector-only contract.
    import outcome_extractor
    return outcome_extractor.run(sys.modules[__name__], args)

# ---- dispatch -------------------------------------------------------------
USAGE = ("usage: chat-graph {ingest|extract-outcomes|export|validate-export|link|unlink|resolve|show|stats|doctor|rebuild|--self-test}\n"
         "  ingest [--collector NAME] [--full] [--limit-files N]\n"
         "  extract-outcomes [--days N] [--limit N] [--sample-per-provider N]\n"
         "                   [--apply-calibration PATH] [--set-enabled 0|1] [--json]\n"
         "  export --json [--out PATH] [--catchup-limit N]   validate-export <file>\n"
         "  link A B --type T [--note ..]   unlink A B [--type T]   resolve <id> <text-hash>\n"
         "  show <id>   stats   doctor   rebuild   --self-test")

def main(argv):
    if not argv:
        print(USAGE); return 1
    cmd, args = argv[0], argv[1:]
    table = {
        "ingest": cmd_ingest, "extract-outcomes": cmd_extract_outcomes,
        "export": cmd_export, "validate-export": cmd_validate_export,
        "link": cmd_link, "unlink": cmd_unlink,
        "resolve": cmd_resolve, "show": cmd_show, "stats": cmd_stats,
        "doctor": cmd_doctor, "rebuild": cmd_rebuild,
        "--self-test": cmd_self_test, "self-test": cmd_self_test,
    }
    fn = table.get(cmd)
    if not fn:
        print(USAGE); return 1
    return fn(args) or 0

if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
