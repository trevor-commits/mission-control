#!/usr/bin/env python3
"""Conservative loose-end runner: explicit branch-push proposals only.

Hard boundaries for this initial implementation:
- default dry-run; no flag can enable a push
- never merge, force-push, delete, edit human documents, or spawn workers
- never act on default/protected, checked-out, dirty, recent, unknown, behind,
  diverged, untracked, credential-remote, or stale-fact branches
- recompute branch facts immediately before every proposal
- log exact redacted before/after evidence with permission-restricted JSONL
- stop before scanning/planning when $MISSION_CONTROL_HOME/loose-end-runner/DISABLE exists

Automatic push activation is deliberately absent. A reviewed live-ledger
dry-run and a later explicit activation decision are separate gates.
"""

from __future__ import annotations

import argparse
import fcntl
import hashlib
import json
import os
import re
import stat
import subprocess
import sys
import time
from pathlib import Path
from typing import Any

SCRIPT_DIR = os.path.dirname(os.path.realpath(__file__))
sys.path.insert(0, SCRIPT_DIR)
from mission_control_common import ACTION, sanitize_text


SAFE_REMOTE_CLASSES = {"https", "ssh", "local"}
MIN_ACTIVITY_GUARD_SECONDS = 6 * 60 * 60
REASON_RE = re.compile(r"^[a-z0-9_]{1,80}$")
REF_RE = re.compile(r"^refs/heads/[A-Za-z0-9._/-]+$")
REMOTE_RE = re.compile(r"^[A-Za-z0-9._-]+$")


class ScanError(RuntimeError):
    pass


def parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser(description="Dry-run conservative loose-end proposals")
    p.add_argument("--repo", action="append", default=[], help="exact repository to evaluate")
    p.add_argument("--scanner", default=os.environ.get("SCAN_UNFINISHED_WORK"),
                   help="scanner executable (tests/diagnostics only)")
    p.add_argument("--dry-run", action="store_true", help="explicitly select the default mode")
    p.add_argument("--execute", action="store_true",
                   help=argparse.SUPPRESS)
    return p.parse_args()


def canonical_repo(path: str) -> str:
    return os.path.realpath(os.path.abspath(os.path.expanduser(path)))


def scanner_path(arg: str | None) -> str:
    if arg:
        return os.path.realpath(os.path.abspath(os.path.expanduser(arg)))
    return os.path.join(os.path.dirname(os.path.realpath(__file__)), "scan-unfinished-work")


def scan_payload(scanner: str, argv: list[str]) -> list[dict[str, Any]]:
    env = {**os.environ, "LC_ALL": "C", "GIT_OPTIONAL_LOCKS": "0"}
    proc = subprocess.run(
        [scanner, "--json"] + argv,
        stdin=subprocess.DEVNULL,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
        timeout=120,
        env=env,
    )
    # Scanner exit 1 means valid findings, not an operational failure.
    if proc.returncode not in (0, 1):
        raise ScanError("scanner_failed")
    try:
        payload = json.loads(proc.stdout)
    except (TypeError, json.JSONDecodeError) as exc:
        raise ScanError("scanner_invalid_json") from exc
    repos = payload.get("repos") if isinstance(payload, dict) else None
    if not isinstance(repos, list) or any(not isinstance(item, dict) for item in repos):
        raise ScanError("scanner_repo_count_invalid")
    return repos


def scan(scanner: str, repo: str) -> dict[str, Any]:
    repos = scan_payload(scanner, ["--repo", repo])
    if len(repos) != 1:
        raise ScanError("scanner_repo_count_invalid")
    result = repos[0]
    if canonical_repo(str(result.get("path", ""))) != repo:
        raise ScanError("scanner_repo_mismatch")
    return result


def scan_all(scanner: str) -> list[dict[str, Any]]:
    repos = scan_payload(scanner, [])
    paths: set[str] = set()
    for result in repos:
        path = result.get("path")
        if not isinstance(path, str):
            raise ScanError("scanner_repo_path_invalid")
        canonical = canonical_repo(path)
        if canonical in paths:
            raise ScanError("scanner_duplicate_repo")
        paths.add(canonical)
    return repos


def find_branch(repo_fact: dict[str, Any], name: str) -> dict[str, Any] | None:
    rows = repo_fact.get("branch_facts")
    if not isinstance(rows, list):
        return None
    for row in rows:
        if isinstance(row, dict) and row.get("name") == name:
            return row
    return None


def safe_reasons(value: Any) -> list[str]:
    if not isinstance(value, list):
        return ["refusal_reasons_invalid"]
    result: list[str] = []
    for item in value:
        if isinstance(item, str) and REASON_RE.fullmatch(item):
            result.append(item)
        else:
            result.append("invalid_scanner_reason")
    return sorted(set(result))


def validate_fact(repo: str, row: dict[str, Any], now: int) -> tuple[list[str], list[str] | None]:
    reasons = safe_reasons(row.get("refusal_reasons"))
    name = row.get("name")
    local_ref = row.get("local_ref")
    upstream_ref = row.get("upstream_ref")
    remote_name = row.get("remote_name")
    remote_class = row.get("remote_classification")
    remote_ref = row.get("remote_branch_ref")

    if not isinstance(name, str) or local_ref != "refs/heads/%s" % name or not REF_RE.fullmatch(str(local_ref)):
        reasons.append("local_branch_ref_invalid")
    if not isinstance(upstream_ref, str) or not upstream_ref.startswith("refs/remotes/"):
        reasons.append("upstream_missing_or_invalid")
    if not isinstance(remote_name, str) or not REMOTE_RE.fullmatch(remote_name):
        reasons.append("remote_missing_or_invalid")
    if remote_class == "credentialed":
        reasons.append("remote_credentials")
    elif remote_class not in SAFE_REMOTE_CLASSES:
        reasons.append("remote_unsafe_or_unknown")
    if not isinstance(remote_ref, str) or not REF_RE.fullmatch(remote_ref):
        reasons.append("remote_branch_ref_invalid")
    ahead, behind = row.get("ahead"), row.get("behind")
    if isinstance(ahead, bool) or not isinstance(ahead, int) or ahead <= 0:
        reasons.append("ahead_not_positive")
    if isinstance(behind, bool) or not isinstance(behind, int):
        reasons.append("behind_unknown")
    elif behind > 0:
        reasons.append("behind_or_diverged")
    if row.get("is_default") is not False:
        reasons.append("default_or_unknown")
    if row.get("is_protected") is not False:
        reasons.append("protected_or_unknown")
    default_branch = row.get("default_branch")
    if not isinstance(default_branch, str) or not default_branch or not re.fullmatch(r"[A-Za-z0-9._/-]+", default_branch):
        reasons.append("default_branch_unknown")
    if row.get("remote_is_default") is not False:
        reasons.append("remote_target_default_or_unknown")
    if row.get("remote_is_protected") is not False:
        reasons.append("remote_target_protected_or_unknown")
    if row.get("checkout_paths") != []:
        reasons.append("branch_checked_out_or_unknown")
    if row.get("worktree_state_known") is not True:
        reasons.append("worktree_state_unknown")
    if row.get("repo_or_worktree_dirty") is not False:
        reasons.append("repo_or_worktree_dirty")

    activity = row.get("last_activity")
    if not isinstance(activity, dict) or activity.get("state") != "stale":
        reasons.append("recent_or_unknown_activity")
    else:
        age, guard = activity.get("age_seconds"), activity.get("guard_seconds")
        if (isinstance(age, bool) or not isinstance(age, int) or
                isinstance(guard, bool) or not isinstance(guard, int) or
                guard < MIN_ACTIVITY_GUARD_SECONDS or
                age < MIN_ACTIVITY_GUARD_SECONDS or age < guard):
            reasons.append("recent_or_unknown_activity")
    if row.get("activity_facts_fresh") is not True:
        reasons.append("activity_facts_not_fresh")
    generated, max_age = row.get("facts_generated_epoch"), row.get("facts_max_age_seconds")
    if (isinstance(generated, bool) or not isinstance(generated, int) or
            isinstance(max_age, bool) or not isinstance(max_age, int) or max_age <= 0 or
            generated > now + 5 or now - generated > min(max_age, 120)):
        reasons.append("facts_stale_or_unknown")
    if row.get("push_eligible") is not True:
        reasons.append("scanner_not_eligible")

    expected = None
    if (isinstance(remote_name, str) and REMOTE_RE.fullmatch(remote_name) and
            isinstance(local_ref, str) and REF_RE.fullmatch(local_ref) and
            isinstance(remote_ref, str) and REF_RE.fullmatch(remote_ref)):
        remote_branch = remote_ref[len("refs/heads/"):]
        expected_upstream = "refs/remotes/%s/%s" % (remote_name, remote_branch)
        if upstream_ref != expected_upstream:
            reasons.append("upstream_remote_mismatch")
        if remote_branch in {"main", "master"} or (isinstance(default_branch, str) and remote_branch == default_branch):
            reasons.append("remote_target_default_or_protected")
        expected = ["git", "-C", repo, "push", "--", remote_name,
                    "%s:%s" % (local_ref, remote_ref)]
        if row.get("proposal_argv") != expected:
            reasons.append("proposal_argv_mismatch")
    else:
        reasons.append("proposal_argv_unconstructable")
    reasons = sorted(set(reasons))
    return reasons, expected if not reasons else None


def safe_str(value: Any, pattern: re.Pattern[str] | None = None) -> str | None:
    if not isinstance(value, str):
        return None
    if pattern and not pattern.fullmatch(value):
        return None
    return value


def snapshot(repo: str, row: dict[str, Any] | None) -> dict[str, Any]:
    if not isinstance(row, dict):
        return {"available": False}
    activity = row.get("last_activity") if isinstance(row.get("last_activity"), dict) else {}
    commit = row.get("last_commit") if isinstance(row.get("last_commit"), dict) else {}
    paths = row.get("checkout_paths")
    safe_paths = [canonical_repo(p) for p in paths if isinstance(p, str)] if isinstance(paths, list) else None
    return {
        "available": True,
        "repo_path": repo,
        "branch": safe_str(row.get("name"), re.compile(r"^[A-Za-z0-9._/-]+$")),
        "local_ref": safe_str(row.get("local_ref"), REF_RE),
        "upstream_ref": safe_str(row.get("upstream_ref"), re.compile(r"^refs/remotes/[A-Za-z0-9._/-]+$")),
        "remote_name": safe_str(row.get("remote_name"), REMOTE_RE),
        "remote_classification": row.get("remote_classification") if row.get("remote_classification") in SAFE_REMOTE_CLASSES | {"credentialed", "missing", "unknown"} else "unknown",
        "remote_branch_ref": safe_str(row.get("remote_branch_ref"), REF_RE),
        "ahead": row.get("ahead") if type(row.get("ahead")) is int else None,
        "behind": row.get("behind") if type(row.get("behind")) is int else None,
        "is_default": row.get("is_default") if type(row.get("is_default")) is bool else None,
        "is_protected": row.get("is_protected") if type(row.get("is_protected")) is bool else None,
        "default_branch": safe_str(row.get("default_branch"), re.compile(r"^[A-Za-z0-9._/-]+$")),
        "remote_is_default": row.get("remote_is_default") if type(row.get("remote_is_default")) is bool else None,
        "remote_is_protected": row.get("remote_is_protected") if type(row.get("remote_is_protected")) is bool else None,
        "checkout_paths": safe_paths,
        "worktree_state_known": row.get("worktree_state_known") is True,
        "repo_or_worktree_dirty": row.get("repo_or_worktree_dirty") if type(row.get("repo_or_worktree_dirty")) is bool else None,
        "last_commit": {
            "sha": safe_str(commit.get("sha"), re.compile(r"^[0-9a-fA-F]{40,64}$")),
            "epoch": commit.get("epoch") if type(commit.get("epoch")) is int else None,
        },
        "last_activity": {
            "epoch": activity.get("epoch") if type(activity.get("epoch")) is int else None,
            "age_seconds": activity.get("age_seconds") if type(activity.get("age_seconds")) is int else None,
            "state": activity.get("state") if activity.get("state") in {"recent", "stale", "unknown"} else "unknown",
            "guard_seconds": activity.get("guard_seconds") if type(activity.get("guard_seconds")) is int else None,
        },
        "facts_generated_epoch": row.get("facts_generated_epoch") if type(row.get("facts_generated_epoch")) is int else None,
        "facts_max_age_seconds": row.get("facts_max_age_seconds") if type(row.get("facts_max_age_seconds")) is int else None,
        "activity_facts_fresh": row.get("activity_facts_fresh") is True,
        "push_eligible": row.get("push_eligible") is True,
        "refusal_reasons": safe_reasons(row.get("refusal_reasons")),
    }


def stable_core(snap: dict[str, Any]) -> dict[str, Any]:
    copy = json.loads(json.dumps(snap))
    copy.pop("facts_generated_epoch", None)
    activity = copy.get("last_activity")
    if isinstance(activity, dict):
        activity.pop("age_seconds", None)
    return copy


def item_id(repo: str, branch: str) -> str:
    return "branch:" + hashlib.sha256((repo + "\0" + branch).encode()).hexdigest()[:20]


def privacy_safe_record(record: dict[str, Any]) -> dict[str, Any]:
    """Apply the shared policy to every string that would be persisted.

    If one field is sensitive, retain only content-free control metadata. Raw
    refs, paths, argv, reasons, and snapshots are never partially persisted.
    """
    def rejected(value: Any) -> bool:
        if isinstance(value, str):
            return sanitize_text(value, ACTION).dropped
        if isinstance(value, list):
            return any(rejected(v) for v in value)
        if isinstance(value, dict):
            return any(rejected(k) or rejected(v) for k, v in value.items())
        return False

    if not rejected(record):
        return record
    digest = hashlib.sha256(json.dumps(record, sort_keys=True, default=str).encode()).hexdigest()[:20]
    return {
        "timestamp_epoch": int(record.get("timestamp_epoch") or time.time()),
        "item_id": "privacy:" + digest,
        "tier": "privacy_refusal",
        "mode": "dry-run",
        "decision": "refused",
        "reason": "privacy_rejected",
        "argv": None,
        "before": {"available": False, "privacy_rejected": True},
        "after": {"available": False, "privacy_rejected": True},
    }


def file_snapshot(path: Path) -> dict[str, Any]:
    try:
        data = path.read_bytes()
        st = path.stat()
    except OSError:
        return {"available": False}
    return {
        "available": True,
        "path": str(path),
        "sha256": hashlib.sha256(data).hexdigest(),
        "size": len(data),
        "mtime_ns": st.st_mtime_ns,
    }


def append_jsonl(path: Path, record: dict[str, Any],
                 stop_requested=None) -> bool:
    parent = path.parent
    parent.mkdir(mode=0o700, parents=True, exist_ok=True)
    if parent.is_symlink():
        raise RuntimeError("log_directory_symlink_refused")
    os.chmod(parent, 0o700)
    flags = os.O_WRONLY | os.O_CREAT | os.O_APPEND
    if hasattr(os, "O_NOFOLLOW"):
        flags |= os.O_NOFOLLOW
    fd = os.open(path, flags, 0o600)
    try:
        if not stat.S_ISREG(os.fstat(fd).st_mode):
            raise RuntimeError("log_not_regular_file")
        os.fchmod(fd, 0o600)
        fcntl.flock(fd, fcntl.LOCK_EX)
        blob = (json.dumps(record, sort_keys=True, separators=(",", ":")) + "\n").encode()
        start = os.lseek(fd, 0, os.SEEK_END)
        written = 0
        try:
            if stop_requested is not None and stop_requested():
                return False
            while written < len(blob):
                count = os.write(fd, blob[written:])
                if count <= 0:
                    raise RuntimeError("short_audit_log_write")
                written += count
            os.fsync(fd)
            # DISABLE arriving during the append window rolls the record back
            # under the same exclusive lock, preserving the pre-append length.
            if stop_requested is not None and stop_requested():
                os.ftruncate(fd, start)
                os.fsync(fd)
                return False
        except BaseException:
            os.ftruncate(fd, start)
            os.fsync(fd)
            raise
    finally:
        os.close(fd)
    return True


def main() -> int:
    args = parse_args()
    if args.execute:
        print("loose-end-runner: live execution is not implemented or authorized", file=sys.stderr)
        return 2
    home = Path(os.path.expanduser(os.environ.get("MISSION_CONTROL_HOME", "~/.mission-control")))
    disable = home / "loose-end-runner" / "DISABLE"
    if disable.exists():
        print(json.dumps({"status": "disabled", "dry_run": True, "actions": []}, sort_keys=True))
        return 0
    scanner = scanner_path(args.scanner)
    if not os.path.isfile(scanner) or not os.access(scanner, os.X_OK):
        print("loose-end-runner: scanner unavailable", file=sys.stderr)
        return 2
    repos = [canonical_repo(p) for p in args.repo]
    if len(set(repos)) != len(repos):
        print("loose-end-runner: duplicate repository refused", file=sys.stderr)
        return 2
    log_path = Path(os.path.expanduser(os.environ.get(
        "LOOSE_END_RUNNER_LOG", str(home / "loose-end-runner" / "report.jsonl"))))
    records: list[dict[str, Any]] = []

    def stopped() -> bool:
        return disable.exists()

    def finish_disabled() -> int:
        print(json.dumps({"status": "disabled_during_run", "dry_run": True,
                          "automatic_push_enabled": False, "actions": records}, sort_keys=True))
        return 0

    def persist(record: dict[str, Any]) -> bool:
        # The second check is intentionally adjacent to the append. DISABLE can
        # arrive during discovery/recomputation or privacy screening.
        if stopped():
            return False
        safe_record = privacy_safe_record(record)
        if stopped():
            return False
        if not append_jsonl(log_path, safe_record, stopped):
            return False
        records.append(safe_record)
        return True
    if repos:
        initial_rows: list[tuple[str, dict[str, Any]]] = []
        for repo in repos:
            try:
                initial_rows.append((repo, scan(scanner, repo)))
            except ScanError as exc:
                print("loose-end-runner: %s" % exc, file=sys.stderr)
                return 1
    else:
        try:
            discovered = scan_all(scanner)
        except ScanError as exc:
            print("loose-end-runner: %s" % exc, file=sys.stderr)
            return 1
        initial_rows = [(canonical_repo(str(row["path"])), row) for row in discovered]
    if stopped():
        return finish_disabled()
    for repo, initial in initial_rows:
        rows = initial.get("branch_facts")
        if not isinstance(rows, list):
            print("loose-end-runner: scanner_branch_contract_invalid", file=sys.stderr)
            return 1
        # Any branch with a non-zero remote delta is considered. Behind-only
        # and diverged branches are logged as explicit refusals, not ignored.
        names = sorted({r.get("name") for r in rows
                        if isinstance(r, dict) and isinstance(r.get("name"), str)
                        and ((type(r.get("ahead")) is int and r.get("ahead") > 0) or
                             (type(r.get("behind")) is int and r.get("behind") > 0))})
        for name in names:
            before: dict[str, Any] = {"available": False}
            after: dict[str, Any] = {"available": False}
            try:
                if stopped():
                    return finish_disabled()
                before_repo = scan(scanner, repo)  # action-time recomputation
                before_row = find_branch(before_repo, name)
                before = snapshot(repo, before_row)
                reasons, argv = validate_fact(repo, before_row or {}, int(time.time()))
                if stopped():
                    return finish_disabled()
                after_repo = scan(scanner, repo)
                after_row = find_branch(after_repo, name)
                after = snapshot(repo, after_row)
                after_reasons, after_argv = validate_fact(repo, after_row or {}, int(time.time()))
                reasons = sorted(set(reasons + after_reasons))
                if argv != after_argv:
                    reasons = sorted(set(reasons + ["proposal_changed_during_evaluation"]))
                    argv = None
            except ScanError:
                reasons, argv = ["scanner_recompute_failed"], None
            if stable_core(before) != stable_core(after):
                reasons = sorted(set(reasons + ["facts_changed_during_evaluation"]))
                argv = None
            decision = "proposed" if not reasons and argv else "refused"
            record = {
                "timestamp_epoch": int(time.time()),
                "item_id": item_id(repo, name),
                "tier": "explicit_branch_push",
                "mode": "dry-run",
                "decision": decision,
                "reason": "eligible_dry_run" if decision == "proposed" else ",".join(reasons),
                "argv": argv,
                "before": before,
                "after": after,
            }
            if not persist(record):
                return finish_disabled()

    # The existing collectors are the only safe reconciliation surface. This
    # initial runner proposes their exact fixed argv but never invokes them.
    graph_path = home / "export" / "graph.json"
    chat_graph = Path(SCRIPT_DIR) / "chat-graph"
    if graph_path.is_file() and chat_graph.is_file():
        for collector in ("todo_open", "repo_dirty", "nightly_finding", "register_open"):
            if stopped():
                return finish_disabled()
            before = file_snapshot(graph_path)
            after = file_snapshot(graph_path)
            record = {
                "timestamp_epoch": int(time.time()),
                "item_id": "reconcile:" + collector,
                "tier": "open_end_reconciliation",
                "mode": "dry-run",
                "decision": "proposed",
                "reason": "safe_reconciliation_dry_run",
                "argv": [str(chat_graph), "ingest", "--collector", collector],
                "before": before,
                "after": after,
            }
            if before != after:
                record.update(decision="refused", reason="graph_changed_during_evaluation", argv=None)
            if not persist(record):
                return finish_disabled()

    # Deterministic satisfied-item detection is deliberately narrow: an
    # unchecked item must exactly duplicate a checked item in the same todo.md.
    # The proposal stores hashes/line numbers only and never edits the document.
    todo_re = re.compile(r"^\s*-\s*\[([ xX])\]\s+(.+?)\s*$")
    for repo, _initial in initial_rows:
        if stopped():
            return finish_disabled()
        todo = Path(repo) / "todo.md"
        try:
            if todo.stat().st_size > 2 * 1024 * 1024:
                continue
            lines = todo.read_text(errors="replace").splitlines()
        except OSError:
            continue
        checked: set[str] = set()
        unchecked: list[tuple[int, str, str]] = []
        for number, line in enumerate(lines, 1):
            match = todo_re.match(line)
            if not match:
                continue
            normalized = " ".join(match.group(2).split()).casefold()
            if match.group(1).lower() == "x":
                checked.add(normalized)
            else:
                unchecked.append((number, normalized, match.group(2)))
        for number, normalized, raw_text in unchecked:
            if normalized not in checked:
                continue
            before = file_snapshot(todo)
            after = file_snapshot(todo)
            sensitive = sanitize_text(raw_text, ACTION).dropped
            record = {
                "timestamp_epoch": int(time.time()),
                "item_id": "todo:" + hashlib.sha256((repo + "\0" + normalized).encode()).hexdigest()[:20],
                "tier": "satisfied_todo_detection",
                "mode": "dry-run",
                "decision": "refused" if sensitive else "proposed",
                "reason": "privacy_rejected" if sensitive else "duplicate_checked_item",
                "argv": None,
                "proposal": None if sensitive else "review_checkoff",
                "line_number": number,
                "before": before,
                "after": after,
            }
            if before != after:
                record.update(decision="refused", reason="todo_changed_during_evaluation",
                              proposal=None)
            if not persist(record):
                return finish_disabled()
    print(json.dumps({"status": "dry-run", "dry_run": True,
                      "automatic_push_enabled": False, "actions": records}, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
